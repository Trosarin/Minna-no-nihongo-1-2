<script>
const CARDS = [
  {l:1, t:"N₁は N₂です", de:"N₁ ist N₂", rule:"Grundlegender Aussagesatz. は (wa) markiert das Thema, です ist die höfliche Kopula (»ist«).", ex:[
    {jp:"<ruby>私<rt>わたし</rt></ruby>はマイクです。",de:"Ich bin Mike."},
    {jp:"<ruby>彼<rt>かれ</rt></ruby>は<ruby>学生<rt>がくせい</rt></ruby>です。",de:"Er ist Student."}
  ], note:"は wird als »wa« ausgesprochen, nicht als »ha«."},
  {l:1, t:"N₁は N₂じゃ ありません", de:"N₁ ist NICHT N₂", rule:"Verneinte Form von です. じゃ ありません (umgangssprachlich) oder では ありません (formell).", ex:[
    {jp:"<ruby>私<rt>わたし</rt></ruby>は<ruby>先生<rt>せんせい</rt></ruby>じゃ ありません。",de:"Ich bin kein Lehrer."},
    {jp:"<ruby>彼<rt>かれ</rt></ruby>は<ruby>日本人<rt>にほんじん</rt></ruby>では ありません。",de:"Er ist kein Japaner."}
  ]},
  {l:1, t:"N₁は N₂ですか", de:"Ist N₁ ein N₂? (Frage)", rule:"Anfügen von か am Satzende macht aus der Aussage eine Ja/Nein-Frage. Antwort: はい (ja) / いいえ (nein).", ex:[
    {jp:"あなたは<ruby>学生<rt>がくせい</rt></ruby>ですか。— はい、<ruby>学生<rt>がくせい</rt></ruby>です。",de:"Sind Sie Student? — Ja, ich bin Student."},
    {jp:"ミラーさんは アメリカ<ruby>人<rt>じん</rt></ruby>ですか。",de:"Ist Herr Miller Amerikaner?"}
  ]},
  {l:1, t:"N₁も N₂です", de:"N₁ ist AUCH N₂", rule:"も ersetzt は und drückt aus, dass etwas zusätzlich ebenfalls zutrifft.", ex:[
    {jp:"<ruby>私<rt>わたし</rt></ruby>も<ruby>学生<rt>がくせい</rt></ruby>です。",de:"Ich bin auch Student."},
    {jp:"<ruby>彼<rt>かれ</rt></ruby>もドイツ<ruby>人<rt>じん</rt></ruby>です。",de:"Er ist auch Deutscher."}
  ]},
  {l:1, t:"N₁の N₂", de:"N₁s N₂ (Genitiv/Zugehörigkeit)", rule:"の verbindet zwei Nomen. N₁ beschreibt oder besitzt N₂. Auch für Zugehörigkeit zu Firma/Gruppe.", ex:[
    {jp:"IMCの<ruby>社員<rt>しゃいん</rt></ruby>です。",de:"Ich bin Angestellter von IMC."},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>の<ruby>本<rt>ほん</rt></ruby>",de:"japanisches Buch / Buch der japanischen Sprache"}
  ]},
  {l:2, t:"これ / それ / あれ", de:"dies / das / jenes (Pronomen)", rule:"これ = bei mir, それ = bei dir, あれ = weiter weg von beiden. Stehen alleine als Subjekt.", ex:[
    {jp:"これは<ruby>本<rt>ほん</rt></ruby>です。",de:"Das hier ist ein Buch."},
    {jp:"それは<ruby>何<rt>なん</rt></ruby>ですか。",de:"Was ist das (bei dir)?"},
    {jp:"あれは<ruby>富士山<rt>ふじさん</rt></ruby>です。",de:"Jenes (dort) ist der Fuji."}
  ]},
  {l:2, t:"この / その / あの + N", de:"dieser / jener + Nomen", rule:"Demonstrative Adjektive — stehen IMMER vor einem Nomen (im Gegensatz zu これ/それ/あれ).", ex:[
    {jp:"この<ruby>本<rt>ほん</rt></ruby>は<ruby>私<rt>わたし</rt></ruby>のです。",de:"Dieses Buch gehört mir."},
    {jp:"あの<ruby>人<rt>ひと</rt></ruby>はミラーさんです。",de:"Jene Person dort ist Herr Miller."}
  ]},
  {l:2, t:"そうです / そうじゃ ありません", de:"Ja, so ist es / Nein", rule:"Bestätigung oder Verneinung einer Aussage über ein Substantiv. Bei Frage »Ist das X?« → »はい、そうです / いいえ、そうじゃ ありません«.", ex:[
    {jp:"それは<ruby>辞書<rt>じしょ</rt></ruby>ですか。— はい、そうです。",de:"Ist das ein Wörterbuch? — Ja, das ist es."},
    {jp:"いいえ、そうじゃ ありません。",de:"Nein, das ist es nicht."}
  ]},
  {l:2, t:"N₁ですか、N₂ですか", de:"Ist es N₁ oder N₂? (Auswahlfrage)", rule:"Stellt zwei Optionen zur Auswahl. Antwort wiederholt die gewählte Option (kein はい/いいえ).", ex:[
    {jp:"これはペンですか、シャープペンシルですか。",de:"Ist das ein Kuli oder ein Druckbleistift?"},
    {jp:"— シャープペンシルです。",de:"— Ein Druckbleistift."}
  ]},
  {l:2, t:"N₁の N₂ (Weglassen)", de:"N₂ kann wegfallen", rule:"Wenn aus dem Kontext klar, kann N₂ nach の weggelassen werden — の steht als »der/die/das von …«.", ex:[
    {jp:"この かばんは <ruby>私<rt>わたし</rt></ruby>のです。",de:"Diese Tasche gehört mir (ist meine)."},
    {jp:"あの<ruby>本<rt>ほん</rt></ruby>はミラーさんのです。",de:"Jenes Buch ist Millers (Buch)."}
  ]},
  {l:3, t:"ここ / そこ / あそこ", de:"hier / dort / dort drüben (Ort)", rule:"Ortsangaben. ここ = beim Sprecher, そこ = beim Hörer, あそこ = entfernt von beiden. Höflicher: こちら/そちら/あちら.", ex:[
    {jp:"ここは<ruby>教室<rt>きょうしつ</rt></ruby>です。",de:"Hier ist das Klassenzimmer."},
    {jp:"トイレは あそこです。",de:"Die Toilette ist dort drüben."}
  ], note:"💡 こそあど-System: こ=nah Sprecher, そ=nah Hörer, あ=fern beiden, ど=Frage. Gilt für これ/この/こちら/こう etc."},
  {l:3, t:"N は (Ort) です", de:"N befindet sich an (Ort)", rule:"Beschreibt den Ort eines Dings/einer Person.", ex:[
    {jp:"<ruby>食堂<rt>しょくどう</rt></ruby>は<ruby>2階<rt>にかい</rt></ruby>です。",de:"Die Mensa ist im 2. Stock."},
    {jp:"ミラーさんは <ruby>事務所<rt>じむしょ</rt></ruby>です。",de:"Herr Miller ist im Büro."}
  ]},
  {l:3, t:"どこ / どちら", de:"wo? / welche Richtung?", rule:"どこ = wo (neutral). どちら = höfliche Variante; auch »aus welchem Land / welcher Firma«.", ex:[
    {jp:"トイレは どこですか。",de:"Wo ist die Toilette?"},
    {jp:"お<ruby>国<rt>くに</rt></ruby>は どちらですか。",de:"Aus welchem Land kommen Sie?"}
  ]},
  {l:3, t:"N₁の N₂ (Land/Hersteller)", de:"N₂ aus/von N₁", rule:"の zeigt Herkunft/Hersteller eines Produkts.", ex:[
    {jp:"これは ドイツの<ruby>車<rt>くるま</rt></ruby>です。",de:"Das ist ein Auto aus Deutschland."},
    {jp:"<ruby>日本<rt>にほん</rt></ruby>の カメラです。",de:"Eine japanische Kamera."}
  ]},
  {l:3, t:"いくらですか", de:"Wie viel kostet es?", rule:"Standardfrage nach dem Preis. Antwort: Zahl + <ruby>円<rt>えん</rt></ruby>.", ex:[
    {jp:"この<ruby>本<rt>ほん</rt></ruby>は いくらですか。— <ruby>2000円<rt>にせんえん</rt></ruby>です。",de:"Wie viel kostet dieses Buch? — 2000 Yen."}
  ]},
  {l:4, t:"<ruby>今<rt>いま</rt></ruby> 〜<ruby>時<rt>じ</rt></ruby> 〜<ruby>分<rt>ふん</rt></ruby>です", de:"Es ist jetzt …Uhr …Minuten", rule:"Zeitangabe. Stunden mit 時, Minuten mit 分/ぷん. Frage: <ruby>何時<rt>なんじ</rt></ruby>ですか。", ex:[
    {jp:"<ruby>今<rt>いま</rt></ruby> <ruby>9時<rt>くじ</rt></ruby><ruby>15分<rt>じゅうごふん</rt></ruby>です。",de:"Es ist jetzt 9:15 Uhr."},
    {jp:"<ruby>今<rt>いま</rt></ruby> <ruby>何時<rt>なんじ</rt></ruby>ですか。",de:"Wie spät ist es jetzt?"}
  ]},
  {l:4, t:"V ます / ません / ました / ませんでした", de:"Verb-Konjugation (höflich)", rule:"Vier Grundformen: ます (Präsens/Zukunft), ません (Verneinung), ました (Vergangenheit positiv), ませんでした (Vergangenheit verneint).", conj:[
    {form:"ます (Präsens+)",verb:"<ruby>働<rt>はたら</rt></ruby>きます",de:"arbeite(t)"},
    {form:"ません (Verneinung)",verb:"<ruby>働<rt>はたら</rt></ruby>きません",de:"arbeite nicht"},
    {form:"ました (Vergangenheit +)",verb:"<ruby>働<rt>はたら</rt></ruby>きました",de:"hat gearbeitet"},
    {form:"ませんでした (Verg. −)",verb:"<ruby>働<rt>はたら</rt></ruby>きませんでした",de:"hat nicht gearbeitet"}
  ], ex:[
    {jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>働<rt>はたら</rt></ruby>きます。",de:"Ich arbeite jeden Tag."},
    {jp:"<ruby>昨日<rt>きのう</rt></ruby> <ruby>働<rt>はたら</rt></ruby>きませんでした。",de:"Gestern habe ich nicht gearbeitet."},
    {jp:"<ruby>宿題<rt>しゅくだい</rt></ruby>を しました。 / しませんでした。",de:"Ich habe die Hausaufgaben gemacht / nicht gemacht."}
  ]},
  {l:4, t:"(Zeit) に V", de:"Um (Zeit) … tun", rule:"に markiert konkrete Zeitpunkte (Uhrzeit, Wochentag, Datum). NICHT bei vagen Zeitangaben wie 今日, 明日, 毎日.", ex:[
    {jp:"<ruby>7時<rt>しちじ</rt></ruby>に <ruby>起<rt>お</rt></ruby>きます。",de:"Ich stehe um 7 Uhr auf."},
    {jp:"<ruby>日曜日<rt>にちようび</rt></ruby>に<ruby>京都<rt>きょうと</rt></ruby>へ<ruby>行<rt>い</rt></ruby>きます。",de:"Am Sonntag fahre ich nach Kyoto."},
    {jp:"<ruby>3月<rt>さんがつ</rt></ruby><ruby>25日<rt>にじゅうごにち</rt></ruby>に <ruby>生<rt>う</rt></ruby>まれました。",de:"Ich bin am 25. März geboren."}
  ], note:"Kein に bei: 今日、きのう、毎日、毎朝、いつ"},
  {l:4, t:"N₁から N₂まで", de:"Von N₁ bis N₂", rule:"Zeit- oder Ortsspanne. Funktioniert auch bei nur einer Seite (z.B. nur から).", ex:[
    {jp:"<ruby>9時<rt>くじ</rt></ruby>から <ruby>5時<rt>ごじ</rt></ruby>まで <ruby>働<rt>はたら</rt></ruby>きます。",de:"Ich arbeite von 9 bis 5 Uhr."},
    {jp:"<ruby>大阪<rt>おおさか</rt></ruby>から<ruby>東京<rt>とうきょう</rt></ruby>まで",de:"von Osaka bis Tokyo"}
  ]},
  {l:4, t:"N₁と N₂", de:"N₁ und N₂ (Aufzählung)", rule:"と verbindet AUSSCHLIESSLICH Nomen (nicht Sätze oder Verben).", ex:[
    {jp:"<ruby>銀行<rt>ぎんこう</rt></ruby>の<ruby>休<rt>やす</rt></ruby>みは <ruby>土曜日<rt>どようび</rt></ruby>と<ruby>日曜日<rt>にちようび</rt></ruby>です。",de:"Die Bank ist samstags und sonntags geschlossen."}
  ]},
  {l:5, t:"(Ort)へ <ruby>行<rt>い</rt></ruby>きます/<ruby>来<rt>き</rt></ruby>ます/<ruby>帰<rt>かえ</rt></ruby>ります", de:"Ich gehe/komme/kehre nach (Ort)", rule:"へ markiert die Bewegungsrichtung (ausgesprochen »e«). Die drei Bewegungsverben: 行く (von hier weg), 来る (zum Sprecher hin), 帰る (zum Ausgangsort zurück).", conj:[
    {form:"行きます",verb:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きます",de:"Ich fahre nach Kyoto"},
    {form:"来ます",verb:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>来<rt>き</rt></ruby>ました",de:"Ich bin nach Japan gekommen"},
    {form:"帰ります",verb:"<ruby>家<rt>いえ</rt></ruby>へ <ruby>帰<rt>かえ</rt></ruby>ります",de:"Ich gehe nach Hause"}
  ], ex:[
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きます。",de:"Ich fahre nach Kyoto."},
    {jp:"<ruby>家<rt>いえ</rt></ruby>へ <ruby>帰<rt>かえ</rt></ruby>ります。",de:"Ich gehe nach Hause."}
  ]},
  {l:5, t:"どこ[へ]も <ruby>行<rt>い</rt></ruby>きません", de:"Ich gehe nirgendwohin", rule:"Fragewort + も + Verneinung = vollständige Negation (»nichts/nirgendwo/niemand«).", ex:[
    {jp:"<ruby>日曜日<rt>にちようび</rt></ruby> どこへも <ruby>行<rt>い</rt></ruby>きませんでした。",de:"Am Sonntag bin ich nirgendwohin gegangen."},
    {jp:"<ruby>何<rt>なに</rt></ruby>も <ruby>食<rt>た</rt></ruby>べません。",de:"Ich esse nichts."},
    {jp:"だれとも <ruby>話<rt>はな</rt></ruby>しませんでした。",de:"Ich habe mit niemandem gesprochen."}
  ]},
  {l:5, t:"(Verkehrsmittel)で <ruby>行<rt>い</rt></ruby>きます", de:"Mit (Verkehrsmittel) fahren", rule:"で markiert das Mittel/Werkzeug. Bei <ruby>歩<rt>ある</rt></ruby>いて (zu Fuß) wird kein で gebraucht.", ex:[
    {jp:"<ruby>電車<rt>でんしゃ</rt></ruby>で <ruby>会社<rt>かいしゃ</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きます。",de:"Ich fahre mit dem Zug zur Firma."},
    {jp:"バスで <ruby>学校<rt>がっこう</rt></ruby>へ <ruby>来<rt>き</rt></ruby>ました。",de:"Ich bin mit dem Bus zur Schule gekommen."},
    {jp:"<ruby>歩<rt>ある</rt></ruby>いて <ruby>帰<rt>かえ</rt></ruby>ります。",de:"Ich gehe zu Fuß nach Hause."}
  ], note:"⚠️ 歩いて (zu Fuß) NIE mit で! Alle anderen Verkehrsmittel: mit で"},
  {l:5, t:"(Person)と V", de:"Mit (Person) etwas tun", rule:"と markiert die Person, mit der man gemeinsam etwas tut. Bei »alleine«: <ruby>一人<rt>ひとり</rt></ruby>で.", ex:[
    {jp:"<ruby>家族<rt>かぞく</rt></ruby>と <ruby>日本<rt>にほん</rt></ruby>へ <ruby>来<rt>き</rt></ruby>ました。",de:"Ich bin mit der Familie nach Japan gekommen."},
    {jp:"<ruby>友達<rt>ともだち</rt></ruby>と <ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>ました。",de:"Ich habe mit einem Freund einen Film gesehen."},
    {jp:"<ruby>一人<rt>ひとり</rt></ruby>で <ruby>行<rt>い</rt></ruby>きます。",de:"Ich gehe alleine."}
  ]},
  {l:5, t:"いつ", de:"Wann?", rule:"Fragewort für Zeitpunkt. Anders als bei konkreten Uhrzeiten KEIN に nach いつ.", ex:[
    {jp:"いつ <ruby>日本<rt>にほん</rt></ruby>へ <ruby>来<rt>き</rt></ruby>ましたか。",de:"Wann bist du nach Japan gekommen?"},
    {jp:"<ruby>3月<rt>さんがつ</rt></ruby><ruby>25日<rt>にじゅうごにち</rt></ruby>に <ruby>来<rt>き</rt></ruby>ました。",de:"Am 25. März."}
  ]},
  {l:6, t:"N を V (Akkusativ)", de:"Direktes Objekt", rule:"を (o) markiert das direkte Objekt transitiver Verben. Typische を-Verben: 食べる・飲む・読む・書く・見る・聞く・買う・作る・教える.", ex:[
    {jp:"パンを <ruby>食<rt>た</rt></ruby>べます。",de:"Ich esse Brot."},
    {jp:"<ruby>新聞<rt>しんぶん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>みます。",de:"Ich lese Zeitung."},
    {jp:"<ruby>音楽<rt>おんがく</rt></ruby>を <ruby>聞<rt>き</rt></ruby>きます。 / テレビを <ruby>見<rt>み</rt></ruby>ます。",de:"Ich höre Musik. / Ich sehe fern."}
  ]},
  {l:6, t:"<ruby>何<rt>なに</rt></ruby>を しますか", de:"Was machen Sie?", rule:"します = tun, machen. Frage nach der Handlung oder Aktivität.", ex:[
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>何<rt>なに</rt></ruby>を しますか。",de:"Was machst du morgen?"},
    {jp:"<ruby>昨日<rt>きのう</rt></ruby> サッカーを しました。",de:"Gestern habe ich Fußball gespielt."},
    {jp:"<ruby>毎朝<rt>まいあさ</rt></ruby> シャワーを します。",de:"Ich dusche jeden Morgen."}
  ]},
  {l:6, t:"(Ort)で V", de:"An (Ort) etwas tun", rule:"で markiert den Ort, an dem eine Handlung stattfindet (im Unterschied zu に für Existenzort).", ex:[
    {jp:"レストランで <ruby>晩<rt>ばん</rt></ruby>ごはんを <ruby>食<rt>た</rt></ruby>べます。",de:"Ich esse zu Abend im Restaurant."},
    {jp:"<ruby>図書館<rt>としょかん</rt></ruby>で <ruby>勉強<rt>べんきょう</rt></ruby>します。",de:"Ich lerne in der Bibliothek."},
    {jp:"<ruby>公園<rt>こうえん</rt></ruby>で <ruby>走<rt>はし</rt></ruby>りました。",de:"Ich bin im Park gelaufen."}
  ], note:"⚠️ Häufiger Fehler: で vs. に! で = Ort einer HANDLUNG (公園で走る). に = Ort der EXISTENZ (公園にいる)"},
  {l:6, t:"V ませんか", de:"Wollen wir nicht …?", rule:"Höfliche Einladung/Vorschlag. Verneinte Form als Aufforderung.", ex:[
    {jp:"<ruby>一緒<rt>いっしょ</rt></ruby>に <ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きませんか。",de:"Wollen wir nicht zusammen nach Kyoto fahren?"},
    {jp:"コーヒーを <ruby>飲<rt>の</rt></ruby>みませんか。",de:"Wie wäre es mit einem Kaffee?"},
    {jp:"いっしょに <ruby>食<rt>た</rt></ruby>べませんか。",de:"Wollen wir nicht zusammen essen?"}
  ]},
  {l:6, t:"V ましょう", de:"Lass uns … tun!", rule:"Vorschlag/Aufforderung. Antwort auf 〜ませんか oder eigener Vorschlag.", ex:[
    {jp:"<ruby>一緒<rt>いっしょ</rt></ruby>に <ruby>食<rt>た</rt></ruby>べましょう。",de:"Lass uns zusammen essen!"},
    {jp:"ちょっと <ruby>休<rt>やす</rt></ruby>みましょう。",de:"Machen wir eine kurze Pause."},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>で <ruby>話<rt>はな</rt></ruby>しましょう。",de:"Lass uns auf Japanisch reden!"}
  ]},
  {l:7, t:"N (Werkzeug) で V", de:"Mit (Werkzeug) etwas tun", rule:"で markiert Werkzeug, Material oder Sprache, mit der eine Handlung ausgeführt wird.", ex:[
    {jp:"はしで <ruby>食<rt>た</rt></ruby>べます。",de:"Ich esse mit Stäbchen."},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>で <ruby>手紙<rt>てがみ</rt></ruby>を <ruby>書<rt>か</rt></ruby>きます。",de:"Ich schreibe einen Brief auf Japanisch."},
    {jp:"ボールペンで <ruby>名前<rt>なまえ</rt></ruby>を <ruby>書<rt>か</rt></ruby>いて ください。",de:"Bitte schreiben Sie Ihren Namen mit einem Kugelschreiber."}
  ]},
  {l:7, t:"〜は (Sprache)で <ruby>何<rt>なん</rt></ruby>ですか", de:"Wie heißt … auf (Sprache)?", rule:"Frage nach Übersetzung eines Wortes.", ex:[
    {jp:"\"Thank you\"は <ruby>日本語<rt>にほんご</rt></ruby>で <ruby>何<rt>なん</rt></ruby>ですか。— ありがとうです。",de:"Was heißt 'Thank you' auf Japanisch?"}
  ]},
  {l:7, t:"N₁(Person)に N₂を あげます/もらいます", de:"geben / bekommen", rule:"あげます = geben (vom Sprecher weg). もらいます = empfangen/bekommen. Geber/Empfänger stehen mit に. くれます = jemand gibt MIR.", conj:[
    {form:"あげます",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんに <ruby>花<rt>はな</rt></ruby>を あげます",de:"Ich gebe Frau Yamada Blumen"},
    {form:"もらいます",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんに <ruby>花<rt>はな</rt></ruby>を もらいます",de:"Ich bekomme von Frau Yamada Blumen"},
    {form:"くれます",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんが <ruby>花<rt>はな</rt></ruby>を くれます",de:"Frau Yamada gibt MIR Blumen"}
  ], ex:[
    {jp:"<ruby>父<rt>ちち</rt></ruby>に ネクタイを あげます。",de:"Ich gebe meinem Vater eine Krawatte."},
    {jp:"<ruby>友達<rt>ともだち</rt></ruby>から <ruby>本<rt>ほん</rt></ruby>を もらいました。",de:"Ich habe von einem Freund ein Buch bekommen."}
  ]},
  {l:7, t:"もう V ました / まだです", de:"Schon getan / noch nicht (Kurzantwort)", rule:"もう + ました = schon. Als einfache Kurzantwort auf »schon?«-Fragen: まだです (noch nicht). Die ausführliche Form まだ V て いません kommt später in L31.", ex:[
    {jp:"もう <ruby>昼<rt>ひる</rt></ruby>ごはんを <ruby>食<rt>た</rt></ruby>べましたか。— はい、もう <ruby>食<rt>た</rt></ruby>べました。",de:"Hast du schon Mittag gegessen? — Ja, schon."},
    {jp:"いいえ、まだです。",de:"Nein, noch nicht."},
    {jp:"もう <ruby>宿題<rt>しゅくだい</rt></ruby>を しましたか。— まだです。",de:"Hast du die Hausaufgaben schon gemacht? — Noch nicht."}
  ], note:"まだです ist die einfache Kurzantwort. Vollständige Form »まだ V ていません« kommt in L31."},
  {l:8, t:"い-Adjektiv & な-Adjektiv (Grundlage)", de:"Zwei Adjektivtypen", rule:"い-Adj endet auf い (たかい). な-Adj braucht な vor Nomen (きれいな). Konjugiert werden beide verschieden.", ex:[
    {jp:"<ruby>富士山<rt>ふじさん</rt></ruby>は <ruby>高<rt>たか</rt></ruby>い<ruby>山<rt>やま</rt></ruby>です。",de:"Der Fuji ist ein hoher Berg."},
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>は きれいな<ruby>町<rt>まち</rt></ruby>です。",de:"Kyoto ist eine schöne Stadt."}
  ]},
  {l:8, t:"い-Adj Konjugation", de:"Alle 4 Formen des い-Adjektivs", rule:"Präsens+: 〜い. Präsens−: 〜くない. Vergangenheit+: 〜かった. Vergangenheit−: 〜くなかった. Ausnahme: いい → よい (よくない, よかった).", conj:[
    {form:"Präsens +",verb:"<ruby>高<rt>たか</rt></ruby>いです",de:"ist hoch/teuer"},
    {form:"Präsens −",verb:"<ruby>高<rt>たか</rt></ruby>くないです",de:"ist nicht hoch"},
    {form:"Vergangenheit +",verb:"<ruby>高<rt>たか</rt></ruby>かったです",de:"war hoch"},
    {form:"Vergangenheit −",verb:"<ruby>高<rt>たか</rt></ruby>くなかったです",de:"war nicht hoch"}
  ], ex:[
    {jp:"この<ruby>本<rt>ほん</rt></ruby>は おもしろいです。/ おもしろくないです。",de:"Dieses Buch ist / ist nicht interessant."},
    {jp:"<ruby>映画<rt>えいが</rt></ruby>は おもしろかったです。/ おもしろくなかったです。",de:"Der Film war / war nicht interessant."},
    {jp:"<ruby>天気<rt>てんき</rt></ruby>は よかったです。（いい→よい）",de:"Das Wetter war gut. (Ausnahme: いい→よい)"}
  ]},
  {l:8, t:"な-Adj Konjugation", de:"Alle 4 Formen des な-Adjektivs", rule:"Präsens+: 〜です. Präsens−: 〜じゃありません. Vergangenheit+: 〜でした. Vergangenheit−: 〜じゃありませんでした.", conj:[
    {form:"Präsens +",verb:"<ruby>静<rt>しず</rt></ruby>かです",de:"ist ruhig"},
    {form:"Präsens −",verb:"<ruby>静<rt>しず</rt></ruby>かじゃありません",de:"ist nicht ruhig"},
    {form:"Vergangenheit +",verb:"<ruby>静<rt>しず</rt></ruby>かでした",de:"war ruhig"},
    {form:"Vergangenheit −",verb:"<ruby>静<rt>しず</rt></ruby>かじゃありませんでした",de:"war nicht ruhig"}
  ], ex:[
    {jp:"この<ruby>町<rt>まち</rt></ruby>は <ruby>静<rt>しず</rt></ruby>かです。/ <ruby>静<rt>しず</rt></ruby>かじゃ ありません。",de:"Diese Stadt ist / ist nicht ruhig."},
    {jp:"テストは <ruby>簡単<rt>かんたん</rt></ruby>でした。/ <ruby>簡単<rt>かんたん</rt></ruby>じゃ ありませんでした。",de:"Der Test war / war nicht einfach."}
  ]},
  {l:8, t:"どんな N", de:"Was für ein N?", rule:"Frage nach den Eigenschaften eines Dings/einer Person.", ex:[
    {jp:"<ruby>奈良<rt>なら</rt></ruby>は どんな<ruby>町<rt>まち</rt></ruby>ですか。",de:"Was für eine Stadt ist Nara?"},
    {jp:"— <ruby>古<rt>ふる</rt></ruby>くて、きれいな<ruby>町<rt>まち</rt></ruby>です。",de:"— Eine alte und schöne Stadt."}
  ]},
  {l:9, t:"N が <ruby>好<rt>す</rt></ruby>き/きらい/<ruby>上手<rt>じょうず</rt></ruby>/<ruby>下手<rt>へた</rt></ruby>です", de:"mögen, hassen, gut/schlecht können", rule:"Diese な-Adjektive verlangen が (nicht を!) für das Objekt. わかります (verstehen) und あります (haben) ebenfalls.", ex:[
    {jp:"<ruby>私<rt>わたし</rt></ruby>は <ruby>音楽<rt>おんがく</rt></ruby>が <ruby>好<rt>す</rt></ruby>きです。 / <ruby>納豆<rt>なっとう</rt></ruby>が きらいです。",de:"Ich mag Musik. / Ich mag Natto nicht."},
    {jp:"ミラーさんは <ruby>料理<rt>りょうり</rt></ruby>が <ruby>上手<rt>じょうず</rt></ruby>です。 / <ruby>私<rt>わたし</rt></ruby>は <ruby>料理<rt>りょうり</rt></ruby>が <ruby>下手<rt>へた</rt></ruby>です。",de:"Herr Miller kann gut kochen. / Ich kann schlecht kochen."},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>が わかります。 / お<ruby>金<rt>かね</rt></ruby>が ありません。",de:"Ich verstehe Japanisch. / Ich habe kein Geld."}
  ], note:"⚠️ IMMER が, niemals を! りんごが好き (nicht りんごを好き)"},
  {l:9, t:"どうして / 〜から", de:"Warum? / weil …", rule:"どうして = warum. Antwort mit 〜から am Satzende = weil. Reihenfolge: Grund + から、Hauptaussage.", ex:[
    {jp:"どうして<ruby>来<rt>き</rt></ruby>ませんでしたか。— <ruby>病気<rt>びょうき</rt></ruby>でしたから。",de:"Warum bist du nicht gekommen? — Weil ich krank war."},
    {jp:"<ruby>時間<rt>じかん</rt></ruby>が ありませんから、<ruby>新聞<rt>しんぶん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>みません。",de:"Weil ich keine Zeit habe, lese ich keine Zeitung."}
  ], note:"🔄 から (subjektiv, direkt) vs. ので (höflicher, natürlicher Zusammenhang, L39). Bei Aufforderungen: lieber ので"},
  {l:9, t:"よく / だいたい / たくさん / すこし / あまり / ぜんぜん", de:"Häufigkeits-/Mengenadverbien", rule:"あまり und ぜんぜん stehen IMMER mit verneintem Verb!", ex:[
    {jp:"スポーツが よく わかります。",de:"Ich kenne mich gut mit Sport aus."},
    {jp:"<ruby>魚<rt>さかな</rt></ruby>が あまり <ruby>好<rt>す</rt></ruby>きじゃ ありません。",de:"Fisch mag ich nicht besonders."},
    {jp:"ぜんぜん わかりません。",de:"Ich verstehe gar nichts."}
  ], note:"⚠️ あまり und ぜんぜん IMMER mit Verneinung — sonst grammatikalisch falsch!"},
  {l:10, t:"N が あります / います", de:"Es gibt / existiert", rule:"あります = leblose Dinge, Pflanzen. います = Lebewesen (Menschen, Tiere). Verneint: ありません / いません.", conj:[
    {form:"あります (Dinge)",verb:"<ruby>本<rt>ほん</rt></ruby>が あります",de:"Es gibt ein Buch"},
    {form:"ありません (Verneinung)",verb:"<ruby>本<rt>ほん</rt></ruby>が ありません",de:"Es gibt kein Buch"},
    {form:"います (Lebewesen)",verb:"<ruby>猫<rt>ねこ</rt></ruby>が います",de:"Es gibt eine Katze"},
    {form:"いません (Verneinung)",verb:"<ruby>猫<rt>ねこ</rt></ruby>が いません",de:"Es gibt keine Katze"}
  ], ex:[
    {jp:"テーブルの<ruby>上<rt>うえ</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>が あります。",de:"Auf dem Tisch ist ein Buch."},
    {jp:"<ruby>庭<rt>にわ</rt></ruby>に <ruby>猫<rt>ねこ</rt></ruby>が います。",de:"Im Garten ist eine Katze."},
    {jp:"だれも いません。",de:"Es ist niemand da."}
  ], note:"⚠️ Belebtheit entscheidet: Menschen+Tiere→います / Dinge+Pflanzen→あります. Ausnahme: Auto mit Fahrer = います"},
  {l:10, t:"(Ort)に N が あります/います", de:"An (Ort) ist N", rule:"Reihenfolge: ORT に + DING/PERSON が + あります/います.", ex:[
    {jp:"<ruby>駅<rt>えき</rt></ruby>の<ruby>前<rt>まえ</rt></ruby>に <ruby>銀行<rt>ぎんこう</rt></ruby>が あります。",de:"Vor dem Bahnhof ist eine Bank."},
    {jp:"<ruby>事務所<rt>じむしょ</rt></ruby>に <ruby>誰<rt>だれ</rt></ruby>か いますか。",de:"Ist jemand im Büro?"}
  ]},
  {l:10, t:"N は (Ort)に あります/います", de:"N befindet sich an (Ort)", rule:"Wenn das DING das Thema ist (bekannt), wird は benutzt.", ex:[
    {jp:"<ruby>東京駅<rt>とうきょうえき</rt></ruby>は どこに ありますか。",de:"Wo ist der Tokyo-Bahnhof?"},
    {jp:"ミラーさんは <ruby>事務所<rt>じむしょ</rt></ruby>に います。",de:"Herr Miller ist im Büro."}
  ]},
  {l:10, t:"Positionswörter", de:"oben/unten/vorne/hinten/innen/außen", rule:"<ruby>上<rt>うえ</rt></ruby>/<ruby>下<rt>した</rt></ruby>/<ruby>前<rt>まえ</rt></ruby>/<ruby>後<rt>うし</rt></ruby>ろ/<ruby>中<rt>なか</rt></ruby>/<ruby>外<rt>そと</rt></ruby>/<ruby>右<rt>みぎ</rt></ruby>/<ruby>左<rt>ひだり</rt></ruby>/<ruby>隣<rt>となり</rt></ruby>. Verbindung: NOMEN の + POSITION に.", ex:[
    {jp:"つくえの<ruby>上<rt>うえ</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>が あります。",de:"Auf dem Schreibtisch ist ein Buch."},
    {jp:"<ruby>木<rt>き</rt></ruby>の<ruby>下<rt>した</rt></ruby>に <ruby>猫<rt>ねこ</rt></ruby>が います。",de:"Unter dem Baum ist eine Katze."},
    {jp:"スーパーの<ruby>隣<rt>となり</rt></ruby>に <ruby>郵便局<rt>ゆうびんきょく</rt></ruby>が あります。",de:"Neben dem Supermarkt ist ein Postamt."}
  ]},
  {l:11, t:"Zähleinheiten (Counter)", de:"Zählen mit Suffixen", rule:"Japanisch nutzt Counter je nach Form/Art: ひとつ〜とお (allgemein), <ruby>人<rt>にん</rt></ruby> (Personen), <ruby>枚<rt>まい</rt></ruby> (flach), <ruby>本<rt>ほん</rt></ruby> (lang/zylindrisch), <ruby>台<rt>だい</rt></ruby> (Maschinen), <ruby>冊<rt>さつ</rt></ruby> (Bücher), <ruby>匹<rt>ひき</rt></ruby> (kleine Tiere), <ruby>頭<rt>とう</rt></ruby> (große Tiere), <ruby>杯<rt>はい</rt></ruby> (Gläser/Tassen).", conj:[
    {form:"〜つ (allgemein)",verb:"ひとつ・ふたつ・みっつ",de:"1・2・3"},
    {form:"〜人 (Personen)",verb:"ひとり・ふたり・さんにん",de:"1・2・3 Personen"},
    {form:"〜枚 (Flaches)",verb:"いちまい・にまい・さんまい",de:"1・2・3 Blatt"},
    {form:"〜本 (Rundes/Langes)",verb:"いっぽん・にほん・さんぼん",de:"1・2・3 Stück"}
  ], ex:[
    {jp:"りんごを <ruby>3<rt>みっ</rt></ruby>つ <ruby>買<rt>か</rt></ruby>いました。",de:"Ich habe 3 Äpfel gekauft."},
    {jp:"<ruby>家族<rt>かぞく</rt></ruby>は <ruby>4人<rt>よにん</rt></ruby>です。",de:"Wir sind 4 in der Familie."},
    {jp:"コーヒーを <ruby>一杯<rt>いっぱい</rt></ruby> <ruby>飲<rt>の</rt></ruby>みました。",de:"Ich habe eine Tasse Kaffee getrunken."}
  ], note:"💡 Im Zweifel: 〜つ (bis 9) funktioniert fast immer. Reihenfolge: [Objekt を] [Zahl+Counter] [Verb] — Zahl direkt vor Verb!"},
  {l:11, t:"Zeitspanne mit に + Häufigkeit", de:"X-mal pro Y", rule:"Format: ZEITRAUM に ANZAHL+Counter. »Pro …« wird mit に ausgedrückt.", ex:[
    {jp:"<ruby>1週間<rt>いっしゅうかん</rt></ruby>に <ruby>2回<rt>にかい</rt></ruby> テニスを します。",de:"Ich spiele 2-mal pro Woche Tennis."},
    {jp:"<ruby>1日<rt>いちにち</rt></ruby>に <ruby>3回<rt>さんかい</rt></ruby> <ruby>食<rt>た</rt></ruby>べます。",de:"Ich esse 3-mal am Tag."}
  ]},
  {l:11, t:"Dauer: 〜<ruby>時間<rt>じかん</rt></ruby> / 〜<ruby>分<rt>ふん</rt></ruby>(<ruby>間<rt>かん</rt></ruby>)", de:"Zeitdauer ausdrücken", rule:"Dauer steht ohne に. <ruby>時間<rt>じかん</rt></ruby>=Stunde(n), <ruby>週間<rt>しゅうかん</rt></ruby>=Woche(n), <ruby>か月<rt>げつ</rt></ruby>=Monat(e), <ruby>年<rt>ねん</rt></ruby>(<ruby>間<rt>かん</rt></ruby>)=Jahr(e), <ruby>分<rt>ふん</rt></ruby>=Minute(n).", ex:[
    {jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>8時間<rt>はちじかん</rt></ruby> <ruby>働<rt>はたら</rt></ruby>きます。",de:"Ich arbeite jeden Tag 8 Stunden."},
    {jp:"<ruby>3年<rt>さんねん</rt></ruby> <ruby>日本<rt>にほん</rt></ruby>に <ruby>住<rt>す</rt></ruby>みました。",de:"Ich habe 3 Jahre in Japan gelebt."},
    {jp:"<ruby>駅<rt>えき</rt></ruby>まで <ruby>30分<rt>さんじゅっぷん</rt></ruby> かかります。",de:"Zum Bahnhof dauert es 30 Minuten."}
  ]},
  {l:11, t:"〜だけ", de:"nur …", rule:"Einschränkende Partikel »nur«. Steht nach dem eingeschränkten Element.", ex:[
    {jp:"<ruby>少<rt>すこ</rt></ruby>しだけ わかります。",de:"Ich verstehe nur ein bisschen."},
    {jp:"<ruby>日曜日<rt>にちようび</rt></ruby>だけ <ruby>休<rt>やす</rt></ruby>みます。",de:"Ich ruhe mich nur am Sonntag aus."}
  ]},
  {l:12, t:"Nomen/な-Adj Vergangenheit", de:"war / war nicht (Nomen, な-Adj)", rule:"Positiv Vergangenheit: でした. Negativ Vergangenheit: じゃ ありませんでした.", ex:[
    {jp:"<ruby>昨日<rt>きのう</rt></ruby>は <ruby>雨<rt>あめ</rt></ruby>でした。",de:"Gestern war Regen."},
    {jp:"テストは <ruby>簡単<rt>かんたん</rt></ruby>じゃ ありませんでした。",de:"Der Test war nicht einfach."}
  ]},
  {l:12, t:"N₁は N₂より Adjです", de:"N₁ ist [Adj]er als N₂", rule:"Vergleich: より = »als« (verglichen mit). Komparativform identisch zur Grundform des Adjektivs.", ex:[
    {jp:"<ruby>飛行機<rt>ひこうき</rt></ruby>は <ruby>船<rt>ふね</rt></ruby>より <ruby>速<rt>はや</rt></ruby>いです。",de:"Das Flugzeug ist schneller als das Schiff."},
    {jp:"<ruby>東京<rt>とうきょう</rt></ruby>は <ruby>大阪<rt>おおさか</rt></ruby>より <ruby>大<rt>おお</rt></ruby>きいです。",de:"Tokyo ist größer als Osaka."},
    {jp:"バスより <ruby>電車<rt>でんしゃ</rt></ruby>のほうが <ruby>速<rt>はや</rt></ruby>いです。",de:"Der Zug ist schneller als der Bus."}
  ]},
  {l:12, t:"N₁と N₂と どちらが Adjですか", de:"Was ist [Adj]er, N₁ oder N₂?", rule:"Vergleichsfrage zwischen 2 Optionen. Antwort: 〜のほうが Adjです.", ex:[
    {jp:"<ruby>紅茶<rt>こうちゃ</rt></ruby>と コーヒーと どちらが <ruby>好<rt>す</rt></ruby>きですか。— コーヒーのほうが <ruby>好<rt>す</rt></ruby>きです。",de:"Was magst du lieber, Tee oder Kaffee? — Kaffee."}
  ]},
  {l:12, t:"〜の<ruby>中<rt>なか</rt></ruby>で <ruby>一番<rt>いちばん</rt></ruby> Adjです", de:"Was/wer ist am [Adj]sten?", rule:"Superlativ-Frage. <ruby>一番<rt>いちばん</rt></ruby> = am meisten/-sten. Kategorie mit の<ruby>中<rt>なか</rt></ruby>で.", ex:[
    {jp:"スポーツの<ruby>中<rt>なか</rt></ruby>で <ruby>何<rt>なに</rt></ruby>が <ruby>一番<rt>いちばん</rt></ruby> <ruby>好<rt>す</rt></ruby>きですか。",de:"Welcher Sport gefällt dir am meisten?"},
    {jp:"<ruby>世界<rt>せかい</rt></ruby>で どこが <ruby>一番<rt>いちばん</rt></ruby> <ruby>暑<rt>あつ</rt></ruby>いですか。",de:"Wo auf der Welt ist es am heißesten?"}
  ]},
  {l:13, t:"N が <ruby>欲<rt>ほ</rt></ruby>しいです", de:"Ich möchte (haben) N", rule:"Wunsch nach einem Ding. Objekt mit が! 欲しい ist ein い-Adjektiv: 欲しいです / 欲しくないです / 欲しかったです.", ex:[
    {jp:"<ruby>新<rt>あたら</rt></ruby>しい<ruby>車<rt>くるま</rt></ruby>が <ruby>欲<rt>ほ</rt></ruby>しいです。",de:"Ich möchte ein neues Auto."},
    {jp:"<ruby>今<rt>いま</rt></ruby>は <ruby>何<rt>なに</rt></ruby>も <ruby>欲<rt>ほ</rt></ruby>しくないです。",de:"Jetzt will ich nichts haben."}
  ], note:"⚠️ Nur 1./2. Person! Für 3. Person (»er/sie möchte«): 欲しがっています"},
  {l:13, t:"V ます-Stamm + たいです", de:"Ich möchte … (Verb)", rule:"Wunsch nach einer Handlung. Konjugiert wie い-Adjektiv: たいです・たくないです・たかったです・たくなかったです.", conj:[
    {form:"たいです (Wunsch +)",verb:"<ruby>行<rt>い</rt></ruby>きたいです",de:"möchte gehen"},
    {form:"たくないです (Wunsch −)",verb:"<ruby>行<rt>い</rt></ruby>きたくないです",de:"möchte nicht gehen"},
    {form:"たかったです (Wunsch Verg.)",verb:"<ruby>行<rt>い</rt></ruby>きたかったです",de:"wollte gehen"},
    {form:"たくなかったです",verb:"<ruby>行<rt>い</rt></ruby>きたくなかったです",de:"wollte nicht gehen"}
  ], ex:[
    {jp:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きたいです。",de:"Ich möchte nach Japan reisen."},
    {jp:"<ruby>何<rt>なに</rt></ruby>も <ruby>食<rt>た</rt></ruby>べたくないです。",de:"Ich möchte nichts essen."},
    {jp:"もっと <ruby>話<rt>はな</rt></ruby>したかったです。",de:"Ich hätte gerne mehr geredet."}
  ]},
  {l:13, t:"(Ort)へ V ます-Stamm + に <ruby>行<rt>い</rt></ruby>きます", de:"Um zu … gehen (Zweck)", rule:"Zweck einer Bewegung: VERB-STAMM + に + 行きます/来ます/帰ります. Bei Suru-Verben: NOMEN + に.", ex:[
    {jp:"デパートへ <ruby>買<rt>か</rt></ruby>い<ruby>物<rt>もの</rt></ruby>に <ruby>行<rt>い</rt></ruby>きます。",de:"Ich gehe ins Kaufhaus, um einzukaufen."},
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>へ お<ruby>寺<rt>てら</rt></ruby>を <ruby>見<rt>み</rt></ruby>に <ruby>行<rt>い</rt></ruby>きます。",de:"Ich fahre nach Kyoto, um Tempel zu besichtigen."},
    {jp:"<ruby>図書館<rt>としょかん</rt></ruby>へ <ruby>本<rt>ほん</rt></ruby>を <ruby>借<rt>か</rt></ruby>りに <ruby>来<rt>き</rt></ruby>ました。",de:"Ich bin in die Bibliothek gekommen, um Bücher zu leihen."}
  ]},
  {l:14, t:"て-Form (Verb) — Bildung", de:"Verbindungsform der Verben", rule:"Gruppe I (u-Verben): Endung verändert sich nach Regel. Gruppe II (ru-Verben): る wird zu て. Unregelmäßig: する→して、来る→きて、★行く→いって (Ausnahme!).", conj:[
    {form:"★ Gruppe I (u-Verben)",verb:"―",de:"―"},
    {form:"う/つ/る → って",verb:"<ruby>買<rt>か</rt></ruby>う→<ruby>買<rt>か</rt></ruby>って / <ruby>待<rt>ま</rt></ruby>つ→<ruby>待<rt>ま</rt></ruby>って / <ruby>帰<rt>かえ</rt></ruby>る→<ruby>帰<rt>かえ</rt></ruby>って",de:"kaufen / warten / zurückkehren"},
    {form:"ぬ/ぶ/む → んで",verb:"<ruby>死<rt>し</rt></ruby>ぬ→<ruby>死<rt>し</rt></ruby>んで / <ruby>呼<rt>よ</rt></ruby>ぶ→<ruby>呼<rt>よ</rt></ruby>んで / <ruby>飲<rt>の</rt></ruby>む→<ruby>飲<rt>の</rt></ruby>んで",de:"sterben / rufen / trinken"},
    {form:"く → いて",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>いて",de:"schreiben"},
    {form:"★ AUSNAHME: 行く → いって",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>って (NICHT 行いて!)",de:"gehen"},
    {form:"ぐ → いで",verb:"<ruby>泳<rt>およ</rt></ruby>ぐ → <ruby>泳<rt>およ</rt></ruby>いで",de:"schwimmen"},
    {form:"す → して",verb:"<ruby>話<rt>はな</rt></ruby>す → <ruby>話<rt>はな</rt></ruby>して",de:"sprechen"},
    {form:"★ Gruppe II (ru-Verben): る → て",verb:"―",de:"―"},
    {form:"Gr.II: る → て",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べて",de:"essen"},
    {form:"Gr.II: る → て",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>て",de:"sehen"},
    {form:"Gr.II: る → て",verb:"<ruby>起<rt>お</rt></ruby>きる → <ruby>起<rt>お</rt></ruby>きて",de:"aufstehen"},
    {form:"★ Unregelmäßige Verben",verb:"―",de:"―"},
    {form:"する",verb:"して",de:"tun"},
    {form:"来る",verb:"<ruby>来<rt>き</rt></ruby>て",de:"kommen"}
  ], ex:[
    {jp:"<ruby>名前<rt>なまえ</rt></ruby>を <ruby>書<rt>か</rt></ruby>いて ください。",de:"Bitte schreiben Sie Ihren Namen."},
    {jp:"ちょっと <ruby>待<rt>ま</rt></ruby>って ください。",de:"Bitte warten Sie kurz."}
  ], note:"💡 Merkregel Gr.I: うつる→って / ぬぶむ→んで / く→いて / ぐ→いで / す→して. ★ 行く→行って (EINZIGE Ausnahme!)"},
  {l:14, t:"V て ください", de:"Bitte … tun (Bitte)", rule:"Höfliche Bitte/Aufforderung. Aus て-Form + ください.", ex:[
    {jp:"ゆっくり <ruby>話<rt>はな</rt></ruby>して ください。",de:"Bitte sprich langsam."},
    {jp:"もう<ruby>一度<rt>いちど</rt></ruby> <ruby>言<rt>い</rt></ruby>って ください。",de:"Bitte sag es noch einmal."},
    {jp:"<ruby>窓<rt>まど</rt></ruby>を <ruby>閉<rt>し</rt></ruby>めて ください。 / <ruby>開<rt>あ</rt></ruby>けて ください。",de:"Bitte schließen / öffnen Sie das Fenster."}
  ]},
  {l:14, t:"V て います (Verlauf)", de:"gerade … tun (Progressiv)", rule:"Beschreibt eine gerade ablaufende Handlung. Wie englisches »be …ing«. Auch für Beruf/Zustand/Gewohnheit (L15).", ex:[
    {jp:"<ruby>今<rt>いま</rt></ruby> <ruby>新聞<rt>しんぶん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んで います。",de:"Ich lese gerade Zeitung."},
    {jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>って います。",de:"Es regnet gerade."},
    {jp:"<ruby>子供<rt>こども</rt></ruby>が <ruby>遊<rt>あそ</rt></ruby>んで います。",de:"Das Kind spielt gerade."}
  ], note:"🔄 て います hat 3 Bedeutungen: ① Progressiv (L14, jetzt) ② Zustand/Beruf (L15) ③ Gewohnheit (L28)"},
  {l:14, t:"V ましょうか (Angebot)", de:"Soll ich …?", rule:"Höfliches Angebot, etwas FÜR jemanden zu tun. Nicht zu verwechseln mit ましょう (Vorschlag).", ex:[
    {jp:"<ruby>手伝<rt>てつだ</rt></ruby>いましょうか。",de:"Soll ich (Ihnen) helfen?"},
    {jp:"<ruby>窓<rt>まど</rt></ruby>を <ruby>開<rt>あ</rt></ruby>けましょうか。",de:"Soll ich das Fenster öffnen?"},
    {jp:"<ruby>駅<rt>えき</rt></ruby>まで <ruby>送<rt>おく</rt></ruby>りましょうか。",de:"Soll ich Sie zum Bahnhof bringen?"}
  ]},
  {l:15, t:"V て も いいですか", de:"Darf ich …? (Erlaubnis)", rule:"Bitte um Erlaubnis. Antwort: はい、どうぞ (gerne) oder すみません、ちょっと… (höfliche Ablehnung).", ex:[
    {jp:"ここで タバコを <ruby>吸<rt>す</rt></ruby>っても いいですか。",de:"Darf ich hier rauchen?"},
    {jp:"<ruby>写真<rt>しゃしん</rt></ruby>を <ruby>撮<rt>と</rt></ruby>っても いいですか。",de:"Darf ich ein Foto machen?"},
    {jp:"このペンを <ruby>使<rt>つか</rt></ruby>っても いいですか。",de:"Darf ich diesen Stift benutzen?"}
  ]},
  {l:15, t:"V ては いけません", de:"Du darfst nicht …", rule:"Verbot. Aus て-Form + は いけません. Strikt — meist auf Schildern oder von Autoritäten.", ex:[
    {jp:"ここで タバコを <ruby>吸<rt>す</rt></ruby>っては いけません。",de:"Hier darf nicht geraucht werden."},
    {jp:"<ruby>授業中<rt>じゅぎょうちゅう</rt></ruby>、<ruby>話<rt>はな</rt></ruby>しては いけません。",de:"Während des Unterrichts darf man nicht reden."},
    {jp:"ここで <ruby>走<rt>はし</rt></ruby>っては いけません。",de:"Hier darf man nicht rennen."}
  ]},
  {l:15, t:"〜を <ruby>知<rt>し</rt></ruby>って いますか", de:"Kennst/weißt du …?", rule:"Sonderfall: 知る funktioniert als Zustandsverb nur mit て います. WICHTIG: Verneinung ist 知りません (NICHT 知って いません!). Für bekannte Information, Personen, Orte, Fakten.", conj:[
    {form:"Positiv (Zustand)",verb:"<ruby>知<rt>し</rt></ruby>って います",de:"Ich weiß/kenne"},
    {form:"★ Verneinung",verb:"<ruby>知<rt>し</rt></ruby>りません (！nicht 知って いません)",de:"Ich weiß nicht/kenne nicht"},
    {form:"Vergangenheit +",verb:"<ruby>知<rt>し</rt></ruby>って いました",de:"Ich wusste/kannte"},
    {form:"Vergangenheit −",verb:"<ruby>知<rt>し</rt></ruby>りませんでした",de:"Ich wusste nicht/kannte nicht"}
  ], ex:[
    {jp:"ミラーさんの <ruby>住所<rt>じゅうしょ</rt></ruby>を <ruby>知<rt>し</rt></ruby>って いますか。— はい、<ruby>知<rt>し</rt></ruby>って います。",de:"Kennst du Herrn Millers Adresse? — Ja, ich kenne sie."},
    {jp:"いいえ、<ruby>知<rt>し</rt></ruby>りません。",de:"Nein, ich weiß es nicht."},
    {jp:"あの<ruby>人<rt>ひと</rt></ruby>を <ruby>知<rt>し</rt></ruby>って いますか。",de:"Kennst du die Person dort?"},
    {jp:"そのニュースを <ruby>知<rt>し</rt></ruby>りませんでした。",de:"Ich wusste von dieser Nachricht nichts."}
  ], note:"Häufiger Fehler von Anfängern: NIE 知っていません sagen — immer 知りません!"},
  {l:15, t:"V て います (Zustand/Beruf/Gewohnheit)", de:"3 Bedeutungen von て います", rule:"(1) Gerade laufende Handlung (L14). (2) Dauerhafter Zustand/Beruf: 住む・結婚する・働く. (3) Wiederholte Gewohnheit.", conj:[
    {form:"① Progressiv",verb:"<ruby>食<rt>た</rt></ruby>べて います",de:"isst gerade"},
    {form:"② Zustand/Beruf",verb:"<ruby>住<rt>す</rt></ruby>んで います / <ruby>結婚<rt>けっこん</rt></ruby>して います",de:"wohnt / ist verheiratet"},
    {form:"③ Gewohnheit",verb:"<ruby>毎朝<rt>まいあさ</rt></ruby> <ruby>走<rt>はし</rt></ruby>って います",de:"läuft jeden Morgen"}
  ], ex:[
    {jp:"<ruby>銀行<rt>ぎんこう</rt></ruby>で <ruby>働<rt>はたら</rt></ruby>いて います。",de:"Ich arbeite bei einer Bank."},
    {jp:"<ruby>結婚<rt>けっこん</rt></ruby>して います。 / <ruby>大阪<rt>おおさか</rt></ruby>に <ruby>住<rt>す</rt></ruby>んで います。",de:"Ich bin verheiratet. / Ich wohne in Osaka."},
    {jp:"カメラを <ruby>持<rt>も</rt></ruby>って います。",de:"Ich habe (bei mir) eine Kamera."}
  ], note:"Sonderfall 知る hat eigene Karte — Verneinung IMMER 知りません (nicht 知っていません)!"},
  {l:16, t:"V₁て、V₂て、V₃ます (Reihenfolge)", de:"… und dann …", rule:"Aufeinanderfolgende Handlungen mit て-Form verbunden. Letztes Verb trägt Tempus (ます/ました).", conj:[
    {form:"Anschluss",verb:"V₁<sub>テ</sub>、 V₂<sub>テ</sub>、 V₃<sub>ル</sub>",de:"mehrere Verben verkettet"},
    {form:"Letztes Verb",verb:"V<sub>マス</sub> / V<sub>マシタ</sub>",de:"trägt das Tempus"},
    {form:"Beispiel",verb:"<ruby>起<rt>お</rt></ruby>きて、<ruby>食<rt>た</rt></ruby>べて、<ruby>行<rt>い</rt></ruby>きます",de:"aufstehen, essen, gehen"},
    {form:"Vergangenheit",verb:"<ruby>起<rt>お</rt></ruby>きて、<ruby>食<rt>た</rt></ruby>べて、<ruby>行<rt>い</rt></ruby>きました",de:"stand auf, aß, ging"}
  ], ex:[
    {jp:"<ruby>朝<rt>あさ</rt></ruby> <ruby>起<rt>お</rt></ruby>きて、シャワーを <ruby>浴<rt>あ</rt></ruby>びて、<ruby>会社<rt>かいしゃ</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きます。",de:"Morgens stehe ich auf, dusche, und gehe zur Firma."},
    {jp:"シャワーを <ruby>浴<rt>あ</rt></ruby>びて、<ruby>歯<rt>は</rt></ruby>を <ruby>磨<rt>みが</rt></ruby>いて、<ruby>寝<rt>ね</rt></ruby>ました。",de:"Ich duschte, putzte die Zähne und ging schlafen."}
  ], note:"⚠️ Nur das LETZTE Verb wird konjugiert! Alle vorherigen bleiben in der て-Form. Die Reihenfolge der Verben = Reihenfolge der Handlungen."},
  {l:16, t:"い-Adj くて / な-Adj で / N で (Verbindung)", de:"Adjektive und Nomen verbinden", rule:"い-Adj: い→くて (高い→高くて). な-Adj/N: + で. Adjektive können hintereinander gereiht werden oder als Begründung dienen.", conj:[
    {form:"い-Adj: い→くて",verb:"<ruby>高<rt>たか</rt></ruby>い → <ruby>高<rt>たか</rt></ruby>くて",de:"teuer und …"},
    {form:"い-Adj: いい→よくて",verb:"いい → よくて (!)",de:"gut und … (Ausnahme!)"},
    {form:"な-Adj: +で",verb:"きれいで",de:"schön und …"},
    {form:"N: +で",verb:"<ruby>学生<rt>がくせい</rt></ruby>で",de:"Student und …"}
  ], ex:[
    {jp:"ミラーさんは <ruby>若<rt>わか</rt></ruby>くて、ハンサムです。",de:"Herr Miller ist jung und gutaussehend."},
    {jp:"この<ruby>町<rt>まち</rt></ruby>は <ruby>静<rt>しず</rt></ruby>かで、きれいです。",de:"Diese Stadt ist ruhig und schön."},
    {jp:"この レストランは <ruby>安<rt>やす</rt></ruby>くて、おいしいです。",de:"Dieses Restaurant ist günstig und lecker."}
  ]},
  {l:16, t:"V₁てから、V₂", de:"Erst V₁, dann V₂", rule:"Betont, dass V₂ erst NACH Abschluss von V₁ stattfindet. Stärker als reine て-Verkettung.", conj:[
    {form:"Anschluss",verb:"V₁<sub>テ</sub> + から、 V₂",de:"erst V₁, dann V₂"},
    {form:"Beispiel",verb:"<ruby>食<rt>た</rt></ruby>べてから、<ruby>行<rt>い</rt></ruby>きます",de:"erst essen, dann gehen"},
    {form:"Vergleich て (lose)",verb:"<ruby>食<rt>た</rt></ruby>べて、<ruby>行<rt>い</rt></ruby>きます",de:"essen UND gehen (Reihenfolge nur lose)"},
    {form:"Vergleich てから (strikt)",verb:"<ruby>食<rt>た</rt></ruby>べてから、<ruby>行<rt>い</rt></ruby>きます",de:"erst NACH dem Essen → gehen"}
  ], ex:[
    {jp:"<ruby>晩<rt>ばん</rt></ruby>ごはんを <ruby>食<rt>た</rt></ruby>べてから、<ruby>勉強<rt>べんきょう</rt></ruby>します。",de:"Erst esse ich zu Abend, dann lerne ich."},
    {jp:"<ruby>仕事<rt>しごと</rt></ruby>が <ruby>終<rt>お</rt></ruby>わってから、<ruby>飲<rt>の</rt></ruby>みに <ruby>行<rt>い</rt></ruby>きませんか。",de:"Wollen wir nach der Arbeit etwas trinken gehen?"},
    {jp:"<ruby>手<rt>て</rt></ruby>を <ruby>洗<rt>あら</rt></ruby>ってから、<ruby>食<rt>た</rt></ruby>べて ください。",de:"Bitte waschen Sie sich zuerst die Hände, dann essen Sie."}
  ], note:"💡 Unterschied: て = nur Reihenfolge / てから = Betonung \"ERST nach Abschluss\". ⚠️ Hauptsatz im Plain-Form ist möglich, aber NUR EIN てから pro Satz!"},
  {l:16, t:"N₁は N₂が Adj (Eigenschafts-Beschreibung)", de:"N₁ hat ein [Adj]es N₂", rule:"Beschreibung eines Teilaspekts von N₁. N₁=Thema (は), N₂=beschriebenes Merkmal (が), dann Adjektiv. Typisch für Körperteile, Orte, Eigenschaften.", conj:[
    {form:"Anschluss",verb:"N₁ <b>は</b> N₂ <b>が</b> Adj",de:"N₁ hat ein N₂, das adj. ist"},
    {form:"Körperteil",verb:"<ruby>象<rt>ぞう</rt></ruby><b>は</b> <ruby>鼻<rt>はな</rt></ruby><b>が</b> <ruby>長<rt>なが</rt></ruby>いです",de:"Der Elefant hat eine lange Nase"},
    {form:"Eigenschaft",verb:"<ruby>東京<rt>とうきょう</rt></ruby><b>は</b> <ruby>人口<rt>じんこう</rt></ruby><b>が</b> <ruby>多<rt>おお</rt></ruby>いです",de:"Tokyo hat viele Einwohner"},
    {form:"Können",verb:"ミラーさん<b>は</b> <ruby>日本語<rt>にほんご</rt></ruby><b>が</b> <ruby>上手<rt>じょうず</rt></ruby>です",de:"Herr M. ist gut im Japanischen"}
  ], ex:[
    {jp:"<ruby>象<rt>ぞう</rt></ruby>は <ruby>鼻<rt>はな</rt></ruby>が <ruby>長<rt>なが</rt></ruby>いです。",de:"Der Elefant hat einen langen Rüssel."},
    {jp:"<ruby>東京<rt>とうきょう</rt></ruby>は <ruby>人<rt>ひと</rt></ruby>が <ruby>多<rt>おお</rt></ruby>いです。",de:"Tokyo hat viele Menschen."},
    {jp:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>背<rt>せ</rt></ruby>が <ruby>高<rt>たか</rt></ruby>いです。",de:"Er ist groß. (wörtl.: sein Rücken ist hoch)"},
    {jp:"このアパートは <ruby>部屋<rt>へや</rt></ruby>が <ruby>広<rt>ひろ</rt></ruby>いです。",de:"Diese Wohnung hat große Zimmer."}
  ], note:"💡 Faustregel: は = Thema (das ganze Subjekt), が = das Merkmal/der Teil, der beschrieben wird. Sehr typisch für Körperteile, Können (好き/上手), Eigenschaften."},
  {l:17, t:"ない-Form (Verneinung) — Bildung", de:"Verneinte Wörterbuchform (Plain negativ)", rule:"Verneinung der Plain-Form. Basisform für viele Strukturen: ないでください, なければなりません, ないほうがいい u.a.", conj:[
    {form:"★ Gruppe I (u-Verben): u → a + ない",verb:"―",de:"―"},
    {form:"書く",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>かない",de:"nicht schreiben"},
    {form:"飲む",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>まない",de:"nicht trinken"},
    {form:"行く",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>かない",de:"nicht gehen"},
    {form:"待つ",verb:"<ruby>待<rt>ま</rt></ruby>つ → <ruby>待<rt>ま</rt></ruby>たない",de:"nicht warten"},
    {form:"★ AUSNAHME: う → わ + ない",verb:"<ruby>買<rt>か</rt></ruby>う → <ruby>買<rt>か</rt></ruby>わない (NICHT 買あない!)",de:"nicht kaufen"},
    {form:"会う",verb:"<ruby>会<rt>あ</rt></ruby>う → <ruby>会<rt>あ</rt></ruby>わない",de:"nicht treffen"},
    {form:"★ Gruppe II (ru-Verben): る weg + ない",verb:"―",de:"―"},
    {form:"食べる",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べない",de:"nicht essen"},
    {form:"見る",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>ない",de:"nicht sehen"},
    {form:"起きる",verb:"<ruby>起<rt>お</rt></ruby>きる → <ruby>起<rt>お</rt></ruby>きない",de:"nicht aufstehen"},
    {form:"★ Unregelmäßige Verben",verb:"―",de:"―"},
    {form:"する",verb:"しない",de:"nicht tun"},
    {form:"来る",verb:"<ruby>来<rt>こ</rt></ruby>ない",de:"nicht kommen (★ ko-nai, nicht ki-nai!)"},
    {form:"★ SONDERFALL: ある → ない",verb:"ある → ない (NICHT あらない!)",de:"nicht haben / nicht existieren"}
  ], ex:[
    {jp:"<ruby>肉<rt>にく</rt></ruby>を <ruby>食<rt>た</rt></ruby>べません。→ <ruby>肉<rt>にく</rt></ruby>を <ruby>食<rt>た</rt></ruby>べない。",de:"Ich esse kein Fleisch. (höflich → plain)"},
    {jp:"<ruby>今日<rt>きょう</rt></ruby>は どこへも <ruby>行<rt>い</rt></ruby>かない。",de:"Heute gehe ich nirgendwohin. (plain)"},
    {jp:"お<ruby>金<rt>かね</rt></ruby>が ない。",de:"Ich habe kein Geld."}
  ]},
  {l:17, t:"V ない で ください", de:"Bitte NICHT … tun", rule:"Höfliche Bitte, etwas zu unterlassen. ない-Form + で ください.", conj:[
    {form:"Anschluss",verb:"V<sub>ナイ</sub> + で ください",de:"bitte nicht …"},
    {form:"Gruppe I",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>かないで ください",de:"bitte nicht gehen"},
    {form:"Gruppe II",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べないで ください",de:"bitte nicht essen"},
    {form:"する → しないで",verb:"する → しないで ください",de:"bitte nicht tun"},
    {form:"来る → 来ないで",verb:"<ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>ないで ください",de:"bitte nicht kommen"}
  ], ex:[
    {jp:"ここで <ruby>写真<rt>しゃしん</rt></ruby>を <ruby>撮<rt>と</rt></ruby>らないで ください。",de:"Bitte fotografieren Sie hier nicht."},
    {jp:"<ruby>心配<rt>しんぱい</rt></ruby>しないで ください。",de:"Machen Sie sich bitte keine Sorgen."},
    {jp:"<ruby>遅<rt>おそ</rt></ruby>く <ruby>起<rt>お</rt></ruby>きないで ください。",de:"Bitte stehen Sie nicht zu spät auf."}
  ], note:"🔄 Vergleich: V<sub>テ</sub> + ください = bitte tun (L14) / V<sub>ナイ</sub> + で ください = bitte NICHT tun (L17). Das で nach ない ist KEINE Pause-Markierung!"},
  {l:17, t:"V なければ なりません / V なくても いいです", de:"Ich muss … / Ich muss NICHT …", rule:"Pflicht: ない-Form (ない→なければ) + なりません. Fehlende Pflicht: ない→なくても + いいです. Kurzform umgangssprachlich: 〜なきゃ。", conj:[
    {form:"Pflicht: なければ なりません",verb:"<ruby>飲<rt>の</rt></ruby>まなければ なりません",de:"muss trinken"},
    {form:"Keine Pflicht: なくても いい",verb:"<ruby>飲<rt>の</rt></ruby>まなくても いいです",de:"muss nicht trinken"},
    {form:"Umg.: 〜なきゃ",verb:"<ruby>行<rt>い</rt></ruby>かなきゃ",de:"Ich muss gehen. (informell)"}
  ], ex:[
    {jp:"<ruby>薬<rt>くすり</rt></ruby>を <ruby>飲<rt>の</rt></ruby>まなければ なりません。",de:"Ich muss die Medizin einnehmen."},
    {jp:"<ruby>明日<rt>あした</rt></ruby>は <ruby>来<rt>こ</rt></ruby>なくても いいです。",de:"Du brauchst morgen nicht zu kommen."},
    {jp:"<ruby>靴<rt>くつ</rt></ruby>を <ruby>脱<rt>ぬ</rt></ruby>がなくても いいですか。",de:"Muss ich die Schuhe nicht ausziehen?"}
  ], note:"💡 Logik: »nicht-nicht-tun geht nicht« = muss. »nicht-tun geht OK« = muss nicht. Doppelte Verneinung = Pflicht"},
  {l:18, t:"<ruby>辞書形<rt>じしょけい</rt></ruby> (Wörterbuchform) — Bildung", de:"Grundform der Verben", rule:"Plain-Form Präsens Positiv. Gruppe I: Stamm + u-Reihe (きく, よむ…). Gruppe II: Stamm + る (たべる, みる…). Unregelmäßig: します→する、きます→くる.", conj:[
    {form:"Gr.I: i-Reihe → u-Reihe",verb:"<ruby>書<rt>か</rt></ruby>きます → <ruby>書<rt>か</rt></ruby>く / <ruby>飲<rt>の</rt></ruby>みます → <ruby>飲<rt>の</rt></ruby>む",de:"schreiben / trinken"},
    {form:"Gr.II: ます-Stamm + る",verb:"<ruby>食<rt>た</rt></ruby>べます → <ruby>食<rt>た</rt></ruby>べる / <ruby>見<rt>み</rt></ruby>ます → <ruby>見<rt>み</rt></ruby>る",de:"essen / sehen"},
    {form:"Unregel.",verb:"します → する / きます → くる",de:"tun / kommen"}
  ], ex:[
    {jp:"<ruby>漢字<rt>かんじ</rt></ruby>を <ruby>読<rt>よ</rt></ruby>む ことが できます。",de:"Ich kann Kanji lesen."},
    {jp:"<ruby>寝<rt>ね</rt></ruby>る <ruby>前<rt>まえ</rt></ruby>に、<ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>みます。",de:"Vor dem Schlafen lese ich ein Buch."}
  ]},
  {l:18, t:"V <ruby>辞書形<rt>じしょけい</rt></ruby> こと が できます", de:"… können (Fähigkeit/Erlaubnis)", rule:"Drückt Können oder Möglichkeit aus. Auch mit Nomen: N が できます.", conj:[
    {form:"Anschluss V",verb:"V<sub>ル</sub> + こと が できます",de:"kann V (Tätigkeit)"},
    {form:"Anschluss N",verb:"N が できます",de:"kann N (Sache)"},
    {form:"Verb-Beispiel",verb:"<ruby>日本語<rt>にほんご</rt></ruby>を<ruby>話<rt>はな</rt></ruby>す こと が できます",de:"kann Japanisch sprechen"},
    {form:"Nomen-Beispiel",verb:"<ruby>運転<rt>うんてん</rt></ruby><b>が</b> できます",de:"kann Auto fahren (kein を!)"},
    {form:"Verneint V",verb:"<ruby>読<rt>よ</rt></ruby>む こと が できません",de:"kann nicht lesen"},
    {form:"Vergleich Potential",verb:"<ruby>話<rt>はな</rt></ruby>せます (L27)",de:"spreche kann (kürzere Form, kommt L27)"}
  ], ex:[
    {jp:"ミラーさんは <ruby>漢字<rt>かんじ</rt></ruby>を <ruby>読<rt>よ</rt></ruby>む ことが できます。",de:"Herr Miller kann Kanji lesen."},
    {jp:"カードで <ruby>払<rt>はら</rt></ruby>う ことが できますか。",de:"Kann man mit Karte zahlen?"},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>が できます。 / ピアノが できます。",de:"Ich kann Japanisch. / Ich kann Klavier spielen."}
  ], note:"⚠️ Bei N + が できます wird KEIN を verwendet! 「運転」を できます ist FALSCH. Korrekt: 運転<b>が</b> できます."},
  {l:18, t:"V<ruby>辞書形<rt>じしょけい</rt></ruby> / N の <ruby>前<rt>まえ</rt></ruby>に、V₂", de:"Vor V₁/N₁ tue ich V₂", rule:"Zeitliche Reihenfolge: V/N + 前に. Bei Verben Wörterbuchform, bei Nomen の.", conj:[
    {form:"Verb",verb:"V<sub>ル</sub> + {r(\"前\",\"まえ\")}に",de:"bevor V"},
    {form:"Nomen",verb:"N + の + {r(\"前\",\"まえ\")}に",de:"vor N"},
    {form:"Zeitangabe",verb:"<ruby>時間<rt>じかん</rt></ruby> + <ruby>前<rt>まえ</rt></ruby>に",de:"vor [Zeit]"},
    {form:"Beispiel V",verb:"<ruby>食<rt>た</rt></ruby>べる <ruby>前<rt>まえ</rt></ruby>に、<ruby>手<rt>て</rt></ruby>を<ruby>洗<rt>あら</rt></ruby>います",de:"vor dem Essen Hände waschen"},
    {form:"Beispiel N",verb:"<ruby>食事<rt>しょくじ</rt></ruby>の <ruby>前<rt>まえ</rt></ruby>に",de:"vor dem Essen"},
    {form:"Beispiel Zeit",verb:"<ruby>3年<rt>さんねん</rt></ruby><ruby>前<rt>まえ</rt></ruby>に",de:"vor 3 Jahren"}
  ], ex:[
    {jp:"<ruby>寝<rt>ね</rt></ruby>る <ruby>前<rt>まえ</rt></ruby>に、<ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>みます。",de:"Vor dem Schlafen lese ich ein Buch."},
    {jp:"<ruby>出<rt>で</rt></ruby>かける <ruby>前<rt>まえ</rt></ruby>に、<ruby>鍵<rt>かぎ</rt></ruby>を かけます。",de:"Vor dem Weggehen schließe ich ab."}
  ], note:"⚠️ Wichtig: VERB immer in <b>Wörterbuchform</b> (auch wenn die Hauptaktion in der Vergangenheit stattfand)! 食べた前に ist FALSCH."},
  {l:19, t:"た-Form (Plain Vergangenheit) — Bildung", de:"Vergangenheits-Grundform (Plain)", rule:"Bildungsregeln wie て-Form, nur mit た/だ statt て/で. Basis für viele Strukturen: たことがあります, たら, たほうがいい, たとき u.a.", conj:[
    {form:"★ Gruppe I (u-Verben)",verb:"―",de:"―"},
    {form:"う/つ/る → った",verb:"<ruby>買<rt>か</rt></ruby>う→<ruby>買<rt>か</rt></ruby>った / <ruby>待<rt>ま</rt></ruby>つ→<ruby>待<rt>ま</rt></ruby>った / <ruby>売<rt>う</rt></ruby>る→<ruby>売<rt>う</rt></ruby>った",de:"gekauft / gewartet / verkauft"},
    {form:"ぬ/ぶ/む → んだ",verb:"<ruby>死<rt>し</rt></ruby>ぬ→<ruby>死<rt>し</rt></ruby>んだ / <ruby>呼<rt>よ</rt></ruby>ぶ→<ruby>呼<rt>よ</rt></ruby>んだ / <ruby>飲<rt>の</rt></ruby>む→<ruby>飲<rt>の</rt></ruby>んだ",de:"gestorben / gerufen / getrunken"},
    {form:"く → いた",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>いた",de:"geschrieben"},
    {form:"★ AUSNAHME: 行く → いった",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>った (NICHT 行いた!)",de:"gegangen"},
    {form:"ぐ → いだ",verb:"<ruby>泳<rt>およ</rt></ruby>ぐ → <ruby>泳<rt>およ</rt></ruby>いだ",de:"geschwommen"},
    {form:"す → した",verb:"<ruby>話<rt>はな</rt></ruby>す → <ruby>話<rt>はな</rt></ruby>した",de:"gesprochen"},
    {form:"★ Gruppe II (ru-Verben): る → た",verb:"―",de:"―"},
    {form:"Gr.II: る → た",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べた",de:"gegessen"},
    {form:"Gr.II: る → た",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>た",de:"gesehen"},
    {form:"Gr.II: る → た",verb:"<ruby>起<rt>お</rt></ruby>きる → <ruby>起<rt>お</rt></ruby>きた",de:"aufgestanden"},
    {form:"★ Unregelmäßige Verben",verb:"―",de:"―"},
    {form:"する",verb:"した",de:"getan"},
    {form:"来る",verb:"<ruby>来<rt>き</rt></ruby>た",de:"gekommen"}
  ], ex:[
    {jp:"<ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>た。",de:"Ich habe einen Film gesehen. (plain)"},
    {jp:"コーヒーを <ruby>飲<rt>の</rt></ruby>んだ。",de:"Ich habe Kaffee getrunken. (plain)"},
    {jp:"<ruby>手紙<rt>てがみ</rt></ruby>を <ruby>書<rt>か</rt></ruby>いた。",de:"Ich habe einen Brief geschrieben. (plain)"}
  ], note:"💡 た-Form = て-Form mit た statt て (書いて→書いた, 飲んで→飲んだ). Gleiche Regeln!"},
  {l:19, t:"V た ことが あります", de:"Ich habe schon mal …", rule:"Erfahrung in der Vergangenheit. Drückt aus, dass man etwas mindestens einmal getan hat. Verneinung: た こと が ありません.", conj:[
    {form:"Anschluss",verb:"V<sub>タ</sub> + ことが あります",de:"habe schon mal V getan (Erfahrung)"},
    {form:"Verneint",verb:"V<sub>タ</sub> + ことが ありません",de:"habe noch nie V getan"},
    {form:"Frage",verb:"V<sub>タ</sub> + ことが ありますか",de:"hast du schon mal V getan?"},
    {form:"Beispiel",verb:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>った ことが あります",de:"War schon mal in Japan"},
    {form:"Verneint",verb:"<ruby>寿司<rt>すし</rt></ruby>を <ruby>食<rt>た</rt></ruby>べた ことが ありません",de:"Habe noch nie Sushi gegessen"}
  ], ex:[
    {jp:"<ruby>北海道<rt>ほっかいどう</rt></ruby>へ <ruby>行<rt>い</rt></ruby>った ことが あります。",de:"Ich war schon mal in Hokkaido."},
    {jp:"<ruby>馬<rt>うま</rt></ruby>に <ruby>乗<rt>の</rt></ruby>った ことが ありますか。— いいえ、ありません。",de:"Bist du schon mal geritten? — Nein, noch nie."},
    {jp:"<ruby>生<rt>なま</rt></ruby>のタコを <ruby>食<rt>た</rt></ruby>べた ことが あります。",de:"Ich habe schon mal rohen Tintenfisch gegessen."}
  ], note:"⚠️ Nicht mit V<sub>ル</sub>+ことが あります verwechseln (= \"manchmal V\") aus L8! た-Form = Erfahrung in der Vergangenheit."},
  {l:19, t:"V₁ た り、V₂ た り します", de:"…und so weiter (Aktivitäten)", rule:"Listet beispielhafte (nicht vollständige) Handlungen auf. た-Form + り.", conj:[
    {form:"Anschluss",verb:"V₁<sub>タ</sub>り、 V₂<sub>タ</sub>り します",de:"mal V₁, mal V₂ (beispielhaft)"},
    {form:"Tempus",verb:"します / しました / します",de:"das letzte します trägt Tempus"},
    {form:"Beispiel",verb:"<ruby>週末<rt>しゅうまつ</rt></ruby>は <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んだり、<ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>たり します",de:"Am Wochenende lese ich u.a. Bücher und schaue Filme"},
    {form:"Vergangenheit",verb:"<ruby>買<rt>か</rt></ruby>い<ruby>物<rt>もの</rt></ruby>したり、<ruby>散歩<rt>さんぽ</rt></ruby>したり しました",de:"habe u.a. eingekauft und spaziert"}
  ], ex:[
    {jp:"<ruby>日曜日<rt>にちようび</rt></ruby>は <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んだり、<ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>たり します。",de:"Sonntags lese ich Bücher, sehe Filme usw."},
    {jp:"<ruby>部屋<rt>へや</rt></ruby>を <ruby>掃除<rt>そうじ</rt></ruby>したり、<ruby>洗濯<rt>せんたく</rt></ruby>したり しました。",de:"Ich habe (u.a.) aufgeräumt und Wäsche gewaschen."}
  ], note:"💡 Unterschied zu て-Form-Reihen: たり-Form impliziert \"BEISPIELHAFT\" (es gab noch mehr) — て-Form impliziert \"alles und in der Reihenfolge\"."},
  {l:19, t:"〜く/に なります", de:"… werden (Veränderung)", rule:"Zustandsveränderung. い-Adj: い→く+なる (寒い→寒くなる). な-Adj/N: に+なる (きれいになる / 医者になる).", conj:[
    {form:"い-Adj: い→く+なる",verb:"<ruby>寒<rt>さむ</rt></ruby>く なります",de:"wird kalt"},
    {form:"な-Adj: に+なる",verb:"きれいに なります",de:"wird schön"},
    {form:"N: に+なる",verb:"<ruby>医者<rt>いしゃ</rt></ruby>に なります",de:"wird Arzt"}
  ], ex:[
    {jp:"<ruby>寒<rt>さむ</rt></ruby>くなりました。 / <ruby>町<rt>まち</rt></ruby>が きれいに なりました。",de:"Es ist kalt geworden. / Die Stadt ist schön geworden."},
    {jp:"<ruby>日本語<rt>にほんご</rt></ruby>が <ruby>上手<rt>じょうず</rt></ruby>に なりたいです。",de:"Ich möchte besser in Japanisch werden."}
  ]},
  {l:20, t:"<ruby>普通形<rt>ふつうけい</rt></ruby> (Plain Form — Übersicht)", de:"Plain-Form (informell)", rule:"Alle 4 Grundformen im Plain-Stil. Verben + Adjektive + Nomen/な-Adj.", conj:[
    {form:"Verb: Präsens +/−",verb:"<ruby>食<rt>た</rt></ruby>べる / <ruby>食<rt>た</rt></ruby>べない",de:"essen / nicht essen"},
    {form:"Verb: Vergangenheit +/−",verb:"<ruby>食<rt>た</rt></ruby>べた / <ruby>食<rt>た</rt></ruby>べなかった",de:"aß / aß nicht"},
    {form:"い-Adj +/− Präs.",verb:"<ruby>大<rt>おお</rt></ruby>きい / <ruby>大<rt>おお</rt></ruby>きくない",de:"groß / nicht groß"},
    {form:"い-Adj +/− Verg.",verb:"<ruby>大<rt>おお</rt></ruby>きかった / <ruby>大<rt>おお</rt></ruby>きくなかった",de:"war groß / war nicht groß"},
    {form:"な-Adj/N Präs. +/−",verb:"<ruby>元気<rt>げんき</rt></ruby>だ / <ruby>元気<rt>げんき</rt></ruby>じゃない",de:"ist gesund / nicht gesund"},
    {form:"な-Adj/N Verg. +/−",verb:"<ruby>元気<rt>げんき</rt></ruby>だった / <ruby>元気<rt>げんき</rt></ruby>じゃなかった",de:"war gesund / nicht gesund"}
  ], ex:[
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>来<rt>く</rt></ruby>る? (plain)",de:"Kommst du morgen?"},
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>来<rt>き</rt></ruby>ますか。(höflich)",de:"Kommen Sie morgen?"}
  ]},
  {l:20, t:"Höflich vs. Plain (Stilebenen)", de:"です/ます ↔ Plain-Form", rule:"Plain-Form für: enge Freunde, Familie, Kinder, Tagebuch, Zeitungen, interne Gedanken. です/ます-Form für: Fremde, Vorgesetzte, Kunden, formelle Situationen. Bei Unsicherheit: immer です/ます.", conj:[
    {form:"Frage plain",verb:"<ruby>食<rt>た</rt></ruby>べる? (mit Intonation)",de:"Isst du?"},
    {form:"Frage höflich",verb:"<ruby>食<rt>た</rt></ruby>べますか。",de:"Essen Sie?"},
    {form:"Aussage plain",verb:"<ruby>行<rt>い</rt></ruby>かない。",de:"Ich gehe nicht."},
    {form:"Aussage höflich",verb:"<ruby>行<rt>い</rt></ruby>きません。",de:"Ich gehe nicht."}
  ], ex:[
    {jp:"お<ruby>腹<rt>なか</rt></ruby> すいた? (plain, Freunde)",de:"Hast du Hunger?"},
    {jp:"お<ruby>腹<rt>なか</rt></ruby>が すきましたか。(höflich)",de:"Haben Sie Hunger?"},
    {jp:"ごめん、わからない。(plain) / すみません、わかりません。(höflich)",de:"Tut mir leid, ich weiß es nicht."}
  ], note:"Frauen nutzen tendenziell weniger だ in Plain-Aussagen. Bei Fragen: だ wird oft weggelassen."},
  {l:20, t:"Plain-Konversation (Fragen & Antworten)", de:"Unterhaltung im Plain-Stil", rule:"Bei Fragen in Plain: だ fällt oft weg, Partikel か wird durch steigende Intonation ersetzt. Bei な-Adj/N in Fragen ebenfalls ohne だ. Antworten haben oft verkürzte Formen.", conj:[
    {form:"Frage: V plain + ?",verb:"<ruby>行<rt>い</rt></ruby>く?",de:"Gehst du? (statt 行きますか)"},
    {form:"Frage: N/な-Adj OHNE だ",verb:"<ruby>元気<rt>げんき</rt></ruby>? / <ruby>学生<rt>がくせい</rt></ruby>?",de:"Geht's dir gut? / Bist du Student?"},
    {form:"ja/nein plain",verb:"うん / ううん",de:"ja / nein (Freunde)"}
  ], ex:[
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>暇<rt>ひま</rt></ruby>? — うん、<ruby>暇<rt>ひま</rt></ruby>だよ。",de:"Hast du morgen Zeit? — Ja, hab ich."},
    {jp:"これ <ruby>食<rt>た</rt></ruby>べる? — ううん、いらない。",de:"Isst du das? — Nein, ich will nicht."},
    {jp:"どこ <ruby>行<rt>い</rt></ruby>くの? (mit の statt か)",de:"Wohin gehst du?"}
  ], note:"の am Ende bei Frauen/informell = statt か. よ/ね für Betonung."},
  {l:20, t:"〜て(い)る・〜て(い)く・〜て(お)く (い/お-Drop)", de:"Weglassen von い und お in Plain", rule:"In informellem Gespräch wird das い in ている/ていく/ていく oft weggelassen. Genauso das お in ておく → とく. Typisch für Jugendsprache und entspannte Konversation.", conj:[
    {form:"〜ている → 〜てる",verb:"<ruby>食<rt>た</rt></ruby>べてる (statt 食べている)",de:"isst gerade"},
    {form:"〜ていく → 〜てく",verb:"<ruby>持<rt>も</rt></ruby>ってく (statt 持っていく)",de:"mitnehmen"},
    {form:"〜ておく → 〜とく",verb:"やっとく (statt やっておく)",de:"vorher erledigen"}
  ], ex:[
    {jp:"<ruby>何<rt>なに</rt></ruby> してる? — テレビ <ruby>見<rt>み</rt></ruby>てる。",de:"Was machst du? — Ich schaue fern."},
    {jp:"<ruby>傘<rt>かさ</rt></ruby> <ruby>持<rt>も</rt></ruby>ってく? — うん、<ruby>持<rt>も</rt></ruby>ってく。",de:"Nimmst du einen Regenschirm mit? — Ja, nehme ich."},
    {jp:"あとで やっとくね。",de:"Ich mache es später (vorher)."}
  ], note:"NICHT in formellen Situationen nutzen!"},
  {l:20, t:"〜けど (Plain-Variante von が)", de:"aber / jedoch (informell)", rule:"けど ist die informelle Plain-Form von が. Kann am Satzende stehen für weiche Aussage/Überleitung. Auch けれど(も) als höflichere Variante, aber けど ist am häufigsten im Alltag.", conj:[
    {form:"が (neutral/schriftlich)",verb:"<ruby>高<rt>たか</rt></ruby>いですが…",de:"Es ist teuer, aber …"},
    {form:"けど (informell/plain)",verb:"<ruby>高<rt>たか</rt></ruby>いけど…",de:"Es ist teuer, aber …"},
    {form:"けれど (höflicher)",verb:"<ruby>高<rt>たか</rt></ruby>いけれど",de:"Es ist teuer, jedoch"}
  ], ex:[
    {jp:"<ruby>行<rt>い</rt></ruby>きたいけど、<ruby>時間<rt>じかん</rt></ruby>が ない。",de:"Ich möchte gehen, aber ich habe keine Zeit."},
    {jp:"すみませんけど、これは <ruby>何<rt>なん</rt></ruby>ですか。",de:"Entschuldigung, aber was ist das?"},
    {jp:"おいしかったけど、ちょっと <ruby>高<rt>たか</rt></ruby>かった。",de:"Es war lecker, aber ein bisschen teuer."}
  ], note:"けど am Satzende = sanfte Aussage, offener Schluss (wie Englisch »though«)"},
  {l:21, t:"<ruby>普通形<rt>ふつうけい</rt></ruby> + と <ruby>思<rt>おも</rt></ruby>います", de:"Ich denke, dass …", rule:"Meinung/Vermutung. Inhalt steht in Plain-Form, gefolgt von と思います. Bei N/な-Adj Präsens: 〜だと思います.", conj:[
    {form:"Anschluss",verb:"Plain-Form + と {r(\"思\",\"おも\")}います",de:"ich denke/glaube, dass …"},
    {form:"Verb",verb:"<ruby>行<rt>い</rt></ruby>く と <ruby>思<rt>おも</rt></ruby>います",de:"ich denke, er geht"},
    {form:"い-Adj",verb:"<ruby>高<rt>たか</rt></ruby>い と <ruby>思<rt>おも</rt></ruby>います",de:"ich denke, es ist teuer"},
    {form:"な-Adj",verb:"<ruby>静<rt>しず</rt></ruby>か<b>だ</b> と <ruby>思<rt>おも</rt></ruby>います",de:"ich denke, es ist ruhig (だ nötig!)"},
    {form:"Nomen",verb:"<ruby>学生<rt>がくせい</rt></ruby><b>だ</b> と <ruby>思<rt>おも</rt></ruby>います",de:"ich denke, er ist Student (だ nötig!)"},
    {form:"Verneint",verb:"<ruby>行<rt>い</rt></ruby>かない と <ruby>思<rt>おも</rt></ruby>います",de:"ich denke, er geht NICHT"}
  ], ex:[
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>ると <ruby>思<rt>おも</rt></ruby>います。",de:"Ich denke, morgen regnet es."},
    {jp:"ミラーさんは もう <ruby>帰<rt>かえ</rt></ruby>ったと <ruby>思<rt>おも</rt></ruby>います。",de:"Ich denke, Herr Miller ist schon nach Hause gegangen."},
    {jp:"それは <ruby>難<rt>むずか</rt></ruby>しいと <ruby>思<rt>おも</rt></ruby>いません。",de:"Ich glaube nicht, dass das schwierig ist."}
  ], note:"⚠️ Bei な-Adj und Nomen MUSS だ vor と stehen! 学生と思います ist FALSCH → 学生<b>だ</b>と思います."},
  {l:21, t:"「…」と <ruby>言<rt>い</rt></ruby>います", de:"Er hat gesagt: »…«", rule:"Direkte oder indirekte Rede. Direkt: 「」と言いました. Indirekt: Plain-Form + と言いました.", conj:[
    {form:"Direkte Rede",verb:"「…」+ と {r(\"言\",\"い\")}います",de:"sagt: \"…\""},
    {form:"Indirekte Rede",verb:"Plain-Form + と {r(\"言\",\"い\")}います",de:"sagt, dass …"},
    {form:"Direkt",verb:"ミラーさんは「<ruby>行<rt>い</rt></ruby>きます」と <ruby>言<rt>い</rt></ruby>いました",de:"M. sagte: \"Ich gehe\""},
    {form:"Indirekt",verb:"ミラーさんは <ruby>行<rt>い</rt></ruby>く と <ruby>言<rt>い</rt></ruby>いました",de:"M. sagte, dass er gehe"},
    {form:"Indirekt な-Adj",verb:"<ruby>元気<rt>げんき</rt></ruby><b>だ</b> と <ruby>言<rt>い</rt></ruby>いました",de:"sagte, er sei gesund (だ nötig!)"}
  ], ex:[
    {jp:"ミラーさんは「<ruby>明日<rt>あした</rt></ruby> <ruby>休<rt>やす</rt></ruby>みます」と <ruby>言<rt>い</rt></ruby>いました。",de:"Herr Miller sagte: »Ich habe morgen frei.«"},
    {jp:"<ruby>母<rt>はは</rt></ruby>は <ruby>来週<rt>らいしゅう</rt></ruby> <ruby>来<rt>く</rt></ruby>ると <ruby>言<rt>い</rt></ruby>いました。",de:"Meine Mutter sagte, sie kommt nächste Woche."}
  ], note:"💡 Direkte Rede: Originaltext in 「」. Indirekte Rede: Plain-Form (mit だ bei な-Adj/N!). Bei Nachrichten/Notizen: と書いてあります (steht geschrieben)."},
  {l:21, t:"〜でしょう?", de:"… nicht wahr?", rule:"Bestätigungsfrage (mit steigender Intonation). Sucht Zustimmung des Gesprächspartners.", conj:[
    {form:"Anschluss",verb:"Plain-Form (ohne だ!) + でしょう?",de:"… oder? (steigende Intonation)"},
    {form:"Verb",verb:"<ruby>明日<rt>あした</rt></ruby> <ruby>来<rt>く</rt></ruby>る でしょう?",de:"kommt er morgen, oder?"},
    {form:"い-Adj",verb:"<ruby>寒<rt>さむ</rt></ruby>い でしょう?",de:"kalt, oder?"},
    {form:"な-Adj",verb:"<ruby>元気<rt>げんき</rt></ruby> でしょう?",de:"gesund, oder? (KEIN だ!)"},
    {form:"Nomen",verb:"<ruby>学生<rt>がくせい</rt></ruby> でしょう?",de:"Student, oder? (KEIN だ!)"}
  ], ex:[
    {jp:"<ruby>明日<rt>あした</rt></ruby>は <ruby>休<rt>やす</rt></ruby>みでしょう?",de:"Morgen hast du frei, oder?"},
    {jp:"あの<ruby>映画<rt>えいが</rt></ruby>は おもしろかったでしょう?",de:"Der Film war interessant, oder?"}
  ], note:"⚠️ Bei な-Adj und Nomen NIEMALS だ vor でしょう! 学生<b>だ</b>でしょう ist FALSCH. でしょう ersetzt das だ. Steigende Intonation = Bestätigungsfrage."},
  {l:21, t:"N₁(Ort)で N₂(Ereignis)が あります", de:"In N₁ findet N₂ statt", rule:"あります kann auch »stattfinden« heißen — für Feste, Veranstaltungen, Konzerte, Besprechungen. で markiert den Veranstaltungsort (nicht に!).", conj:[
    {form:"Anschluss",verb:"N₁(Ort)<b>で</b> N₂(Event)<b>が</b> あります",de:"in N₁ findet N₂ statt"},
    {form:"Beispiel",verb:"<ruby>東京<rt>とうきょう</rt></ruby>で コンサート<b>が</b> あります",de:"In Tokyo gibt es ein Konzert"},
    {form:"⚠️ Vergleich (Existenz)",verb:"<ruby>東京<rt>とうきょう</rt></ruby><b>に</b> <ruby>駅<rt>えき</rt></ruby><b>が</b> あります",de:"In Tokyo gibt es einen Bahnhof (Existenz!)"},
    {form:"Beispiel Tempus",verb:"<ruby>昨日<rt>きのう</rt></ruby> ホテルで <ruby>会議<rt>かいぎ</rt></ruby><b>が</b> ありました",de:"Gestern war im Hotel eine Konferenz"}
  ], ex:[
    {jp:"<ruby>東京<rt>とうきょう</rt></ruby>で コンサートが あります。",de:"In Tokyo findet ein Konzert statt."},
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>で <ruby>祭<rt>まつ</rt></ruby>りが あります。",de:"In Kyoto findet ein Fest statt."},
    {jp:"<ruby>会議室<rt>かいぎしつ</rt></ruby>で <ruby>会議<rt>かいぎ</rt></ruby>が あります。",de:"Im Besprechungsraum findet eine Besprechung statt."}
  ], note:"⚠️ Wichtig: Bei Veranstaltungen/Events benutzt man <b>で</b> (Aktionsort), bei Existenz von Dingen <b>に</b> (Existenzort)! Konzert/Fest/Besprechung → で. Bahnhof/Park → に."},
  {l:21, t:"N (<ruby>機会<rt>きかい</rt></ruby>) で", de:"Bei (Gelegenheit/Anlass)", rule:"で markiert auch Anlässe und Gelegenheiten (Besprechungen, Reisen, Partys). Drückt aus: »bei/während dieser Gelegenheit«. Fokus auf den Rahmen, in dem etwas passiert.", conj:[
    {form:"Anschluss",verb:"N(Anlass) + で",de:"bei/während (Anlass)"},
    {form:"Konferenz",verb:"<ruby>会議<rt>かいぎ</rt></ruby>で <ruby>発表<rt>はっぴょう</rt></ruby>します",de:"in der Konferenz präsentieren"},
    {form:"Reise",verb:"<ruby>旅行<rt>りょこう</rt></ruby>で <ruby>写真<rt>しゃしん</rt></ruby>を <ruby>撮<rt>と</rt></ruby>りました",de:"auf der Reise Fotos gemacht"},
    {form:"Party",verb:"パーティー で たくさん <ruby>食<rt>た</rt></ruby>べました",de:"auf der Party viel gegessen"}
  ], ex:[
    {jp:"<ruby>会議<rt>かいぎ</rt></ruby>で いろいろ <ruby>話<rt>はな</rt></ruby>しました。",de:"Bei der Besprechung haben wir viel geredet."},
    {jp:"<ruby>旅行<rt>りょこう</rt></ruby>で <ruby>友達<rt>ともだち</rt></ruby>が できました。",de:"Auf der Reise habe ich Freunde gefunden."},
    {jp:"パーティーで <ruby>彼<rt>かれ</rt></ruby>に <ruby>会<rt>あ</rt></ruby>いました。",de:"Auf der Party habe ich ihn getroffen."}
  ], note:"💡 で markiert hier den ANLASS / RAHMEN, nicht den Ort. Häufig: 会議で, 旅行で, パーティーで, 仕事で, 試験で."},
  {l:21, t:"N でも V (Vorschlag)", de:"Wie wäre es mit N? (Vorschlag)", rule:"N でも bei Vorschlägen: »zum Beispiel N, oder etwas anderes«. Zeigt, dass N nur ein Beispiel ist und der Sprecher offen für Alternativen ist. Sehr höflich.", conj:[
    {form:"Vorschlag machen",verb:"コーヒーでも <ruby>飲<rt>の</rt></ruby>みませんか",de:"Wie wäre es mit Kaffee (oder was anderem)?"},
    {form:"Freizeit",verb:"<ruby>映画<rt>えいが</rt></ruby>でも <ruby>見<rt>み</rt></ruby>ませんか",de:"Wollen wir einen Film schauen (oder so)?"}
  ], ex:[
    {jp:"お<ruby>茶<rt>ちゃ</rt></ruby>でも <ruby>飲<rt>の</rt></ruby>みましょう。",de:"Lass uns einen Tee (oder so) trinken."},
    {jp:"<ruby>週末<rt>しゅうまつ</rt></ruby> <ruby>映画<rt>えいが</rt></ruby>でも <ruby>見<rt>み</rt></ruby>に <ruby>行<rt>い</rt></ruby>きませんか。",de:"Wollen wir am Wochenende einen Film sehen (o.ä.)?"},
    {jp:"<ruby>散歩<rt>さんぽ</rt></ruby>でも しませんか。",de:"Wie wäre es mit einem Spaziergang?"}
  ], note:"でも macht Vorschläge weicher und weniger aufdringlich"},
  {l:21, t:"V<ruby>ない<rt></rt></ruby>-Form + と…", de:"Ich muss … (Kurzform)", rule:"Sehr häufige Kurzform von なければならない. ない-Form + と… (der Rest wird weggelassen, weil klar). Besonders in Plain-Konversation. Kann auch bedeuten »sonst passiert etwas Schlimmes«.", conj:[
    {form:"〜ないと (Kurzform)",verb:"<ruby>行<rt>い</rt></ruby>かないと",de:"Ich muss gehen"},
    {form:"Vollform: 〜ないといけない",verb:"<ruby>行<rt>い</rt></ruby>かないと いけない",de:"Ich muss gehen"},
    {form:"Vgl. formeller: 〜なければならない",verb:"<ruby>行<rt>い</rt></ruby>かなければ ならない",de:"Ich muss gehen (formell)"}
  ], ex:[
    {jp:"もう <ruby>行<rt>い</rt></ruby>かないと…",de:"Ich muss jetzt gehen…"},
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>早<rt>はや</rt></ruby>く <ruby>起<rt>お</rt></ruby>きないと。",de:"Morgen muss ich früh aufstehen."},
    {jp:"<ruby>薬<rt>くすり</rt></ruby>を <ruby>飲<rt>の</rt></ruby>まないと、<ruby>治<rt>なお</rt></ruby>らないよ。",de:"Du musst die Medizin nehmen, sonst wirst du nicht gesund."}
  ], note:"Formalität: 〜ないと (sehr casual) < 〜ないといけない < 〜なければならない (formell)"},
  {l:22, t:"<ruby>名詞修飾<rt>めいししゅうしょく</rt></ruby> (Relativsatz)", de:"Verb-/Adj-Sätze als Attribut", rule:"Plain-Form-Satz steht direkt VOR einem Nomen und beschreibt es. Kein »who/which/that«. Subjekt im Relativsatz mit が (nicht は!).", conj:[
    {form:"Anschluss",verb:"[Plain-Satz] + N",de:"der Plain-Satz beschreibt N"},
    {form:"Subjekt im RS",verb:"<ruby>が<rt></rt></ruby> (NICHT は!)",de:"innerhalb des Relativsatzes immer が"},
    {form:"Verb-RS",verb:"ミラーさん<b>が</b><ruby>作<rt>つく</rt></ruby>った ケーキ",de:"der Kuchen, den M. machte"},
    {form:"Verb-RS Präsens",verb:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>く <ruby>人<rt>ひと</rt></ruby>",de:"die Person, die nach Kyoto fährt"},
    {form:"Verb-RS Verneint",verb:"<ruby>行<rt>い</rt></ruby>かない <ruby>人<rt>ひと</rt></ruby>",de:"die Person, die nicht geht"},
    {form:"Vergleich Deutsch",verb:"[Satz] N",de:"Reihenfolge: erst Beschreibung, DANN Nomen"}
  ], ex:[
    {jp:"これは ミラーさんが <ruby>作<rt>つく</rt></ruby>った ケーキです。",de:"Das ist der Kuchen, den Herr Miller gemacht hat."},
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>く <ruby>人<rt>ひと</rt></ruby>は <ruby>誰<rt>だれ</rt></ruby>ですか。",de:"Wer ist die Person, die nach Kyoto fährt?"},
    {jp:"<ruby>昨日<rt>きのう</rt></ruby> <ruby>会<rt>あ</rt></ruby>った <ruby>人<rt>ひと</rt></ruby>は <ruby>医者<rt>いしゃ</rt></ruby>です。",de:"Die Person, die ich gestern getroffen habe, ist Arzt."}
  ], note:"⚠️ KEIN »der/die/das«! KEIN Komma! Im Relativsatz steht das Subjekt mit <b>が</b> (NIEMALS は). Reihenfolge: erst Beschreibung → dann Nomen (umgekehrt zum Deutschen)."},
  {l:22, t:"Relativsatz mit verschiedenen Wortarten", de:"alle Wortarten als Attribut", rule:"い-Adj: direkt (高い本). な-Adj: な (きれいな町). N: の (日本語の本). Verb: Plain-Form (食べる人・食べた人).", conj:[
    {form:"Verb (Plain)",verb:"V<sub>ル</sub> / V<sub>タ</sub> / V<sub>ナイ</sub> + N",de:"<ruby>食<rt>た</rt></ruby>べる <ruby>人<rt>ひと</rt></ruby> = Person, die isst"},
    {form:"い-Adj",verb:"い-Adj + N (direkt!)",de:"<ruby>赤<rt>あか</rt></ruby>い かばん = rote Tasche"},
    {form:"な-Adj",verb:"な-Adj + <b>な</b> + N",de:"<ruby>有名<rt>ゆうめい</rt></ruby><b>な</b> <ruby>寺<rt>てら</rt></ruby> = berühmter Tempel"},
    {form:"Nomen",verb:"N₁ + <b>の</b> + N₂",de:"<ruby>日本語<rt>にほんご</rt></ruby><b>の</b> <ruby>本<rt>ほん</rt></ruby> = japan. Buch"},
    {form:"Verneint な-Adj",verb:"な-Adj<b>じゃない</b> + N",de:"<ruby>有名<rt>ゆうめい</rt></ruby>じゃない <ruby>店<rt>みせ</rt></ruby> = nicht berühmtes Geschäft"},
    {form:"Verneint Nomen",verb:"N + <b>じゃない</b> + N₂",de:"<ruby>先生<rt>せんせい</rt></ruby>じゃない <ruby>人<rt>ひと</rt></ruby> = nicht-Lehrer-Person"}
  ], ex:[
    {jp:"<ruby>赤<rt>あか</rt></ruby>い かばんが <ruby>欲<rt>ほ</rt></ruby>しいです。",de:"Ich möchte eine rote Tasche."},
    {jp:"<ruby>有名<rt>ゆうめい</rt></ruby>な お<ruby>寺<rt>てら</rt></ruby>を <ruby>見<rt>み</rt></ruby>ました。",de:"Ich habe einen berühmten Tempel gesehen."},
    {jp:"これは <ruby>日本<rt>にほん</rt></ruby>で <ruby>作<rt>つく</rt></ruby>られた <ruby>車<rt>くるま</rt></ruby>です。",de:"Das ist ein in Japan hergestelltes Auto."}
  ], note:"💡 Faustregel: Verb/い-Adj direkt davor. な-Adj braucht な. Nomen braucht の. Bei Verneinung der な-Adj/Nomen: じゃない (NICHT じゃ ありません!)."},
  {l:22, t:"V<ruby>辞書形<rt>じしょけい</rt></ruby> + <ruby>時間<rt>じかん</rt></ruby>/<ruby>約束<rt>やくそく</rt></ruby>/<ruby>用事<rt>ようじ</rt></ruby>", de:"Zeit/Verabredung/Termin, etwas zu tun", rule:"Typische Kollokationen: Wörterbuchform-Satz + Zeit-Nomen. Drückt aus, dass man Zeit/Verabredung/Etwas zu tun HAT für eine bestimmte Aktivität.", conj:[
    {form:"Vdict+時間 (Zeit für …)",verb:"<ruby>食<rt>た</rt></ruby>べる <ruby>時間<rt>じかん</rt></ruby>",de:"Zeit zum Essen"},
    {form:"Vdict+約束 (Verabredung zu …)",verb:"<ruby>会<rt>あ</rt></ruby>う <ruby>約束<rt>やくそく</rt></ruby>",de:"Verabredung, sich zu treffen"},
    {form:"Vdict+用事 (etwas zu tun)",verb:"<ruby>銀行<rt>ぎんこう</rt></ruby>へ <ruby>行<rt>い</rt></ruby>く <ruby>用事<rt>ようじ</rt></ruby>",de:"etwas zur Bank zu erledigen"}
  ], ex:[
    {jp:"<ruby>朝<rt>あさ</rt></ruby>ごはんを <ruby>食<rt>た</rt></ruby>べる <ruby>時間<rt>じかん</rt></ruby>が ありません。",de:"Ich habe keine Zeit zum Frühstücken."},
    {jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>友達<rt>ともだち</rt></ruby>と <ruby>会<rt>あ</rt></ruby>う <ruby>約束<rt>やくそく</rt></ruby>が あります。",de:"Morgen habe ich eine Verabredung mit einem Freund."},
    {jp:"ちょっと <ruby>行<rt>い</rt></ruby>く <ruby>用事<rt>ようじ</rt></ruby>が あるんです。",de:"Ich habe da noch etwas zu erledigen."}
  ]},
  {l:22, t:"が im Relativsatz (Subjekt-Markierung)", de:"が markiert das Subjekt im Relativsatz", rule:"WICHTIG: Innerhalb eines Relativsatzes wird das Subjekt mit が markiert (nicht は!). は ist nur im Hauptsatz erlaubt. Auch の ist als Variante möglich (nur in Relativsätzen).", conj:[
    {form:"Hauptsatz: は",verb:"ミラーさんは ケーキを <ruby>作<rt>つく</rt></ruby>った",de:"Herr Miller hat den Kuchen gemacht"},
    {form:"★ Relativsatz: が (nicht は!)",verb:"ミラーさんが <ruby>作<rt>つく</rt></ruby>った ケーキ",de:"der Kuchen, den Herr Miller gemacht hat"},
    {form:"Variante: の (nur Relativsatz)",verb:"ミラーさんの <ruby>作<rt>つく</rt></ruby>った ケーキ",de:"(gleiche Bedeutung)"}
  ], ex:[
    {jp:"<ruby>私<rt>わたし</rt></ruby>が <ruby>書<rt>か</rt></ruby>いた <ruby>手紙<rt>てがみ</rt></ruby>です。",de:"Das ist der Brief, den ich geschrieben habe."},
    {jp:"<ruby>昨日<rt>きのう</rt></ruby> <ruby>友達<rt>ともだち</rt></ruby>が <ruby>来<rt>き</rt></ruby>た <ruby>日<rt>ひ</rt></ruby>",de:"der Tag, an dem gestern ein Freund kam"},
    {jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>って いる <ruby>町<rt>まち</rt></ruby>",de:"die Stadt, in der es regnet"}
  ], note:"Häufiger Fehler: は im Relativsatz. IMMER が (oder の) verwenden!"},
  {l:23, t:"V<ruby>辞書形<rt>じしょけい</rt></ruby>/V<ruby>ない<rt></rt></ruby>+ とき、…", de:"Wenn (vor/während der Handlung)", rule:"Wörterbuchform oder ない-Form vor とき: Haupthandlung passiert VOR oder WÄHREND der Nebenhandlung. Die Nebenhandlung ist noch nicht abgeschlossen.", conj:[
    {form:"辞書形+とき (vor/während)",verb:"<ruby>行<rt>い</rt></ruby>くとき",de:"bevor ich gehe / unterwegs"},
    {form:"い-Adj+とき",verb:"<ruby>若<rt>わか</rt></ruby>いとき",de:"als ich jung war"},
    {form:"な-Adj/N + な/の + とき",verb:"<ruby>暇<rt>ひま</rt></ruby>なとき / <ruby>学生<rt>がくせい</rt></ruby>のとき",de:"wenn ich Zeit habe / als ich Student war"},
    {form:"ない+とき",verb:"<ruby>分<rt>わ</rt></ruby>からないとき",de:"wenn man nicht versteht"}
  ], ex:[
    {jp:"<ruby>図書館<rt>としょかん</rt></ruby>で <ruby>本<rt>ほん</rt></ruby>を <ruby>借<rt>か</rt></ruby>りるとき、カードが <ruby>要<rt>い</rt></ruby>ります。",de:"Wenn man in der Bibliothek Bücher leiht, braucht man eine Karte."},
    {jp:"<ruby>若<rt>わか</rt></ruby>いとき、よく <ruby>旅行<rt>りょこう</rt></ruby>しました。",de:"Als ich jung war, bin ich oft gereist."},
    {jp:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>くとき、カメラを <ruby>買<rt>か</rt></ruby>いました。",de:"Bevor ich nach Japan fuhr, habe ich eine Kamera gekauft."}
  ]},
  {l:23, t:"V た + とき、…", de:"Als (nach der Handlung abgeschlossen)", rule:"た-Form vor とき: Nebenhandlung ist BEREITS ABGESCHLOSSEN, wenn die Haupthandlung beginnt. Wichtiger Unterschied zu 辞書形+とき!", conj:[
    {form:"Vた+とき (Handlung abgeschlossen)",verb:"<ruby>着<rt>つ</rt></ruby>いたとき",de:"als (ich) angekommen war"},
    {form:"Vergleich: 行くとき vs 行ったとき",verb:"<ruby>行<rt>い</rt></ruby>くとき (vor Abfahrt) / <ruby>行<rt>い</rt></ruby>ったとき (nach Ankunft)",de:"vor dem Gehen / als ich angekommen war"}
  ], ex:[
    {jp:"<ruby>家<rt>いえ</rt></ruby>へ <ruby>帰<rt>かえ</rt></ruby>ったとき、「ただいま」と <ruby>言<rt>い</rt></ruby>います。",de:"Wenn ich nach Hause komme (angekommen bin), sage ich »tadaima«."},
    {jp:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>来<rt>き</rt></ruby>たとき、<ruby>友達<rt>ともだち</rt></ruby>が <ruby>迎<rt>むか</rt></ruby>えに <ruby>来<rt>き</rt></ruby>ました。",de:"Als ich nach Japan kam, holte mich ein Freund ab."},
    {jp:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>ったとき、この お<ruby>土産<rt>みやげ</rt></ruby>を <ruby>買<rt>か</rt></ruby>いました。",de:"Als ich in Kyoto war, habe ich dieses Souvenir gekauft."}
  ], note:"Wichtig: 日本へ行くとき = vor Abreise (noch in Deutschland). 日本へ行ったとき = in Japan (schon dort)."},
  {l:23, t:"V<ruby>辞書形<rt>じしょけい</rt></ruby> と、…", de:"Wenn/sobald …, automatisch …", rule:"Konditional »と«: wenn A, dann passiert immer/automatisch B. Naturgesetz, Gewohnheit, Mechanismus. Kein Wille oder Bitte im Hauptsatz!", conj:[
    {form:"Anschluss",verb:"V<sub>ル</sub> + と、…",de:"wenn V passiert, dann automatisch …"},
    {form:"Beispiel",verb:"このボタンを <ruby>押<rt>お</rt></ruby>す と、お<ruby>釣<rt>つ</rt></ruby>りが <ruby>出<rt>で</rt></ruby>ます",de:"wenn man drückt, kommt Wechselgeld"},
    {form:"Naturgesetz",verb:"<ruby>春<rt>はる</rt></ruby>に なる と、<ruby>桜<rt>さくら</rt></ruby>が <ruby>咲<rt>さ</rt></ruby>きます",de:"wenn Frühling kommt, blühen Kirschen"},
    {form:"Verneint",verb:"V<sub>ナイ</sub> + と、…",de:"wenn man V NICHT tut, dann …"},
    {form:"Beispiel verneint",verb:"<ruby>勉強<rt>べんきょう</rt></ruby>しない と、<ruby>試験<rt>しけん</rt></ruby>に <ruby>落<rt>お</rt></ruby>ちます",de:"wer nicht lernt, fällt durch"}
  ], ex:[
    {jp:"このボタンを <ruby>押<rt>お</rt></ruby>すと、お<ruby>釣<rt>つ</rt></ruby>りが <ruby>出<rt>で</rt></ruby>ます。",de:"Wenn man diesen Knopf drückt, kommt das Wechselgeld heraus."},
    {jp:"<ruby>春<rt>はる</rt></ruby>に なると、<ruby>桜<rt>さくら</rt></ruby>が <ruby>咲<rt>さ</rt></ruby>きます。",de:"Wenn der Frühling kommt, blüht die Kirschblüte."},
    {jp:"この<ruby>道<rt>みち</rt></ruby>を まっすぐ <ruby>行<rt>い</rt></ruby>くと、<ruby>駅<rt>えき</rt></ruby>が あります。",de:"Wenn man diese Straße geradeaus geht, ist der Bahnhof da."}
  ], note:"⚠️ 4 Konditionale unterscheiden: <b>と</b> = automatisch (Naturgesetz, Mechanismus) / <b>たら</b> = einmalige Folge / <b>ば</b> = generelle Bedingung / <b>なら</b> = themenbezogen. Bei <b>と</b> NIEMALS Wille/Bitte/Befehl im Hauptsatz!"},
  {l:23, t:"N(Ort) を V (Bewegungsverb)", de:"durch/über/entlang N (Ort der Bewegung)", rule:"を markiert den Ort, durch/über/entlang dem man sich bewegt. Mit Bewegungsverben wie 歩く (gehen), 走る (laufen), 渡る (überqueren), 曲がる (abbiegen), 散歩する (spazieren), 通る (passieren), 飛ぶ (fliegen).", conj:[
    {form:"歩く (gehen)",verb:"<ruby>道<rt>みち</rt></ruby>を <ruby>歩<rt>ある</rt></ruby>く",de:"die Straße entlanggehen"},
    {form:"渡る (überqueren)",verb:"<ruby>橋<rt>はし</rt></ruby>を <ruby>渡<rt>わた</rt></ruby>る",de:"die Brücke überqueren"},
    {form:"曲がる (abbiegen)",verb:"<ruby>角<rt>かど</rt></ruby>を <ruby>曲<rt>ま</rt></ruby>がる",de:"an der Ecke abbiegen"},
    {form:"散歩する (spazieren)",verb:"<ruby>公園<rt>こうえん</rt></ruby>を <ruby>散歩<rt>さんぽ</rt></ruby>する",de:"im Park spazieren"},
    {form:"飛ぶ (fliegen)",verb:"<ruby>空<rt>そら</rt></ruby>を <ruby>飛<rt>と</rt></ruby>ぶ",de:"durch die Luft fliegen"}
  ], ex:[
    {jp:"この <ruby>道<rt>みち</rt></ruby>を まっすぐ <ruby>行<rt>い</rt></ruby>って ください。",de:"Bitte gehen Sie diese Straße geradeaus."},
    {jp:"<ruby>橋<rt>はし</rt></ruby>を <ruby>渡<rt>わた</rt></ruby>って、<ruby>右<rt>みぎ</rt></ruby>へ <ruby>曲<rt>ま</rt></ruby>がって ください。",de:"Überqueren Sie die Brücke und biegen Sie rechts ab."},
    {jp:"<ruby>毎朝<rt>まいあさ</rt></ruby> <ruby>公園<rt>こうえん</rt></ruby>を <ruby>散歩<rt>さんぽ</rt></ruby>します。",de:"Jeden Morgen gehe ich im Park spazieren."}
  ], note:"Achtung: を (Weg) ≠ で (Ort einer Handlung). 公園で走る = im Park laufen (dort) / 公園を走る = durch den Park laufen (Strecke)."},
  {l:24, t:"くれます", de:"jemand gibt MIR/uns", rule:"くれます = jemand gibt mir/meiner Familie etwas (vs. あげます = ich gebe weg). Geber ist Subjekt mit は/が. Empfänger ist IMMER »ich« oder jemand aus meinem Kreis.", conj:[
    {form:"あげます (ich → andere)",verb:"<ruby>私<rt>わたし</rt></ruby>は <ruby>山田<rt>やまだ</rt></ruby>さんに <ruby>花<rt>はな</rt></ruby>を あげました",de:"Ich gab Yamada Blumen"},
    {form:"もらいます (ich bekomme)",verb:"<ruby>私<rt>わたし</rt></ruby>は <ruby>山田<rt>やまだ</rt></ruby>さんに <ruby>花<rt>はな</rt></ruby>を もらいました",de:"Ich bekam von Yamada Blumen"},
    {form:"くれます (andere → ich)",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんが [<ruby>私<rt>わたし</rt></ruby>に] <ruby>花<rt>はな</rt></ruby>を くれました",de:"Yamada gab MIR Blumen"}
  ], ex:[
    {jp:"<ruby>山田<rt>やまだ</rt></ruby>さんは [<ruby>私<rt>わたし</rt></ruby>に] <ruby>本<rt>ほん</rt></ruby>を くれました。",de:"Frau Yamada hat mir ein Buch gegeben."},
    {jp:"<ruby>父<rt>ちち</rt></ruby>は <ruby>妹<rt>いもうと</rt></ruby>に お<ruby>金<rt>かね</rt></ruby>を くれました。",de:"Mein Vater gab meiner Schwester Geld."}
  ], note:"くれる wird NUR verwendet, wenn der Empfänger »ich« oder jemand aus meinem Inkreis (Familie) ist."},
  {l:24, t:"V て あげます / もらいます / くれます", de:"FÜR jemanden tun", rule:"Drückt aus, dass eine Handlung als Gefallen ausgeführt wird. あげる = ich → andere. もらう = ich bekomme. くれる = andere → ich/uns.", conj:[
    {form:"てあげます (Sprecher hilft)",verb:"<ruby>友達<rt>ともだち</rt></ruby>に <ruby>貸<rt>か</rt></ruby>して あげます",de:"Ich leihe es meinem Freund"},
    {form:"てもらいます (Sprecher profitiert)",verb:"<ruby>友達<rt>ともだち</rt></ruby>に <ruby>直<rt>なお</rt></ruby>して もらいます",de:"Ich lasse es von meinem Freund reparieren"},
    {form:"てくれます (andere → ich)",verb:"<ruby>母<rt>はは</rt></ruby>が <ruby>作<rt>つく</rt></ruby>って くれます",de:"Meine Mutter macht es für mich"}
  ], ex:[
    {jp:"<ruby>友達<rt>ともだち</rt></ruby>に <ruby>京都<rt>きょうと</rt></ruby>を <ruby>案内<rt>あんない</rt></ruby>して もらいました。",de:"Ich habe mich von einem Freund durch Kyoto führen lassen."},
    {jp:"<ruby>母<rt>はは</rt></ruby>は ケーキを <ruby>作<rt>つく</rt></ruby>って くれました。",de:"Meine Mutter hat mir einen Kuchen gemacht."}
  ], note:"あげる = ich Helfer / もらう = ich Empfänger (Initiative bei mir) / くれる = jemand für mich (spontan)"},
  {l:24, t:"N(Person) が V (Subjekt bei Empfangshandlungen)", de:"が statt は bei Geben/Nehmen", rule:"Bei くれる und anderen »geben-für-mich«-Verben wird die gebende Person oft mit が markiert, besonders wenn sie neu eingeführt wird oder betont ist.", conj:[
    {form:"Standard: N は",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんは <ruby>本<rt>ほん</rt></ruby>を くれました",de:"Frau Yamada gab mir ein Buch"},
    {form:"Betont/neu: N が",verb:"<ruby>山田<rt>やまだ</rt></ruby>さんが <ruby>本<rt>ほん</rt></ruby>を くれました",de:"Es war Frau Yamada, die mir das Buch gab"}
  ], ex:[
    {jp:"だれが この <ruby>本<rt>ほん</rt></ruby>を くれましたか。— <ruby>山田<rt>やまだ</rt></ruby>さんが くれました。",de:"Wer hat dir das Buch gegeben? — Frau Yamada."},
    {jp:"<ruby>母<rt>はは</rt></ruby>が セーターを <ruby>作<rt>つく</rt></ruby>って くれました。",de:"Meine Mutter hat mir einen Pullover gestrickt."},
    {jp:"<ruby>友達<rt>ともだち</rt></ruby>が <ruby>駅<rt>えき</rt></ruby>まで <ruby>送<rt>おく</rt></ruby>って くれました。",de:"Ein Freund hat mich zum Bahnhof gebracht."}
  ]},
  {l:24, t:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> が V", de:"Wer/was/welche …?", rule:"Bei Fragen mit Fragewort als Subjekt IMMER が (nicht は!). Gilt für: だれ, なに, どれ, どの+N, いつ (wenn Subjekt der Zeit).", conj:[
    {form:"だれが (wer?)",verb:"だれが <ruby>来<rt>き</rt></ruby>ましたか",de:"Wer ist gekommen?"},
    {form:"なにが (was?)",verb:"<ruby>何<rt>なに</rt></ruby>が <ruby>好<rt>す</rt></ruby>きですか",de:"Was magst du?"},
    {form:"どれが (welches?)",verb:"どれが いいですか",de:"Welches ist gut?"}
  ], ex:[
    {jp:"だれが <ruby>日本語<rt>にほんご</rt></ruby>を <ruby>教<rt>おし</rt></ruby>えましたか。",de:"Wer hat dich Japanisch gelehrt?"},
    {jp:"<ruby>何<rt>なに</rt></ruby>が いちばん おいしいですか。",de:"Was ist am leckersten?"},
    {jp:"どの <ruby>色<rt>いろ</rt></ruby>が いちばん <ruby>好<rt>す</rt></ruby>きですか。",de:"Welche Farbe magst du am liebsten?"}
  ], note:"★ Fragewort als Subjekt = IMMER が, nie は"},
  {l:25, t:"V たら、… (Konditional »たら«)", de:"Wenn/falls …, dann …", rule:"Sehr flexibel: hypothetisch, sequenziell, »nachdem«. た-Form + ら. Hauptsatz darf Wille/Bitte/Aufforderung enthalten (im Gegensatz zu と).", conj:[
    {form:"た-Form + ら",verb:"<ruby>食<rt>た</rt></ruby>べたら → <ruby>飲<rt>の</rt></ruby>んだら → <ruby>来<rt>き</rt></ruby>たら",de:"wenn man gegessen/getrunken/gekommen ist"},
    {form:"い-Adj: かったら",verb:"<ruby>安<rt>やす</rt></ruby>かったら",de:"wenn es günstig wäre"},
    {form:"な-Adj/N: だったら",verb:"<ruby>元気<rt>げんき</rt></ruby>だったら / <ruby>学生<rt>がくせい</rt></ruby>だったら",de:"wenn er gesund wäre / wenn er Student wäre"}
  ], ex:[
    {jp:"お<ruby>金<rt>かね</rt></ruby>が あったら、<ruby>旅行<rt>りょこう</rt></ruby>します。",de:"Wenn ich Geld hätte, würde ich reisen."},
    {jp:"<ruby>家<rt>いえ</rt></ruby>へ <ruby>帰<rt>かえ</rt></ruby>ったら、すぐ シャワーを <ruby>浴<rt>あ</rt></ruby>びます。",de:"Sobald ich nach Hause komme, dusche ich."},
    {jp:"わからなかったら、<ruby>聞<rt>き</rt></ruby>いて ください。",de:"Falls Sie es nicht verstehen, fragen Sie bitte."}
  ], note:"🔄 たら (hypothetisch) vs. とき (faktische Zeit). »Nach Hause kommen«: 帰ったら=wenn/falls / 帰ったとき=als ich zurückkam"},
  {l:25, t:"V て も、… (Konzessiv)", de:"Auch wenn …", rule:"Drückt aus, dass etwas trotz einer Bedingung gilt. て-Form + も. Bei Adjektiven/Nomen: くても / でも.", conj:[
    {form:"Verb",verb:"V<sub>テ</sub> + も、…",de:"auch wenn V"},
    {form:"い-Adj",verb:"〜<b>く</b>ても、…",de:"<ruby>高<rt>たか</rt></ruby><b>く</b>ても = auch wenn teuer"},
    {form:"な-Adj",verb:"〜<b>で</b>も、…",de:"<ruby>元気<rt>げんき</rt></ruby><b>で</b>も = auch wenn gesund"},
    {form:"Nomen",verb:"〜<b>で</b>も、…",de:"<ruby>日曜日<rt>にちようび</rt></ruby><b>で</b>も = auch sonntags"},
    {form:"Verneint Verb",verb:"V<sub>ナイ</sub>く + ても、…",de:"<ruby>行<rt>い</rt></ruby>かなくても = auch wenn nicht gehen"},
    {form:"Beispiel",verb:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>っても、<ruby>行<rt>い</rt></ruby>きます",de:"auch wenn es regnet, gehe ich"}
  ], ex:[
    {jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>っても、<ruby>行<rt>い</rt></ruby>きます。",de:"Auch wenn es regnet, gehe ich."},
    {jp:"<ruby>高<rt>たか</rt></ruby>くても、<ruby>買<rt>か</rt></ruby>います。 / <ruby>日曜日<rt>にちようび</rt></ruby>でも、<ruby>働<rt>はたら</rt></ruby>きます。",de:"Auch wenn teuer / Auch sonntags…"},
    {jp:"どんなに <ruby>疲<rt>つか</rt></ruby>れても、<ruby>続<rt>つづ</rt></ruby>けます。",de:"Auch wenn ich noch so müde bin, mache ich weiter."}
  ], note:"💡 Memory aid: ても = \"even if\". Achtung: Verneint NICHT 〜なくても (das wäre \"auch wenn nicht\"), sondern 〜<b>なくて</b>+も!"},
  {l:25, t:"もし / いくら …ても", de:"Falls / egal wie sehr …", rule:"もし = »falls« (oft mit たら, verstärkt hypothetischen Charakter). いくら〜ても = »egal wie sehr A, B«. Betonung, dass A keinen Einfluss auf B hat.", conj:[
    {form:"もし …たら",verb:"もし <ruby>時間<rt>じかん</rt></ruby>が あったら",de:"falls ich Zeit habe"},
    {form:"いくら …ても",verb:"いくら <ruby>高<rt>たか</rt></ruby>くても",de:"egal wie teuer"},
    {form:"いくら V ても",verb:"いくら <ruby>食<rt>た</rt></ruby>べても",de:"egal wie viel ich esse"}
  ], ex:[
    {jp:"もし <ruby>1億円<rt>いちおくえん</rt></ruby> あったら、<ruby>何<rt>なに</rt></ruby>を <ruby>買<rt>か</rt></ruby>いますか。",de:"Was würdest du kaufen, wenn du 100 Millionen Yen hättest?"},
    {jp:"もし <ruby>時間<rt>じかん</rt></ruby>が あったら、<ruby>来<rt>き</rt></ruby>て ください。",de:"Falls Sie Zeit haben, kommen Sie doch."},
    {jp:"いくら <ruby>高<rt>たか</rt></ruby>くても、<ruby>買<rt>か</rt></ruby>います。",de:"Egal wie teuer es ist, ich kaufe es."},
    {jp:"いくら <ruby>勉強<rt>べんきょう</rt></ruby>しても、<ruby>覚<rt>おぼ</rt></ruby>えられません。",de:"Egal wie viel ich lerne, ich kann es mir nicht merken."}
  ]},
  {l:25, t:"N が (unerwartetes/neues Subjekt)", de:"が hebt neues/unerwartetes Subjekt hervor", rule:"が (statt は) wird verwendet, um ein NEUES, unerwartetes oder kontrastiertes Subjekt einzuführen. Antwort auf »wer/was?«-Fragen. Auch in existenziellen Sätzen nach Positionsangaben.", conj:[
    {form:"は (bekanntes Thema)",verb:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>医者<rt>いしゃ</rt></ruby>です",de:"Er ist Arzt (Thema bekannt)"},
    {form:"が (neue Info/Antwort)",verb:"<ruby>彼<rt>かれ</rt></ruby>が <ruby>医者<rt>いしゃ</rt></ruby>です",de:"ER ist der Arzt (wer? er!)"},
    {form:"が bei Existenz",verb:"<ruby>猫<rt>ねこ</rt></ruby>が います",de:"Da ist eine Katze"}
  ], ex:[
    {jp:"だれが <ruby>来<rt>き</rt></ruby>ましたか。— ミラーさんが <ruby>来<rt>き</rt></ruby>ました。",de:"Wer ist gekommen? — Herr Miller ist gekommen."},
    {jp:"<ruby>何<rt>なに</rt></ruby>が いちばん <ruby>好<rt>す</rt></ruby>きですか。— すしが いちばん <ruby>好<rt>す</rt></ruby>きです。",de:"Was magst du am meisten? — Sushi am meisten."},
    {jp:"あ、<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>って きました!",de:"Oh, es fängt an zu regnen!"}
  ], note:"が = neue Information / Antwort auf Fragewort / Existenz. は = bekanntes Thema, Kontrast."},
  {l:25, t:"N が (unerwartetes/überraschendes Subjekt)", de:"が bei Überraschung/neuer Information", rule:"In L25-Kontext: が markiert ein Subjekt, das UNERWARTET ist oder als neue Information auftaucht — im Gegensatz zum erwarteten は. Häufig bei spontanen Beobachtungen, Entdeckungen.", conj:[
    {form:"Erwartung: は",verb:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>来<rt>き</rt></ruby>ました",de:"Er ist gekommen (wie erwartet)"},
    {form:"Überraschung: が",verb:"<ruby>彼<rt>かれ</rt></ruby>が <ruby>来<rt>き</rt></ruby>ました!",de:"ER ist gekommen! (unerwartet)"}
  ], ex:[
    {jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>って きました。",de:"Es fängt an zu regnen (Entdeckung)."},
    {jp:"あ、<ruby>田中<rt>たなか</rt></ruby>さんが <ruby>来<rt>き</rt></ruby>ました。",de:"Oh, Herr Tanaka ist (unerwartet) gekommen."},
    {jp:"<ruby>桜<rt>さくら</rt></ruby>が <ruby>咲<rt>さ</rt></ruby>きました。",de:"Die Kirschblüten blühen! (neue Beobachtung)"}
  ], note:"が = neue/unerwartete Info, spontane Beobachtung"},
  {l:26, t:"〜んです (Erklärung/Nachfrage)", de:"… nämlich / es ist so, dass …",
   rule:"Setzt eine Erklärung, einen Grund oder eine Nachfrage in Beziehung zur Situation. Sehr häufig in der Konversation, oft als Reaktion auf etwas Beobachtetes.",
   build:[{form:"Verb (Plain)",verb:"V<sub>普通形</sub> + んです",de:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>くんです"},{form:"い-Adjektiv",verb:"い-Adj + んです",de:"<ruby>痛<rt>いた</rt></ruby>い → <ruby>痛<rt>いた</rt></ruby>いんです"},{form:"な-Adjektiv",verb:"な-Adj + <b>な</b>んです",de:"<ruby>元気<rt>げんき</rt></ruby> → <ruby>元気<rt>げんき</rt></ruby><b>な</b>んです"},{form:"Nomen",verb:"N + <b>な</b>んです",de:"<ruby>学生<rt>がくせい</rt></ruby> → <ruby>学生<rt>がくせい</rt></ruby><b>な</b>んです"}],
   pattern:{slots:[{text:"Situation/Anlass",role:"plain",label:""},{text:"。",role:"plain"},{text:"Plain-Form",role:"verb",label:"Inhalt"},{text:"んです",role:"actor",label:"Erklärung"}],gloss:"»[Beobachtung]. Es ist nämlich so, dass [Inhalt].« — der んです-Teil liefert den Hintergrund / Grund."},
   ex:[{jp:"どうして <ruby>遅<rt>おそ</rt></ruby>く <ruby>来<rt>き</rt></ruby>ましたか。— <ruby>道<rt>みち</rt></ruby>が <ruby>込<rt>こ</rt></ruby>んでいた<b>んです</b>。",de:"Warum bist du spät gekommen? — Die Straße war nämlich verstopft."},{jp:"<ruby>頭<rt>あたま</rt></ruby>が <ruby>痛<rt>いた</rt></ruby>い<b>んです</b>。",de:"Ich habe nämlich Kopfschmerzen."},{jp:"きょうは <ruby>休<rt>やす</rt></ruby>みたいです。<ruby>疲<rt>つか</rt></ruby>れた<b>んです</b>。",de:"Heute will ich frei machen. Ich bin nämlich müde."}],
   note:"⚠️ Bei な-Adj und Nomen kommt <b>な</b> vor んです: 学生<b>な</b>んです (NICHT 学生だんです). 💡 Frage- und Antwortform: どうして〜んですか? → 〜から/ので."},
  {l:26, t:"どうして 〜んですか", de:"Warum denn …? (fragend-interessiert)",
   rule:"Frage nach dem Grund mit Interesse/Anteilnahme. Stärker als nur どうして〜ますか — der Sprecher erwartet eine Erklärung, weil er etwas Auffälliges bemerkt hat.",
   build:[{form:"V 辞書形 + んですか",verb:"どうして <ruby>行<rt>い</rt></ruby>くんですか",de:"Warum gehst du (denn)?"},{form:"V た + んですか",verb:"どうして <ruby>休<rt>やす</rt></ruby>んだんですか",de:"Warum hast du gefehlt?"},{form:"V ない + んですか",verb:"どうして <ruby>食<rt>た</rt></ruby>べないんですか",de:"Warum isst du nicht?"},{form:"な-Adj/N: + なんですか",verb:"どうして <ruby>病気<rt>びょうき</rt></ruby>なんですか",de:"Warum bist du krank?"}],
   pattern:{slots:[{text:"どうして",role:"cond",label:"Frage"},{text:"Plain-Form",role:"verb",label:"was?"},{text:"んですか",role:"actor",label:"interessiert"}],gloss:"»Wie kommt es, dass [Inhalt]?« — Antwort meist mit 〜から/ので/〜んです."},
   ex:[{jp:"どうして <ruby>日本語<rt>にほんご</rt></ruby>を <ruby>勉強<rt>べんきょう</rt></ruby>している<b>んですか</b>。",de:"Warum lernst du denn Japanisch?"},{jp:"どうして そんなに <ruby>急<rt>いそ</rt></ruby>いでいる<b>んですか</b>。— <ruby>電車<rt>でんしゃ</rt></ruby>に <ruby>遅<rt>おく</rt></ruby>れそうな<b>んです</b>。",de:"Warum hast du es so eilig? — Ich drohe nämlich den Zug zu verpassen."},{jp:"どうして <ruby>泣<rt>な</rt></ruby>いている<b>んですか</b>。",de:"Warum weinst du denn?"}],
   note:"💡 Vergleich: どうして〜ますか? = neutral-sachlich. どうして〜んですか? = anteilnehmend, persönlich."},
  {l:26, t:"V て いただけませんか", de:"Könnten Sie bitte …?",
   rule:"Sehr höfliche Bitte. Höflichkeitsstufe deutlich über ください. Wird im Berufsalltag, gegenüber Vorgesetzten und Fremden verwendet.",
   build:[{form:"Anschluss",verb:"V<sub>テ</sub> + いただけませんか",de:"höflich: könnten Sie bitte V?"},{form:"Höflichkeitsleiter",verb:"↑ je weiter unten, desto höflicher ↑",de:"—"},{form:"1. Direkt",verb:"V<sub>テ</sub>",de:"mach! (sehr direkt)"},{form:"2. Bitte",verb:"V<sub>テ</sub> + ください",de:"bitte tu (L14, normal)"},{form:"3. Sehr höflich",verb:"V<sub>テ</sub> + いただけませんか",de:"könnten Sie bitte? (formell)"}],
   pattern:{slots:[{text:"(Adressat)",role:"actor",label:"an wen"},{text:"Bitte-Inhalt",role:"obj",label:"was"},{text:"V-て",role:"verb",label:"Verb"},{text:"いただけませんか",role:"plain"}],gloss:"»Könnten Sie für mich [Verb-Aktion] tun?« — Verbinhalt + て-Form, dann höflicher Bitt-Suffix."},
   ex:[{jp:"もう <ruby>少<rt>すこ</rt></ruby>し <ruby>待<rt>ま</rt></ruby>って いただけませんか。",de:"Könnten Sie bitte noch etwas warten?"},{jp:"ここに <ruby>名前<rt>なまえ</rt></ruby>を <ruby>書<rt>か</rt></ruby>いて いただけませんか。",de:"Könnten Sie hier bitte Ihren Namen schreiben?"},{jp:"もう <ruby>一度<rt>いちど</rt></ruby> <ruby>説明<rt>せつめい</rt></ruby>して いただけませんか。",de:"Könnten Sie es bitte noch einmal erklären?"}],
   note:"💡 Höher als てください, weil als verneinte Frage formuliert (»wäre es nicht möglich, dass …?«). Noch höflicher: 〜ていただきたいんですが."},
  {l:26, t:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + V たら いいですか", de:"Wie/was soll ich (am besten) …?",
   rule:"Höfliche Bitte um Rat oder Anweisung. Fragewort + Verb in たら-Form + いいですか. Sehr häufig in Alltagssituationen: Wegbeschreibungen, Beratung beim Einkauf, Rat bei Krankheit.",
   build:[{form:"どう + V たら",verb:"どうしたら いいですか",de:"Was soll ich tun?"},{form:"どこへ + V たら",verb:"どこへ <ruby>行<rt>い</rt></ruby>ったら いいですか",de:"Wohin soll ich gehen?"},{form:"何を + V たら",verb:"<ruby>何<rt>なに</rt></ruby>を <ruby>買<rt>か</rt></ruby>ったら いいですか",de:"Was soll ich kaufen?"},{form:"いつ + V たら",verb:"いつ <ruby>来<rt>き</rt></ruby>たら いいですか",de:"Wann soll ich kommen?"}],
   pattern:{slots:[{text:"Fragewort",role:"cond",label:"どう/何/どこ…"},{text:"V-たら",role:"verb",label:"Verb"},{text:"いいですか",role:"plain"}],gloss:"»Wenn ich [Verb] täte, wäre es gut?« — wörtlich, im Sinn von »Was wäre die richtige Handlung?«."},
   ex:[{jp:"<ruby>熱<rt>ねつ</rt></ruby>が あるんです。<b>どうしたら いいですか</b>。— <ruby>病院<rt>びょういん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>った <ruby>方<rt>ほう</rt></ruby>が いいですよ。",de:"Ich habe Fieber. Was soll ich tun? — Du solltest zum Arzt gehen."},{jp:"<b>どこで</b> この <ruby>本<rt>ほん</rt></ruby>を <b><ruby>買<rt>か</rt></ruby>ったら いいですか</b>。",de:"Wo soll ich dieses Buch am besten kaufen?"},{jp:"<b><ruby>何時<rt>なんじ</rt></ruby>に</b> <b><ruby>来<rt>き</rt></ruby>たら いいですか</b>。— <ruby>2時<rt>にじ</rt></ruby>に <ruby>来<rt>き</rt></ruby>てください。",de:"Um wie viel Uhr soll ich kommen? — Bitte um 2."}],
   note:"Vergleich L35: 疑問詞 + V(ば) + いいですか — fast identisch, ば-Form klingt etwas formeller/schriftlicher."},
  {l:27, t:"<ruby>可能形<rt>かのうけい</rt></ruby> (Potential-Form) — Bildung", de:"… können",
   rule:"Drückt Fähigkeit oder Möglichkeit aus. Alternative zu V辞書形 + ことができます (L18), aber kürzer und natürlicher in der Konversation.",
   build:[{form:"★ Gruppe I (u-Verben): u → e + る",verb:"—",de:"—"},{form:"<ruby>書<rt>か</rt></ruby>く",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>ける",de:"schreiben können"},{form:"<ruby>飲<rt>の</rt></ruby>む",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>める",de:"trinken können"},{form:"<ruby>話<rt>はな</rt></ruby>す",verb:"<ruby>話<rt>はな</rt></ruby>す → <ruby>話<rt>はな</rt></ruby>せる",de:"sprechen können"},{form:"<ruby>買<rt>か</rt></ruby>う",verb:"<ruby>買<rt>か</rt></ruby>う → <ruby>買<rt>か</rt></ruby>える",de:"kaufen können"},{form:"<ruby>行<rt>い</rt></ruby>く",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>ける",de:"gehen können"},{form:"★ Gruppe II (ru-Verben): る → られる",verb:"—",de:"—"},{form:"<ruby>食<rt>た</rt></ruby>べる",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べられる",de:"essen können"},{form:"<ruby>見<rt>み</rt></ruby>る",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>られる",de:"sehen können"},{form:"★ Unregelmäßig",verb:"する → できる / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>られる",de:"tun können / kommen können"}],
   pattern:{slots:[{text:"Subjekt",role:"subj",label:"wer"},{text:"は",role:"plain"},{text:"Objekt",role:"obj",label:"was"},{text:"が",role:"plain",label:"⚠️ nicht を!"},{text:"V-Potential",role:"verb",label:"kann V"}],gloss:"⚠️ Bei der Potential-Form wird das Objekt mit が markiert (nicht を!) — »漢字が読める«, nicht »漢字を読める«."},
   ex:[{jp:"<ruby>私<rt>わたし</rt></ruby>は <ruby>漢字<rt>かんじ</rt></ruby><b>が</b> <ruby>読<rt>よ</rt></ruby>めます。",de:"Ich kann Kanji lesen."},{jp:"<ruby>刺身<rt>さしみ</rt></ruby><b>が</b> <ruby>食<rt>た</rt></ruby>べられますか。",de:"Können Sie Sashimi essen?"},{jp:"<ruby>明日<rt>あした</rt></ruby> <ruby>来<rt>こ</rt></ruby>られません。",de:"Ich kann morgen nicht kommen."},{jp:"<ruby>速<rt>はや</rt></ruby>く <ruby>走<rt>はし</rt></ruby>れます。",de:"Ich kann schnell laufen."}],
   note:"⚠️ Gr. II-Form (食べられる) ist IDENTISCH mit Passiv (L37) und respektvollem Keigo (L49) — der Kontext entscheidet. 💡 In moderner Umgangssprache hört man oft das »ら« weg: 食べれる, 見れる (»ら抜き言葉«), gilt aber als unsauber."},
  {l:27, t:"<ruby>見<rt>み</rt></ruby>えます / <ruby>聞<rt>き</rt></ruby>こえます", de:"sehen können (spontan) / hören können (spontan)",
   rule:"Spontane Wahrnehmung — etwas IST sichtbar/hörbar, ohne dass man aktiv etwas dafür tut. Im Gegensatz zu 見られる/聞ける (Potential), wo man aktiv schauen/hören KANN.",
   build:[{form:"sichtbar sein",verb:"N が <ruby>見<rt>み</rt></ruby>えます",de:"N ist sichtbar (spontan)"},{form:"hörbar sein",verb:"N が <ruby>聞<rt>き</rt></ruby>こえます",de:"N ist hörbar (spontan)"},{form:"⚠ vs. Potential",verb:"N が <ruby>見<rt>み</rt></ruby>られます",de:"man KANN N (aktiv) sehen"},{form:"⚠ vs. Potential",verb:"N が <ruby>聞<rt>き</rt></ruby>けます",de:"man KANN N (aktiv) hören"}],
   pattern:{slots:[{text:"(Ort)から",role:"place",label:"woher"},{text:"N",role:"subj",label:"was"},{text:"が",role:"plain"},{text:"見えます/聞こえます",role:"verb",label:"erscheint/klingt"}],gloss:"»Von [Ort] aus ist [N] sichtbar/hörbar.« — Beobachtung passiert von selbst, ohne Anstrengung."},
   ex:[{jp:"ここから <ruby>海<rt>うみ</rt></ruby><b>が</b> <ruby>見<rt>み</rt></ruby>えます。",de:"Von hier sieht man das Meer."},{jp:"<ruby>富士山<rt>ふじさん</rt></ruby><b>が</b> <ruby>見<rt>み</rt></ruby>えません。",de:"Den Fuji sieht man nicht."},{jp:"<ruby>隣<rt>となり</rt></ruby>の <ruby>部屋<rt>へや</rt></ruby>から <ruby>音楽<rt>おんがく</rt></ruby><b>が</b> <ruby>聞<rt>き</rt></ruby>こえます。",de:"Aus dem Nebenzimmer hört man Musik."}],
   note:"💡 Kontrast-Beispiel: 海が見える = das Meer ist (von hier) sichtbar (spontane Wahrnehmung). 映画が見られる = man kann den Film schauen (aktiv möglich, z.B. weil das Kino offen ist)."},
  {l:27, t:"〜しか …ない", de:"nur (mit Verneinung)",
   rule:"Einschränkung mit negativem Beiklang: »nur (und das ist zu wenig)«. Das Verb MUSS verneint sein. Im Gegensatz zu だけ (neutral) drückt しか…ない aus, dass die Menge/Auswahl begrenzt und unbefriedigend ist.",
   build:[{form:"だけ (neutral)",verb:"<ruby>100円<rt>ひゃくえん</rt></ruby>だけ あります",de:"Ich habe (nur) 100 Yen [neutral]"},{form:"しか〜ない (zu wenig)",verb:"<ruby>100円<rt>ひゃくえん</rt></ruby>しか ありません",de:"Ich habe nur 100 Yen [betont: zu wenig!]"},{form:"Anschluss",verb:"N + しか + V<b>negativ</b>",de:"Verb MUSS verneint sein"}],
   pattern:{slots:[{text:"N",role:"obj",label:"was"},{text:"しか",role:"actor",label:"nur"},{text:"V-ない/ません",role:"verb",label:"verneint!"}],gloss:"»Außer [N] gibt/kann/hat es nichts.« — die Negation ist zwingend, sonst grammatikalisch falsch."},
   ex:[{jp:"<ruby>1000円<rt>せんえん</rt></ruby>しか ありません。",de:"Ich habe nur 1000 Yen (zu wenig)."},{jp:"ひらがなしか <ruby>読<rt>よ</rt></ruby>めません。",de:"Ich kann nur Hiragana lesen."},{jp:"<ruby>日本語<rt>にほんご</rt></ruby>しか <ruby>話<rt>はな</rt></ruby>せません。",de:"Ich kann nur Japanisch sprechen."}],
   note:"⚠️ しか ersetzt は/が/を, wird aber an に/で/から angehängt: <ruby>東京<rt>とうきょう</rt></ruby>にしか ありません = gibt es nur in Tokio."},
  {l:27, t:"Kombinierte Partikeln mit は", de:"は wird an andere Partikeln angehängt",
   rule:"Bei に/で/と/から/まで wird は ANGEHÄNGT (にはで・では・とは…). Hebt die Partikel-Funktion hervor oder erzeugt Kontrast. Wichtige Ausnahme: を und が werden durch は ERSETZT, nicht kombiniert.",
   build:[{form:"に + は = には",verb:"<ruby>東京<rt>とうきょう</rt></ruby>には",de:"in/nach Tokyo (im Gegensatz zu …)"},{form:"で + は = では",verb:"<ruby>学校<rt>がっこう</rt></ruby>では",de:"in der Schule (im Gegensatz zu …)"},{form:"と + は = とは",verb:"<ruby>彼<rt>かれ</rt></ruby>とは",de:"mit ihm (speziell)"},{form:"から + は = からは",verb:"<ruby>今<rt>いま</rt></ruby>からは",de:"ab jetzt (im Gegensatz zu davor)"},{form:"⚠️ を → は (ersetzt!)",verb:"<ruby>肉<rt>にく</rt></ruby>は <ruby>食<rt>た</rt></ruby>べません",de:"Fleisch (speziell) esse ich nicht"},{form:"⚠️ が → は (ersetzt!)",verb:"これは <ruby>分<rt>わ</rt></ruby>かりません",de:"Das (im Kontrast) verstehe ich nicht"}],
   pattern:{slots:[{text:"N",role:"subj",label:"Element"},{text:"P",role:"actor",label:"Partikel"},{text:"+ は",role:"verb",label:"Kontrast"},{text:"…Rest",role:"plain"}],gloss:"Mit に/で/と/から/まで: kombinieren (にはで…). Mit を/が: ersetzen. Effekt: »speziell DIESES, im Gegensatz zu anderen«."},
   ex:[{jp:"この <ruby>部屋<rt>へや</rt></ruby><b>では</b> タバコを <ruby>吸<rt>す</rt></ruby>っては いけません。",de:"In diesem Zimmer (im Gegensatz zu anderen) darf man nicht rauchen."},{jp:"<ruby>東京<rt>とうきょう</rt></ruby><b>には</b> <ruby>人<rt>ひと</rt></ruby>が たくさん います。",de:"In Tokyo gibt es viele Menschen."},{jp:"<ruby>日本<rt>にほん</rt></ruby><b>からは</b> <ruby>手紙<rt>てがみ</rt></ruby>が <ruby>来<rt>き</rt></ruby>ませんでした。",de:"Aus Japan kam kein Brief."}],
   note:"💡 Faustregel: は macht die Partikel kontrastiv/betont (»speziell DIESES«). Bei を/が verschwinden diese und nur は steht da."},
  {l:27, t:"N は (kontrastives は bei Potential)", de:"N kann schon, aber … (Kontrast)",
   rule:"Bei der Potential-Form wechselt が oft zu は, wenn man einen Kontrast ausdrücken will: »DAS kann ich, JENES nicht.« Implizit wird mit etwas anderem verglichen.",
   build:[{form:"Neutral: が",verb:"<ruby>漢字<rt>かんじ</rt></ruby>が <ruby>読<rt>よ</rt></ruby>めます",de:"Ich kann Kanji lesen [Tatsache]"},{form:"Kontrast: は",verb:"ひらがなは <ruby>読<rt>よ</rt></ruby>めます",de:"Hiragana kann ich lesen [aber …]"}],
   pattern:{slots:[{text:"N",role:"obj",label:"Aspekt 1"},{text:"は",role:"actor",label:"Kontrast"},{text:"V-Potential",role:"verb"},{text:"が、",role:"plain"},{text:"N₂ は",role:"obj",label:"Aspekt 2"},{text:"V-Potential ません",role:"verb"}],gloss:"»[N] kann ich, aber [N₂] nicht.« — Vergleich zwischen zwei Aspekten desselben Sprechers."},
   ex:[{jp:"ひらがな<b>は</b> <ruby>読<rt>よ</rt></ruby>めますが、<ruby>漢字<rt>かんじ</rt></ruby><b>は</b> <ruby>読<rt>よ</rt></ruby>めません。",de:"Hiragana kann ich lesen, aber Kanji nicht."},{jp:"<ruby>肉<rt>にく</rt></ruby><b>は</b> <ruby>食<rt>た</rt></ruby>べられますが、<ruby>魚<rt>さかな</rt></ruby><b>は</b> <ruby>食<rt>た</rt></ruby>べられません。",de:"Fleisch kann ich essen, aber Fisch nicht."},{jp:"<ruby>日本語<rt>にほんご</rt></ruby><b>は</b> <ruby>話<rt>はな</rt></ruby>せますが、<ruby>書<rt>か</rt></ruby>けません。",de:"Japanisch sprechen kann ich, schreiben nicht."}],
   note:"💡 Auch außerhalb von Potential nutzbar, immer wenn man zwei Dinge gegenüberstellt."},
  {l:28, t:"V ます-Stamm + ながら、…", de:"während gleichzeitig …",
   rule:"Zwei gleichzeitige Handlungen DERSELBEN Person. Das Hauptverb (= die wichtigere Handlung) steht am Satzende, die Begleithandlung mit ながら davor.",
   build:[{form:"Bildung",verb:"V<sub>マス</sub>-Stamm + ながら",de:"<ruby>食<rt>た</rt></ruby>べます → <ruby>食<rt>た</rt></ruby>べながら"},{form:"Beispiel",verb:"<ruby>聞<rt>き</rt></ruby>きます → <ruby>聞<rt>き</rt></ruby>きながら",de:"während (Musik) hören"},{form:"⚠️ Selbe Person",verb:"beide Verben = derselbe Akteur",de:"sonst nicht möglich"},{form:"⚠️ Tempus",verb:"nur am Hauptverb!",de:"<ruby>聞<rt>き</rt></ruby>きながら、<ruby>勉強<rt>べんきょう</rt></ruby>しました"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj",label:"wer"},{text:"Begleit-Obj",role:"obj"},{text:"V₁ます-Stamm",role:"verb",label:"V1"},{text:"ながら、",role:"actor",label:"während"},{text:"Haupt-Obj",role:"obj"},{text:"V₂",role:"verb",label:"V2 (Haupt)"}],gloss:"»Während [V₁ macht], [V₂].« — V₂ ist das Wichtigste, V₁ läuft nebenbei. Tempus nur am V₂."},
   ex:[{jp:"<ruby>音楽<rt>おんがく</rt></ruby>を <ruby>聞<rt>き</rt></ruby>き<b>ながら</b>、<ruby>勉強<rt>べんきょう</rt></ruby>します。",de:"Ich lerne, während ich Musik höre."},{jp:"テレビを <ruby>見<rt>み</rt></ruby><b>ながら</b>、ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べます。",de:"Ich esse, während ich fernsehe."},{jp:"<ruby>働<rt>はたら</rt></ruby>き<b>ながら</b>、<ruby>大学<rt>だいがく</rt></ruby>に <ruby>通<rt>かよ</rt></ruby>って います。",de:"Ich besuche die Uni, während ich arbeite."}],
   note:"⚠️ Bei zwei verschiedenen Personen → andere Konstruktion (z.B. て-Form oder と) nutzen. ながら geht nur bei einer Person."},
  {l:28, t:"V て います (Gewohnheit / Wiederholung)", de:"regelmäßig … tun",
   rule:"Erweiterte Bedeutung von ています (über die laufende Handlung aus L14 hinaus): wiederholte Handlungen über einen längeren Zeitraum — Gewohnheiten, Hobbys, regelmäßige Aktivitäten, andauernde Aktivitäten wie das Japanisch-Lernen.",
   build:[{form:"L14: läuft jetzt",verb:"<ruby>今<rt>いま</rt></ruby> ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べて います",de:"esse gerade"},{form:"L28: Gewohnheit",verb:"<ruby>毎朝<rt>まいあさ</rt></ruby> ジョギングして います",de:"jogge jeden Morgen (regelmäßig)"},{form:"L28: Beruf/Lage",verb:"<ruby>銀行<rt>ぎんこう</rt></ruby>で <ruby>働<rt>はたら</rt></ruby>いて います",de:"arbeite in einer Bank (Beruf)"},{form:"L28: andauernd",verb:"<ruby>日本語<rt>にほんご</rt></ruby>を <ruby>勉強<rt>べんきょう</rt></ruby>して います",de:"lerne (zur Zeit) Japanisch"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj",label:"wer"},{text:"Häufigkeit",role:"time",label:"wann/wie oft"},{text:"Objekt を",role:"obj"},{text:"V-て います",role:"verb",label:"Gewohnheit"}],gloss:"»[Subjekt] macht regelmäßig/dauerhaft [Verb].« — der Kontext (z.B. 毎日/いつも) entscheidet, ob es Gewohnheit oder gerade laufend ist."},
   ex:[{jp:"<ruby>毎朝<rt>まいあさ</rt></ruby> ジョギングを <ruby>して<rt></rt></ruby> います。",de:"Ich jogge jeden Morgen."},{jp:"ミラーさんは <ruby>銀行<rt>ぎんこう</rt></ruby>で <ruby>働<rt>はたら</rt></ruby>いて います。",de:"Herr Miller arbeitet in einer Bank."},{jp:"<ruby>毎晩<rt>まいばん</rt></ruby> <ruby>日本語<rt>にほんご</rt></ruby>を <ruby>勉強<rt>べんきょう</rt></ruby>して います。",de:"Ich lerne jeden Abend Japanisch."}],
   note:"💡 Marker für Gewohnheit: 毎日/毎朝/いつも/よく + ています. Marker für »läuft gerade«: 今 + ています."},
  {l:28, t:"〜し、〜し、… (mehrere Gründe)", de:"… und … (Aufzählung von Gründen)",
   rule:"Zählt mehrere Gründe oder Eigenschaften auf, die als zusammenhängend zur Konsequenz führen. Stärker als reine て-Verkettung — zeigt, dass jeder einzelne Punkt schon ein Argument wäre.",
   build:[{form:"Plain-Form + し",verb:"V/Adj/N + し",de:"…und (Grund)"},{form:"Verb",verb:"<ruby>安<rt>やす</rt></ruby>いし、おいしい",de:"billig und (auch noch) lecker"},{form:"な-Adj/N",verb:"きれいだし、<ruby>静<rt>しず</rt></ruby>かだ",de:"schön und (auch noch) ruhig"},{form:"Negation",verb:"<ruby>高<rt>たか</rt></ruby>くないし、まずくない",de:"nicht teuer und nicht schlecht"}],
   pattern:{slots:[{text:"Grund 1",role:"cond",label:"Argument 1"},{text:"し、",role:"actor"},{text:"Grund 2",role:"cond",label:"Argument 2"},{text:"し、",role:"actor"},{text:"Folge",role:"verb",label:"deshalb"}],gloss:"»[Grund 1] — und [Grund 2] — und deshalb [Folge].« — jeder し-Punkt ist ein eigenständiges Argument."},
   ex:[{jp:"この <ruby>店<rt>みせ</rt></ruby>は <ruby>安<rt>やす</rt></ruby>い<b>し</b>、おいしい<b>し</b>、よく <ruby>来<rt>き</rt></ruby>ます。",de:"Dieses Lokal ist billig und lecker — deshalb komme ich oft."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>頭<rt>あたま</rt></ruby>が いい<b>し</b>、ハンサムだ<b>し</b>、<ruby>人気<rt>にんき</rt></ruby>が ある。",de:"Er ist klug und gutaussehend — deshalb ist er beliebt."},{jp:"きょうは <ruby>雨<rt>あめ</rt></ruby>だ<b>し</b>、<ruby>寒<rt>さむ</rt></ruby>い<b>し</b>、<ruby>家<rt>いえ</rt></ruby>に いましょう。",de:"Heute regnet es und ist kalt — bleiben wir zu Hause."}],
   note:"💡 Hinter dem letzten し steht oft die Konsequenz — sie kann aber auch weggelassen werden, wenn sie aus dem Kontext klar ist."},
  {l:28, t:"それで (deshalb / daher)", de:"deshalb / daher / deswegen",
   rule:"Konjunktion am Satzanfang: »das ist der Grund, warum …«. Verbindet einen vorher genannten Grund mit einer Folge. Neutraler als だから.",
   build:[{form:"Anschluss",verb:"[Grund] 。それで、[Folge]",de:"deswegen [Folge]"},{form:"vs. だから",verb:"だから = persönlicher/emotionaler",de:"それで = neutral, sachlich"},{form:"vs. ですから",verb:"ですから = höflich-formell",de:"それで = neutral-höflich"}],
   pattern:{slots:[[{text:"[Grund]",role:"cond",label:"Vorher"},{text:"。",role:"plain"}],[{text:"それで、",role:"actor",label:"deshalb"},{text:"[Folge]",role:"verb",label:"Konsequenz"}]],gloss:"Erst der Grund (eigenständiger Satz), dann それで am Anfang des nächsten Satzes mit der Folge."},
   ex:[{jp:"きのうは <ruby>頭<rt>あたま</rt></ruby>が <ruby>痛<rt>いた</rt></ruby>かったです。<b>それで</b>、<ruby>会社<rt>かいしゃ</rt></ruby>を <ruby>休<rt>やす</rt></ruby>みました。",de:"Gestern hatte ich Kopfschmerzen. Deshalb bin ich nicht zur Arbeit gegangen."},{jp:"<ruby>道<rt>みち</rt></ruby>が <ruby>込<rt>こ</rt></ruby>んで いました。<b>それで</b>、<ruby>遅<rt>おく</rt></ruby>れました。",de:"Die Straße war verstopft. Deshalb komme ich zu spät."}],
   note:"💡 Reihenfolge: それで kommt IMMER an den Anfang des Folge-Satzes, niemals mittendrin."},
  {l:29, t:"V て います (Zustand nach Handlung)", de:"Zustand nach Veränderung",
   rule:"Bei intransitiven Verben drückt ています einen Zustand aus, der NACH einer Handlung entstanden ist und noch andauert: das Fenster IST geöffnet, der Stuhl IST kaputt.",
   build:[{form:"<ruby>開<rt>あ</rt></ruby>く (öffnen)",verb:"<ruby>開<rt>あ</rt></ruby>いて います",de:"ist geöffnet (Zustand)"},{form:"<ruby>閉<rt>し</rt></ruby>まる (schließen)",verb:"<ruby>閉<rt>し</rt></ruby>まって います",de:"ist geschlossen"},{form:"<ruby>壊<rt>こわ</rt></ruby>れる (kaputt gehen)",verb:"<ruby>壊<rt>こわ</rt></ruby>れて います",de:"ist kaputt"},{form:"<ruby>消<rt>き</rt></ruby>える (ausgehen)",verb:"<ruby>消<rt>き</rt></ruby>えて います",de:"ist aus"},{form:"⚠ Vergleich",verb:"<ruby>食<rt>た</rt></ruby>べて います",de:"esse gerade (= L14)"}],
   pattern:{slots:[{text:"N (Ding)",role:"subj",label:"was"},{text:"が/は",role:"plain"},{text:"V<sub>自</sub>-て います",role:"verb",label:"Zustand"}],gloss:"»[N] befindet sich im Zustand nach [V].« — das Verb ist intransitiv (passiert von selbst), ています beschreibt das Ergebnis."},
   ex:[{jp:"<ruby>窓<rt>まど</rt></ruby>が <ruby>開<rt>あ</rt></ruby>いて います。",de:"Das Fenster ist geöffnet (jemand hat es geöffnet, jetzt steht es offen)."},{jp:"この いすは <ruby>壊<rt>こわ</rt></ruby>れて います。",de:"Dieser Stuhl ist kaputt."},{jp:"<ruby>電気<rt>でんき</rt></ruby>が <ruby>消<rt>き</rt></ruby>えて います。",de:"Das Licht ist aus."}],
   note:"💡 Vergleich mit L30 (てあります): てあります = bewusst von jemandem so vorbereitet (transitiv). ています hier = einfach der Zustand, ohne Akteur-Fokus."},
  {l:29, t:"<ruby>自動詞<rt>じどうし</rt></ruby> ⇆ <ruby>他動詞<rt>たどうし</rt></ruby>: Verbpaare", de:"intransitiv ⇆ transitiv (Paare lernen)",
   rule:"Im Japanischen kommen viele Verben in Paaren: 自動詞 (intransitiv, »passiert von selbst«, mit が) und 他動詞 (transitiv, »jemand tut es aktiv«, mit を). Lerne sie immer als Paar.",
   build:[{form:"<ruby>開<rt>あ</rt></ruby>く ⇆ <ruby>開<rt>あ</rt></ruby>ける",verb:"が <ruby>開<rt>あ</rt></ruby>く / を <ruby>開<rt>あ</rt></ruby>ける",de:"sich öffnen / öffnen"},{form:"<ruby>閉<rt>し</rt></ruby>まる ⇆ <ruby>閉<rt>し</rt></ruby>める",verb:"が <ruby>閉<rt>し</rt></ruby>まる / を <ruby>閉<rt>し</rt></ruby>める",de:"sich schließen / schließen"},{form:"<ruby>付<rt>つ</rt></ruby>く ⇆ <ruby>付<rt>つ</rt></ruby>ける",verb:"が <ruby>付<rt>つ</rt></ruby>く / を <ruby>付<rt>つ</rt></ruby>ける",de:"angehen / anschalten"},{form:"<ruby>消<rt>き</rt></ruby>える ⇆ <ruby>消<rt>け</rt></ruby>す",verb:"が <ruby>消<rt>き</rt></ruby>える / を <ruby>消<rt>け</rt></ruby>す",de:"ausgehen / ausschalten"},{form:"<ruby>入<rt>はい</rt></ruby>る ⇆ <ruby>入<rt>い</rt></ruby>れる",verb:"が <ruby>入<rt>はい</rt></ruby>る / を <ruby>入<rt>い</rt></ruby>れる",de:"hineingehen / hineintun"},{form:"<ruby>出<rt>で</rt></ruby>る ⇆ <ruby>出<rt>だ</rt></ruby>す",verb:"が <ruby>出<rt>で</rt></ruby>る / を <ruby>出<rt>だ</rt></ruby>す",de:"herausgehen / herausnehmen"},{form:"<ruby>始<rt>はじ</rt></ruby>まる ⇆ <ruby>始<rt>はじ</rt></ruby>める",verb:"が <ruby>始<rt>はじ</rt></ruby>まる / を <ruby>始<rt>はじ</rt></ruby>める",de:"anfangen (von selbst) / anfangen (etw.)"},{form:"<ruby>終<rt>お</rt></ruby>わる ⇆ <ruby>終<rt>お</rt></ruby>える",verb:"が <ruby>終<rt>お</rt></ruby>わる / を <ruby>終<rt>お</rt></ruby>える",de:"enden / beenden"},{form:"<ruby>壊<rt>こわ</rt></ruby>れる ⇆ <ruby>壊<rt>こわ</rt></ruby>す",verb:"が <ruby>壊<rt>こわ</rt></ruby>れる / を <ruby>壊<rt>こわ</rt></ruby>す",de:"kaputtgehen / kaputtmachen"}],
   pattern:{slots:[[{text:"N",role:"subj"},{text:"が",role:"plain"},{text:"V<sub>自</sub>",role:"verb",label:"intransitiv"},{text:"  passiert von selbst",role:"plain"}],[{text:"Person は",role:"actor",label:"Täter"},{text:"N",role:"obj"},{text:"を",role:"plain"},{text:"V<sub>他</sub>",role:"verb",label:"transitiv"},{text:"  jemand tut aktiv",role:"plain"}]],gloss:"Intransitiv: Subjekt + が + V自 (Tür öffnet sich). Transitiv: Akteur + は + Objekt + を + V他 (jemand öffnet die Tür)."},
   ex:[{jp:"ドアが <ruby>開<rt>あ</rt></ruby>きます。 / ドアを <ruby>開<rt>あ</rt></ruby>けます。",de:"Die Tür öffnet sich. / Ich öffne die Tür."},{jp:"<ruby>授業<rt>じゅぎょう</rt></ruby>が <ruby>始<rt>はじ</rt></ruby>まりました。 / <ruby>授業<rt>じゅぎょう</rt></ruby>を <ruby>始<rt>はじ</rt></ruby>めました。",de:"Der Unterricht hat begonnen. / Ich habe den Unterricht begonnen."},{jp:"<ruby>電気<rt>でんき</rt></ruby>が <ruby>消<rt>き</rt></ruby>えました。 / <ruby>電気<rt>でんき</rt></ruby>を <ruby>消<rt>け</rt></ruby>しました。",de:"Das Licht ging aus. / Ich machte das Licht aus."}],
   note:"💡 Faustregel zur Erkennung: Endung -aru/-eru oft intransitiv, -eru/-asu/-su oft transitiv. Aber nicht 100% — am besten paarweise lernen."},
  {l:29, t:"V て しまいました", de:"komplett getan / leider getan",
   rule:"Zwei Bedeutungen: ① Vollendung (»komplett zu Ende gemacht«), ② Bedauern (»leider/ungewollt passiert«). Der Kontext entscheidet, welche der beiden gemeint ist.",
   build:[{form:"Anschluss",verb:"V<sub>テ</sub> + しまいました",de:"komplett/leider getan"},{form:"① Vollendung",verb:"<ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んで しまいました",de:"habe das Buch (ganz) ausgelesen"},{form:"② Bedauern",verb:"かばんを <ruby>忘<rt>わす</rt></ruby>れて しまいました",de:"habe leider die Tasche vergessen"},{form:"Umgangssprache",verb:"〜ちゃった (て→ちゃった)",de:"<ruby>食<rt>た</rt></ruby>べちゃった = aufgegessen/leider gegessen"},{form:"Umgangssprache",verb:"〜じゃった (で→じゃった)",de:"<ruby>飲<rt>の</rt></ruby>んじゃった = ausgetrunken"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Objekt を",role:"obj"},{text:"V-て",role:"verb"},{text:"しまいました",role:"actor",label:"ganz / leider"}],gloss:"»Habe [V] (komplett/leider) getan.« — Kontext entscheidet: positive Vollendung oder negatives Bedauern."},
   ex:[{jp:"<ruby>本<rt>ほん</rt></ruby>を ぜんぶ <ruby>読<rt>よ</rt></ruby>んで しまいました。",de:"Ich habe das Buch komplett ausgelesen. [Vollendung]"},{jp:"パスポートを なくして しまいました。",de:"Ich habe (leider) den Pass verloren. [Bedauern]"},{jp:"<ruby>弟<rt>おとうと</rt></ruby>の ケーキを <ruby>食<rt>た</rt></ruby>べて しまいました。",de:"Ich habe den Kuchen meines Bruders aufgegessen. [Bedauern]"}],
   note:"💡 Wenn eine Konsequenz ungewollt war oder etwas Bedauerliches passiert ist: meist ② Bedauern. Wenn der Sprecher stolz auf den Abschluss ist: ① Vollendung."},
  {l:30, t:"V て あります (Vorbereitungs-Zustand)", de:"ist (absichtlich) vorbereitet worden",
   rule:"Zustand als RESULTAT einer absichtlichen, vorbereitenden Handlung. Nur mit transitiven Verben. Zeigt: jemand hat das bewusst so eingerichtet. Objekt mit が (nicht を!).",
   build:[{form:"Anschluss",verb:"N が V<sub>他テ</sub> + あります",de:"N ist (absichtlich) V-t worden"},{form:"vs. ています (L29)",verb:"<ruby>窓<rt>まど</rt></ruby>が <ruby>開<rt>あ</rt></ruby>いて います",de:"Fenster IST offen (Zustand neutral)"},{form:"vs. てあります",verb:"<ruby>窓<rt>まど</rt></ruby>が <ruby>開<rt>あ</rt></ruby>けて あります",de:"Fenster wurde geöffnet (jmd. hat absichtlich)"}],
   pattern:{slots:[{text:"N",role:"obj",label:"vorbereitetes Ding"},{text:"が",role:"plain",label:"⚠️ nicht を"},{text:"V<sub>他</sub>-て",role:"verb",label:"transitiv"},{text:"あります",role:"actor",label:"vorbereitet"}],gloss:"»[N] ist (für einen Zweck) [V]-vorbereitet worden.« — jemand hat das bewusst so gemacht; Objekt wechselt von を zu が."},
   ex:[{jp:"テーブルの <ruby>上<rt>うえ</rt></ruby>に <ruby>花<rt>はな</rt></ruby>が <ruby>飾<rt>かざ</rt></ruby>って あります。",de:"Auf dem Tisch sind Blumen aufgestellt (jemand hat sie hingestellt)."},{jp:"<ruby>窓<rt>まど</rt></ruby>が <ruby>開<rt>あ</rt></ruby>けて あります。",de:"Das Fenster ist (absichtlich) geöffnet worden."},{jp:"<ruby>冷蔵庫<rt>れいぞうこ</rt></ruby>に ビールが <ruby>入<rt>い</rt></ruby>れて あります。",de:"Im Kühlschrank ist Bier (vorbereitend) hineingelegt."}],
   note:"💡 Schlüsselwort »vorbereitend«: jemand hat es absichtlich gemacht, damit es jetzt so ist. Bei intransitiven Verben (開く) → 開いて います (L29)."},
  {l:30, t:"V て おきます (im Voraus tun)", de:"im Voraus / vorbereitend erledigen",
   rule:"Aktive Handlung, die man ZUR VORBEREITUNG im Voraus erledigt. Auch: einen Zustand bewusst belassen. In der Umgangssprache oft verkürzt zu とく (持って→持っとく).",
   build:[{form:"① im Voraus tun",verb:"V<sub>テ</sub> + おきます",de:"vorbereiten"},{form:"② Zustand belassen",verb:"そのままに して おきます",de:"so lassen wie es ist"},{form:"Umgangssprache",verb:"〜ておく → 〜とく",de:"<ruby>持<rt>も</rt></ruby>っとく = mitnehmen (umg.)"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"(für später…)",role:"time",label:"Zweck"},{text:"Objekt を",role:"obj"},{text:"V-て",role:"verb"},{text:"おきます",role:"actor",label:"im Voraus"}],gloss:"»Ich [V] schon mal — für später / damit es bereit ist.« — bewusst-vorausschauende Aktion."},
   ex:[{jp:"<ruby>旅行<rt>りょこう</rt></ruby>の <ruby>前<rt>まえ</rt></ruby>に きっぷを <ruby>買<rt>か</rt></ruby>って おきます。",de:"Vor der Reise kaufe ich (schon mal) das Ticket."},{jp:"<ruby>会議<rt>かいぎ</rt></ruby>の <ruby>前<rt>まえ</rt></ruby>に <ruby>資料<rt>しりょう</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んで おきます。",de:"Vor der Besprechung lese ich (schon mal) die Unterlagen."},{jp:"ビールを <ruby>冷蔵庫<rt>れいぞうこ</rt></ruby>に <ruby>入<rt>い</rt></ruby>れて おきました。",de:"Ich habe das Bier (vorbereitend) in den Kühlschrank getan."}],
   note:"💡 Vergleich てあります vs. ておきます: あります = beschreibt den Zustand (statisch). おきます = beschreibt die Handlung (aktiv vorbereitend)."},
  {l:30, t:"まだ V て います (noch andauernd)", de:"noch immer (läuft weiter)",
   rule:"まだ + て-Form drückt aus, dass eine Aktion oder ein Zustand WEITERHIN andauert — sie ist noch nicht beendet.",
   build:[{form:"まだ + て-Form",verb:"まだ V<sub>テ</sub> います",de:"macht noch (immer)"},{form:"Gegensatz",verb:"もう V ました",de:"hat schon V-t (abgeschlossen)"},{form:"Gegensatz",verb:"もう V ません",de:"macht nicht mehr"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"まだ",role:"time",label:"noch"},{text:"V-て います",role:"verb",label:"laufend"}],gloss:"»[Subjekt] [V]-t immer noch.« — Aktion ist nicht abgeschlossen, läuft weiter."},
   ex:[{jp:"<ruby>雨<rt>あめ</rt></ruby>が まだ <ruby>降<rt>ふ</rt></ruby>って います。",de:"Es regnet noch immer."},{jp:"<ruby>父<rt>ちち</rt></ruby>は まだ <ruby>働<rt>はたら</rt></ruby>いて います。",de:"Mein Vater arbeitet noch immer."},{jp:"<ruby>子供<rt>こども</rt></ruby>たちは まだ <ruby>遊<rt>あそ</rt></ruby>んで います。",de:"Die Kinder spielen noch immer."}],
   note:"⚠️ Verwechsle nicht mit まだ V ていません (»noch nicht«, L31) — das ist die Verneinung mit anderem Sinn."},
  {l:30, t:"まだ V<ruby>辞書形<rt>じしょけい</rt></ruby> (noch ausstehend)", de:"noch / immer noch …",
   rule:"まだ + Wörterbuchform = etwas dauert an, ist noch nicht beendet, oder steht noch bevor. Wird oft mit ている-Form kombiniert.",
   build:[{form:"まだ + Vる",verb:"まだ <ruby>食<rt>た</rt></ruby>べる",de:"isst noch (= weiter)"},{form:"まだ + V ている",verb:"まだ <ruby>食<rt>た</rt></ruby>べて いる",de:"isst noch (häufiger)"},{form:"Gegenteil",verb:"もう V ました ↔ まだ V ていません",de:"schon V-t ↔ noch nicht V-t"}],
   pattern:{slots:[{text:"まだ",role:"time",label:"noch"},{text:"V-辞書形 / V-ている",role:"verb"}],gloss:"»[V] dauert/läuft weiter / steht noch aus.« — Kontrast zu もう (»schon«)."},
   ex:[{jp:"まだ <ruby>時間<rt>じかん</rt></ruby>が ある。",de:"Es ist noch Zeit (übrig)."},{jp:"まだ <ruby>夏休<rt>なつやす</rt></ruby>みが <ruby>続<rt>つづ</rt></ruby>いて いる。",de:"Die Sommerferien dauern noch an."},{jp:"まだ <ruby>食<rt>た</rt></ruby>べて いる。",de:"Ich esse noch (immer noch dabei)."}],
   note:"💡 Faustregel: もう = schon (abgeschlossen) ↔ まだ = noch (läuft / steht aus). Beides oft kontrastiv im selben Gespräch verwendet."},
  {l:31, t:"<ruby>意向形<rt>いこうけい</rt></ruby> (Volitional-Form) — Bildung", de:"Lass uns … / ich will …",
   rule:"Plain-Form von ましょう. Drückt einen Vorschlag (»lass uns!«) oder eine eigene Absicht (»ich will/werde …«) aus, je nach Kontext.",
   build:[{form:"Gruppe I: u → o + う",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>こう",de:"lass uns schreiben"},{form:"Gruppe I",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>もう",de:"lass uns trinken"},{form:"Gruppe I",verb:"<ruby>行<rt>い</rt></ruby>く → <ruby>行<rt>い</rt></ruby>こう",de:"lass uns gehen"},{form:"Gruppe II: る → よう",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べよう",de:"lass uns essen"},{form:"Gruppe II",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>よう",de:"lass uns schauen"},{form:"Unregelmäßig",verb:"する → しよう / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>よう",de:"machen / kommen"},{form:"Höflich-Variante",verb:"V<sub>マス</sub>-Stamm + ましょう",de:"lass uns V (höflich, L6)"}],
   pattern:{slots:[{text:"(Gemeinsam …)",role:"plain",label:""},{text:"V-Volitional",role:"verb",label:"Vorschlag/Absicht"},{text:"。",role:"plain"}],gloss:"Volitional steht meist allein als Aufforderung/Vorschlag oder leitet einen Plan ein (mit と思っています/つもり)."},
   ex:[{jp:"いっしょに ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べよう。",de:"Lass uns zusammen essen."},{jp:"そろそろ <ruby>帰<rt>かえ</rt></ruby>ろう。",de:"Lass uns langsam zurückgehen."},{jp:"きょうは <ruby>早<rt>はや</rt></ruby>く <ruby>寝<rt>ね</rt></ruby>よう。",de:"Heute lass uns früh schlafen."}],
   note:"💡 Volitional ist die Plain-Form von ましょう — gleicher Sinn, aber informell. Im formellen Kontext lieber ましょう benutzen."},
  {l:31, t:"V<ruby>意向形<rt>いこうけい</rt></ruby> + と <ruby>思<rt>おも</rt></ruby>っています", de:"Ich habe vor / plane zu …",
   rule:"Drückt eine Absicht/einen Plan aus, den der Sprecher schon länger hat. Volitional + と思っています ist weicher und flexibler als つもりです — die Entscheidung steht nicht ganz fest.",
   build:[{form:"Anschluss",verb:"V<sub>意向</sub> + と <ruby>思<rt>おも</rt></ruby>っています",de:"ich plane V"},{form:"vs. つもりです",verb:"festere, klare Absicht",de:""},{form:"vs. と<ruby>思<rt>おも</rt></ruby>います",verb:"",de:"spontaner Gedanke (jetzt entstanden)"}],
   pattern:{slots:[{text:"Subjekt (ich)",role:"subj",label:"meist ich"},{text:"は",role:"plain"},{text:"V-Volitional",role:"verb",label:"Plan"},{text:"と<ruby>思<rt>おも</rt></ruby>っています",role:"actor",label:"habe vor"}],gloss:"»Ich denke daran, [V] zu tun.« — länger gehegter Plan, mit Spielraum für Änderungen."},
   ex:[{jp:"<ruby>来年<rt>らいねん</rt></ruby> <ruby>日本<rt>にほん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>こうと <ruby>思<rt>おも</rt></ruby>っています。",de:"Ich plane, nächstes Jahr nach Japan zu gehen."},{jp:"<ruby>週末<rt>しゅうまつ</rt></ruby>は <ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>ようと <ruby>思<rt>おも</rt></ruby>っています。",de:"Am Wochenende will ich (vorhaben) einen Film schauen."},{jp:"<ruby>新<rt>あたら</rt></ruby>しい <ruby>車<rt>くるま</rt></ruby>を <ruby>買<rt>か</rt></ruby>おうと <ruby>思<rt>おも</rt></ruby>っています。",de:"Ich habe vor, ein neues Auto zu kaufen."}],
   note:"💡 Reihenfolge der Festigkeit: と思います (spontan) < と思っています (länger geplant) < つもりです (klar entschlossen) < 予定です (offiziell terminiert)."},
  {l:31, t:"もう V ました / まだ V ていません", de:"Schon getan / noch nicht getan",
   rule:"Vollständige Form (Erweiterung von L7). もう + V ました = etwas ist schon erledigt. まだ + V ていません = es steht noch aus, wird aber noch passieren. ⚠️ NICHT まだ V ませんでした!",
   build:[{form:"schon getan",verb:"もう V ました",de:"habe schon V getan"},{form:"noch nicht (steht aus)",verb:"まだ V ていません",de:"habe noch nicht V"},{form:"⚠ FALSCH",verb:"まだ V ませんでした",de:"NICHT verwenden!"},{form:"vs. (gar nicht getan)",verb:"V ませんでした",de:"hat (damals) nicht V"}],
   pattern:{slots:[[{text:"もう",role:"time",label:"schon"},{text:"V-ました",role:"verb",label:"abgeschlossen"}],[{text:"まだ",role:"time",label:"noch nicht"},{text:"V-て いません",role:"verb",label:"steht aus"}]],gloss:"Zwei Pole: もう…ました (positiv abgeschlossen) ↔ まだ…ていません (offen, kommt noch)."},
   ex:[{jp:"もう <ruby>昼<rt>ひる</rt></ruby>ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べましたか。— はい、<b>もう</b> <ruby>食<rt>た</rt></ruby>べました。",de:"Hast du schon Mittag gegessen? — Ja, schon."},{jp:"いいえ、<b>まだ</b> <ruby>食<rt>た</rt></ruby>べて いません。",de:"Nein, noch nicht (werde ich aber)."},{jp:"レポートは <b>まだ</b> <ruby>書<rt>か</rt></ruby>いて いません。",de:"Den Bericht habe ich noch nicht geschrieben."}],
   note:"⚠️ Häufiger Fehler: まだ <ruby>食<rt>た</rt></ruby>べませんでした ist FALSCH. Richtig: まだ <ruby>食<rt>た</rt></ruby>べて いません."},
  {l:31, t:"V つもりです / V ない つもりです", de:"Ich habe (nicht) die Absicht zu …",
   rule:"Klare, feste Absicht — fester als と思っています. Positiv: 辞書形+つもりです. Negativ: ない形+つもりです (Absicht, NICHT zu tun).",
   build:[{form:"positiv",verb:"V<sub>辞書</sub> + つもりです",de:"habe vor zu V"},{form:"negativ",verb:"V<sub>ない</sub> + つもりです",de:"habe vor, NICHT zu V"},{form:"Vergangenheit",verb:"〜つもりでした",de:"hatte (damals) vor"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V-辞書/ない",role:"verb",label:"Plan"},{text:"つもりです",role:"actor",label:"feste Absicht"}],gloss:"»Ich habe die feste Absicht, [V] (nicht) zu tun.« — klar entschlossen."},
   ex:[{jp:"<ruby>来年<rt>らいねん</rt></ruby> <ruby>結婚<rt>けっこん</rt></ruby>する つもりです。",de:"Nächstes Jahr habe ich vor zu heiraten."},{jp:"タバコは もう <ruby>吸<rt>す</rt></ruby>わない つもりです。",de:"Ich habe vor, nicht mehr zu rauchen."},{jp:"きょうは <ruby>出<rt>で</rt></ruby>かけない つもりです。",de:"Heute habe ich vor, nicht auszugehen."}],
   note:"💡 Plan-Stufen: と思っています (weich, flexibel) < つもりです (fest entschlossen) < 予定です (terminiert/offiziell)."},
  {l:31, t:"V<ruby>辞書形<rt>じしょけい</rt></ruby> + <ruby>予定<rt>よてい</rt></ruby>です", de:"Es ist geplant, dass …",
   rule:"Konkreter, festgelegter Plan: Termine, Reisen, Geschäftliches. Formeller als つもりです, oft mit Datum/Zeit. Bei Nomen: N + の予定です.",
   build:[{form:"Verb",verb:"V<sub>辞書</sub> + <ruby>予定<rt>よてい</rt></ruby>です",de:"ist geplant zu V"},{form:"Nomen",verb:"N + の <ruby>予定<rt>よてい</rt></ruby>です",de:"N ist geplant"},{form:"Vergangenheit",verb:"〜<ruby>予定<rt>よてい</rt></ruby>でした",de:"war geplant"}],
   pattern:{slots:[{text:"Zeit/Datum",role:"time",label:"wann"},{text:"V-辞書 / N の",role:"verb"},{text:"<ruby>予定<rt>よてい</rt></ruby>です",role:"actor",label:"terminiert"}],gloss:"»Am [Datum] ist [V/N] terminlich geplant.« — feste Terminplanung, oft offiziell oder beruflich."},
   ex:[{jp:"<ruby>来週<rt>らいしゅう</rt></ruby>の <ruby>月曜日<rt>げつようび</rt></ruby> <ruby>会議<rt>かいぎ</rt></ruby>を する <ruby>予定<rt>よてい</rt></ruby>です。",de:"Nächsten Montag ist eine Besprechung geplant."},{jp:"<ruby>3時<rt>さんじ</rt></ruby>から <ruby>面接<rt>めんせつ</rt></ruby>の <ruby>予定<rt>よてい</rt></ruby>です。",de:"Ab 3 Uhr ist ein Vorstellungsgespräch geplant."},{jp:"<ruby>来月<rt>らいげつ</rt></ruby> <ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>く <ruby>予定<rt>よてい</rt></ruby>です。",de:"Nächsten Monat plane ich, nach Kyoto zu fahren."}],
   note:"💡 Reihenfolge nach Festigkeit: つもりです (eigene Absicht) → 予定です (offiziell terminiert, kalendarisch)."},
  {l:32, t:"V た ほうが いい / V ない ほうが いい", de:"Du solltest (nicht) …",
   rule:"Ratschlag/Empfehlung. Positiv: た-Form + ほうが いい. Negativ: ない-Form + ほうが いい. ⚠️ NICHT 辞書形 verwenden!",
   build:[{form:"positiv (Empfehlung)",verb:"V<sub>た</sub> + ほうが いい",de:"sollte V tun"},{form:"negativ (Warnung)",verb:"V<sub>ない</sub> + ほうが いい",de:"sollte V NICHT tun"},{form:"⚠ FALSCH",verb:"V<sub>辞書</sub> + ほうが いい",de:"NICHT verwenden"},{form:"höflich",verb:"〜ほうが いいですよ",de:"Tipp/Rat (höflich)"}],
   pattern:{slots:[{text:"Empfänger は",role:"subj",label:"du/Sie"},{text:"V-た / V-ない",role:"verb",label:"Handlung"},{text:"ほうが",role:"actor"},{text:"いいです (よ)",role:"plain"}],gloss:"»Es wäre besser, [V] (nicht) zu tun.« — Rat, oft mit よ am Ende für Anteilnahme."},
   ex:[{jp:"<ruby>熱<rt>ねつ</rt></ruby>が ありますね。<ruby>病院<rt>びょういん</rt></ruby>へ <b>行<rt>い</rt>った ほうが いいですよ</b>。",de:"Du hast Fieber. Du solltest zum Arzt gehen."},{jp:"タバコは <b>吸わない ほうが いいです</b>。",de:"Du solltest nicht rauchen."},{jp:"<ruby>無理<rt>むり</rt></ruby>を <b>しない ほうが いいですよ</b>。",de:"Du solltest dich nicht überanstrengen."}],
   note:"⚠️ Häufiger Fehler: 行く ほうが いい → falsch! Richtig: 行<b>った</b> ほうが いい (た-Form!)."},
  {l:32, t:"Plain-Form + でしょう (Vermutung)", de:"vermutlich / wahrscheinlich …",
   rule:"Vermutung des Sprechers mit mittlerer Sicherheit (~70-80%). Bei な-Adj/N: だ FÄLLT WEG! Oft mit たぶん zusammen.",
   build:[{form:"Verb",verb:"V<sub>普通形</sub> + でしょう",de:"<ruby>降<rt>ふ</rt></ruby>るでしょう = wird wohl regnen"},{form:"い-Adj",verb:"い-Adj + でしょう",de:"<ruby>寒<rt>さむ</rt></ruby>いでしょう = wird wohl kalt"},{form:"な-Adj",verb:"な-Adj (ohne だ!) + でしょう",de:"<ruby>元気<rt>げんき</rt></ruby>でしょう (NICHT 元気だでしょう)"},{form:"Nomen",verb:"N (ohne だ!) + でしょう",de:"<ruby>学生<rt>がくせい</rt></ruby>でしょう"}],
   pattern:{slots:[{text:"たぶん",role:"time",label:"wahrscheinlich"},{text:"Inhalt",role:"verb",label:"Vermutung"},{text:"でしょう",role:"actor",label:"wohl"}],gloss:"»[Inhalt] vermutlich.« — eigene Einschätzung, etwa 70-80% Sicherheit."},
   ex:[{jp:"あした たぶん <ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>るでしょう。",de:"Morgen wird es wohl regnen."},{jp:"ミラーさんは いま <ruby>会社<rt>かいしゃ</rt></ruby>に いるでしょう。",de:"Herr Miller ist jetzt vermutlich in der Firma."},{jp:"<ruby>明日<rt>あした</rt></ruby>は <ruby>休<rt>やす</rt></ruby>みでしょう。",de:"Morgen ist vermutlich frei (Feiertag)."}],
   note:"⚠️ Bei な-Adj/N: KEIN だ vor でしょう! 元気だでしょう ist falsch. 💡 Bei Frage in Plain (informell): 〜だろう statt でしょう."},
  {l:32, t:"Plain-Form + かもしれません", de:"vielleicht / möglicherweise …",
   rule:"Schwächere Vermutung als でしょう (~30-50% Sicherheit). Bei な-Adj/N: だ FÄLLT WEG! Umgangssprachlich: かもしれない oder kurz かも.",
   build:[{form:"Verb",verb:"V<sub>普通形</sub> + かもしれません",de:"vielleicht V"},{form:"い-Adj",verb:"い-Adj + かもしれません",de:"vielleicht Adj"},{form:"な-Adj",verb:"な-Adj (ohne だ!) + かもしれません",de:"vielleicht Adj"},{form:"Nomen",verb:"N (ohne だ!) + かもしれません",de:"vielleicht N"},{form:"Umgangssprache",verb:"〜かも (kurz)",de:"vielleicht (lässig)"}],
   pattern:{slots:[{text:"もしかしたら/たぶん",role:"time",label:"vielleicht"},{text:"Inhalt (Plain)",role:"verb"},{text:"かもしれません",role:"actor",label:"möglicherweise"}],gloss:"»Vielleicht [Inhalt].« — schwache Vermutung, viel unsicherer als でしょう."},
   ex:[{jp:"あしたは <ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>るかもしれません。",de:"Morgen regnet es vielleicht."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>来<rt>こ</rt></ruby>ないかもしれません。",de:"Vielleicht kommt er nicht."},{jp:"これは <ruby>難<rt>むずか</rt></ruby>しいかも。",de:"Das ist vielleicht schwierig. [Umg.]"}],
   note:"💡 Sicherheits-Skala: かもしれません (~30-50%) < でしょう (~70-80%) < はずです (~90%, L46) < に違いない (~99%, fortgeschritten)."},
  {l:32, t:"もしかしたら 〜 かもしれません", de:"eventuell / womöglich …",
   rule:"Verstärkt die Unsicherheit. »Es könnte sogar sein, dass …«. もしかしたら am Satzanfang + かもしれません am Satzende.",
   build:[{form:"Anschluss",verb:"もしかしたら 〜 かもしれません",de:"womöglich (sogar)"},{form:"Variante",verb:"もしかすると 〜 かもしれません",de:"etwas formeller"}],
   pattern:{slots:[{text:"もしかしたら",role:"time",label:"womöglich"},{text:"Inhalt (Plain)",role:"verb"},{text:"かもしれません",role:"actor",label:"vielleicht"}],gloss:"Doppelte Unsicherheits-Markierung am Anfang UND am Ende — »vage Ahnung, dass …«."},
   ex:[{jp:"<b>もしかしたら</b> <ruby>明日<rt>あした</rt></ruby>は <ruby>雪<rt>ゆき</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>る<b>かもしれません</b>。",de:"Womöglich schneit es morgen sogar."},{jp:"<b>もしかしたら</b> <ruby>彼<rt>かれ</rt></ruby>は もう <ruby>知<rt>し</rt></ruby>っている<b>かもしれません</b>。",de:"Womöglich weiß er es schon."}],
   note:"💡 Drückt eine vage Ahnung aus, oft mit überraschtem oder besorgtem Unterton."},
  {l:33, t:"<ruby>命令形<rt>めいれいけい</rt></ruby> (Befehlsform)", de:"Tu es! (Befehl)",
   rule:"Starker, brüsker Befehl. Nur in Notfällen, Sport-Anfeuerung, zwischen Männern (informell), Kommando-Tonfall, Verkehrsschildern verwenden. ⚠️ Unter Freunden/Familie meist ZU HART!",
   build:[{form:"Gruppe I: u → e",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>け",de:"schreib!"},{form:"Gruppe I",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>め",de:"trink!"},{form:"Gruppe I",verb:"<ruby>急<rt>いそ</rt></ruby>ぐ → <ruby>急<rt>いそ</rt></ruby>げ",de:"beeil dich!"},{form:"Gruppe II: る → ろ",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べろ",de:"iss!"},{form:"Gruppe II",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>ろ",de:"schau!"},{form:"Unregelmäßig",verb:"する → しろ / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>い",de:"mach! / komm!"}],
   pattern:{slots:[{text:"V-Befehl",role:"verb",label:"Imperativ"},{text:"!",role:"plain"}],gloss:"Steht meist allein als knapper Befehl. Tonfall ist sehr direkt — nur in passenden Kontexten."},
   ex:[{jp:"<ruby>早<rt>はや</rt></ruby>く <ruby>来<rt>こ</rt></ruby>い!",de:"Komm schnell! [Sport/Notfall]"},{jp:"がんばれ!",de:"Gib alles! [Anfeuerung]"},{jp:"<ruby>止<rt>と</rt></ruby>まれ。",de:"Halt! [Verkehrsschild]"}],
   note:"⚠️ Höflichere Alternativen: V<sub>テ</sub> ください (L14) / V<sub>テ</sub> いただけませんか (L26). Befehlsform NIE im normalen Gespräch nutzen."},
  {l:33, t:"<ruby>禁止形<rt>きんしけい</rt></ruby> (Prohibitiv/Verbot)", de:"Tu es NICHT! (Verbot)",
   rule:"Starkes Verbot. Bildung ist FÜR ALLE GRUPPEN GLEICH: Wörterbuchform + な. Sehr brüsk — auf Warnschildern, zwischen Männern (informell), in Notsituationen.",
   build:[{form:"Universalregel: V<sub>辞書</sub> + な",verb:"alle Gruppen gleich",de:"—"},{form:"Beispiel Gr. I",verb:"<ruby>触<rt>さわ</rt></ruby>る → <ruby>触<rt>さわ</rt></ruby>るな",de:"nicht anfassen!"},{form:"Beispiel Gr. II",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べるな",de:"nicht essen!"},{form:"Unregelmäßig",verb:"する → するな / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>く</rt></ruby>るな",de:"nicht tun! / nicht kommen!"}],
   pattern:{slots:[{text:"V-辞書",role:"verb"},{text:"な",role:"actor",label:"Verbot"},{text:"!",role:"plain"}],gloss:"»Tu [V] NICHT!« — sehr direkt, oft auf Verbotsschildern."},
   ex:[{jp:"<ruby>触<rt>さわ</rt></ruby>るな!",de:"Nicht anfassen! [Schild]"},{jp:"ここで タバコを <ruby>吸<rt>す</rt></ruby>うな。",de:"Hier nicht rauchen!"},{jp:"<ruby>嘘<rt>うそ</rt></ruby>を つくな!",de:"Lüg nicht!"}],
   note:"⚠️ Höflichere Alternativen: V<sub>ない</sub>で ください (L17) / 〜ては いけません (L17). 禁止形 nur auf Schildern oder in Extremsituationen."},
  {l:33, t:"V + ように <ruby>言<rt>い</rt></ruby>います", de:"jemandem sagen, dass er … soll",
   rule:"Indirekte Aufforderung — »jemandem sagen, dass er etwas (nicht) tun soll«. 辞書形+ように (positive Aufforderung) oder ない形+ように (negative).",
   build:[{form:"positiv",verb:"V<sub>辞書</sub> + ように <ruby>言<rt>い</rt></ruby>います",de:"sagen, dass V"},{form:"negativ",verb:"V<sub>ない</sub> + ように <ruby>言<rt>い</rt></ruby>います",de:"sagen, dass NICHT V"},{form:"Varianten",verb:"<ruby>頼<rt>たの</rt></ruby>む / <ruby>伝<rt>つた</rt></ruby>える / <ruby>注意<rt>ちゅうい</rt></ruby>する",de:"bitten / weitergeben / ermahnen"}],
   pattern:{slots:[{text:"Sprecher は",role:"subj"},{text:"Empfänger に",role:"actor",label:"wem"},{text:"V-辞書/ない",role:"verb"},{text:"ように",role:"plain"},{text:"<ruby>言<rt>い</rt></ruby>います",role:"verb",label:"Aufforderung"}],gloss:"»[Sprecher] sagt [Empfänger], dass er [V] (nicht) tun soll.« — indirekte Wiedergabe einer Aufforderung."},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>は <ruby>学生<rt>がくせい</rt></ruby>に <ruby>宿題<rt>しゅくだい</rt></ruby>を する<b>ように</b> <ruby>言<rt>い</rt></ruby>いました。",de:"Der Lehrer sagte den Schülern, dass sie die Hausaufgaben machen sollen."},{jp:"<ruby>母<rt>はは</rt></ruby>は <ruby>遅<rt>おそ</rt></ruby>く <ruby>帰<rt>かえ</rt></ruby>らない<b>ように</b> <ruby>言<rt>い</rt></ruby>いました。",de:"Meine Mutter sagte mir, dass ich nicht spät heimkommen soll."},{jp:"<ruby>医者<rt>いしゃ</rt></ruby>に お<ruby>酒<rt>さけ</rt></ruby>を <ruby>飲<rt>の</rt></ruby>まない<b>ように</b> <ruby>言<rt>い</rt></ruby>われました。",de:"Mir wurde vom Arzt gesagt, dass ich keinen Alkohol trinken soll."}],
   note:"💡 Direktes Zitat dagegen mit と: »<ruby>食<rt>た</rt></ruby>べて« と <ruby>言<rt>い</rt></ruby>いました = sagte »iss«."},
  {l:33, t:"〜と <ruby>読<rt>よ</rt></ruby>みます / 〜と <ruby>書<rt>か</rt></ruby>いて あります", de:"wird gelesen als / ist geschrieben",
   rule:"Beschreibt, wie ein Wort gelesen wird, oder was auf einem Schild/in einem Text steht. Häufig bei Schildern und Kanji-Lesungen.",
   build:[{form:"Lesung",verb:"〜と <ruby>読<rt>よ</rt></ruby>みます",de:"wird gelesen als"},{form:"Geschrieben",verb:"〜と <ruby>書<rt>か</rt></ruby>いて あります",de:"steht geschrieben"},{form:"Bedeutung",verb:"〜と いう <ruby>意味<rt>いみ</rt></ruby>です",de:"bedeutet (siehe nächste Karte)"}],
   pattern:{slots:[{text:"Wort/Schild",role:"obj",label:"das"},{text:"は",role:"plain"},{text:"»…«",role:"subj",label:"Inhalt"},{text:"と",role:"plain",label:"als"},{text:"<ruby>読<rt>よ</rt></ruby>みます/<ruby>書<rt>か</rt></ruby>いてあります",role:"verb"}],gloss:"»[Wort] liest sich als »…« / steht als »…« geschrieben.« — Brücke zwischen Schriftbild und Aussprache/Inhalt."},
   ex:[{jp:"この <ruby>漢字<rt>かんじ</rt></ruby>は 「みち」と <ruby>読<rt>よ</rt></ruby>みます。",de:"Dieses Kanji wird »michi« gelesen."},{jp:"あの かんばんに 「<ruby>禁煙<rt>きんえん</rt></ruby>」と <ruby>書<rt>か</rt></ruby>いて あります。",de:"Auf jenem Schild steht »Rauchverbot«."},{jp:"ここに 「<ruby>立入禁止<rt>たちいりきんし</rt></ruby>」と <ruby>書<rt>か</rt></ruby>いて あります。",de:"Hier steht »Betreten verboten«."}],
   note:"💡 Anführungszeichen 「 」 markieren das zitierte Wort/den Text. と funktioniert hier wie ein »als«-Marker."},
  {l:33, t:"〜と いう <ruby>意味<rt>いみ</rt></ruby>です", de:"das bedeutet …",
   rule:"Erklärung der Bedeutung eines Wortes, Schildes oder Ausdrucks. Auch als Frage: どういう意味ですか = »Was bedeutet das?«.",
   build:[{form:"Aussage",verb:"〜は 〜と いう <ruby>意味<rt>いみ</rt></ruby>です",de:"… bedeutet …"},{form:"Frage",verb:"どういう <ruby>意味<rt>いみ</rt></ruby>ですか",de:"was bedeutet das?"}],
   pattern:{slots:[{text:"Wort/Schild",role:"obj"},{text:"は",role:"plain"},{text:"»Bedeutung«",role:"subj"},{text:"と いう <ruby>意味<rt>いみ</rt></ruby>です",role:"verb",label:"bedeutet"}],gloss:"»[Wort] bedeutet [Bedeutung].« — typisch in Erklärungen für Anfänger oder bei Schildern."},
   ex:[{jp:"この マークは「<ruby>立入禁止<rt>たちいりきんし</rt></ruby>」と いう <ruby>意味<rt>いみ</rt></ruby>です。",de:"Dieses Zeichen bedeutet »Betreten verboten«."},{jp:"「もったいない」は どういう <ruby>意味<rt>いみ</rt></ruby>ですか。",de:"Was bedeutet »mottainai«?"},{jp:"「やばい」は <ruby>危<rt>あぶ</rt></ruby>ないと いう <ruby>意味<rt>いみ</rt></ruby>です。",de:"»Yabai« bedeutet gefährlich."}],
   note:"💡 Auch in Konversation häufig: 〜って どういう意味? = umgangssprachlich für »was heißt …?«."},
  {l:33, t:"S + と <ruby>言<rt>い</rt></ruby>って いました", de:"… hat gesagt, dass … (indirekte Rede)",
   rule:"Berichtet, was jemand anders gesagt hat. Plain-Form + と言っていました. Im Unterschied zu と言いました betont いました, dass die Aussage länger zurückliegt oder wiederholt wurde.",
   build:[{form:"Anschluss",verb:"S/Plain-Form + と <ruby>言<rt>い</rt></ruby>って いました",de:"hat gesagt, dass S"},{form:"vs. と<ruby>言<rt>い</rt></ruby>いました",verb:"einmaliger Aussage-Akt",de:"hat einmal gesagt"},{form:"vs. と<ruby>言<rt>い</rt></ruby>って います",verb:"sagt es regelmäßig/dauerhaft",de:"sagt (laufend)"}],
   pattern:{slots:[{text:"Person",role:"actor",label:"wer sagte"},{text:"は/が",role:"plain"},{text:"Inhalt (Plain)",role:"verb",label:"was"},{text:"と <ruby>言<rt>い</rt></ruby>って いました",role:"actor",label:"hat (damals) gesagt"}],gloss:"»[Person] hat gesagt, dass [Inhalt].« — wiedergegebene Aussage, Inhalt steht in Plain-Form."},
   ex:[{jp:"<ruby>田中<rt>たなか</rt></ruby>さんは <ruby>明日<rt>あした</rt></ruby> <ruby>休<rt>やす</rt></ruby>むと <ruby>言<rt>い</rt></ruby>って いました。",de:"Frau Tanaka hat gesagt, dass sie morgen frei nimmt."},{jp:"<ruby>母<rt>はは</rt></ruby>は <ruby>体<rt>からだ</rt></ruby>に <ruby>気<rt>き</rt></ruby>を つけてと <ruby>言<rt>い</rt></ruby>って いました。",de:"Meine Mutter hat gesagt, ich solle auf meine Gesundheit achten."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は おもしろい <ruby>映画<rt>えいが</rt></ruby>だと <ruby>言<rt>い</rt></ruby>って いました。",de:"Er hat gesagt, dass es ein interessanter Film ist."}],
   note:"💡 Bei Nomen/な-Adj wird だ vor と eingefügt: <ruby>学生<rt>がくせい</rt></ruby>だと言っていました."},
  {l:33, t:"S + と <ruby>伝<rt>つた</rt></ruby>えて いただけませんか", de:"Könnten Sie bitte weitergeben, dass …?",
   rule:"Höfliche Bitte um Weiterleitung einer Nachricht. Plain-Form + と + 伝えて いただけませんか (sehr höflich) oder 伝えて ください (normal höflich).",
   build:[{form:"sehr höflich",verb:"〜と <ruby>伝<rt>つた</rt></ruby>えて いただけませんか",de:"könnten Sie bitte weitergeben"},{form:"höflich",verb:"〜と <ruby>伝<rt>つた</rt></ruby>えて ください",de:"bitte weitergeben"}],
   pattern:{slots:[{text:"(Adressat) に",role:"actor",label:"an wen"},{text:"Inhalt (Plain)",role:"verb"},{text:"と",role:"plain"},{text:"<ruby>伝<rt>つた</rt></ruby>えて いただけませんか",role:"verb",label:"weitergeben (höfl.)"}],gloss:"»Würden Sie [Person] bitte ausrichten, dass [Inhalt]?« — höfliche Nachrichtenübermittlung."},
   ex:[{jp:"<ruby>田中<rt>たなか</rt></ruby>さんに <ruby>会議<rt>かいぎ</rt></ruby>が <ruby>3時<rt>さんじ</rt></ruby>からだと <ruby>伝<rt>つた</rt></ruby>えて いただけませんか。",de:"Könnten Sie Frau Tanaka bitte ausrichten, dass die Besprechung um 3 anfängt?"},{jp:"あとで <ruby>電話<rt>でんわ</rt></ruby>すると <ruby>伝<rt>つた</rt></ruby>えて ください。",de:"Bitte richten Sie aus, dass ich später anrufe."}],
   note:"💡 Im Büroalltag und am Telefon sehr typisch — wenn man nicht direkt mit der Zielperson sprechen kann."},
  {l:34, t:"V<ruby>辞書<rt>じしょ</rt></ruby>/V た + とおりに、…", de:"genau wie / so wie …",
   rule:"Etwas genauso tun, wie es vorgegeben ist. V + とおりに oder N + のとおりに. 辞書形 = »wie man tut«, た-Form = »wie es schon getan wurde«.",
   build:[{form:"V<sub>辞書</sub> + とおりに",verb:"<ruby>言<rt>い</rt></ruby>うとおりに",de:"so wie ich/man sage"},{form:"V<sub>た</sub> + とおりに",verb:"<ruby>聞<rt>き</rt></ruby>いたとおりに",de:"so wie ich gehört habe"},{form:"N + のとおりに",verb:"<ruby>説明書<rt>せつめいしょ</rt></ruby>のとおりに",de:"so wie in der Anleitung"}],
   pattern:{slots:[{text:"Vorgabe",role:"cond",label:"Vorlage"},{text:"とおりに",role:"actor",label:"genau so"},{text:"V (Hauptverb)",role:"verb",label:"machen"}],gloss:"»Genau wie [Vorgabe] [V tun].« — exakte Befolgung einer Anweisung/Anleitung/Aussage."},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>が <ruby>言<rt>い</rt></ruby>った とおりに <ruby>書<rt>か</rt></ruby>いて ください。",de:"Bitte schreib genau so, wie der Lehrer es gesagt hat."},{jp:"<ruby>説明書<rt>せつめいしょ</rt></ruby>の とおりに <ruby>組<rt>く</rt></ruby>み <ruby>立<rt>た</rt></ruby>てました。",de:"Ich habe es nach Anleitung zusammengebaut."},{jp:"<ruby>地図<rt>ちず</rt></ruby>の とおりに <ruby>行<rt>い</rt></ruby>けば、すぐ つきます。",de:"Wenn Sie der Karte folgen, kommen Sie gleich an."}],
   note:"💡 Faustregel: 辞書形 = »so wie es ist« (allgemein) / た-Form = »so wie es gewesen ist« (konkret-vergangen)."},
  {l:34, t:"V た + あとで、V₂", de:"Nachdem … (V₁), dann V₂",
   rule:"Reihenfolge mit klarer Trennung. た-Form + あとで. Bei N: N + の あとで. Vergleich: てから (sofort danach) vs. あとで (nach einer Weile).",
   build:[{form:"Verb",verb:"V<sub>た</sub> + あとで、V₂",de:"nachdem V, dann V₂"},{form:"Nomen",verb:"N + の あとで、V₂",de:"nach N, dann V₂"},{form:"vs. てから",verb:"V<sub>テ</sub> + から",de:"sofort nachdem (enge Folge)"},{form:"vs. あとで",verb:"nach einer Weile (loser)",de:""}],
   pattern:{slots:[[{text:"V₁-た / N の",role:"verb",label:"erst"},{text:"あとで、",role:"actor",label:"danach"},{text:"V₂",role:"verb",label:"dann"}]],gloss:"»Nachdem [V₁], (etwas später) [V₂].« — zeitlich klar getrennte Reihenfolge."},
   ex:[{jp:"ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べた あとで、お <ruby>風呂<rt>ふろ</rt></ruby>に <ruby>入<rt>はい</rt></ruby>ります。",de:"Nach dem Essen nehme ich ein Bad."},{jp:"<ruby>仕事<rt>しごと</rt></ruby>の あとで、<ruby>飲<rt>の</rt></ruby>みに <ruby>行<rt>い</rt></ruby>きませんか。",de:"Wollen wir nach der Arbeit was trinken gehen?"},{jp:"<ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>た あとで、レストランへ <ruby>行<rt>い</rt></ruby>きました。",de:"Nach dem Film bin ich ins Restaurant gegangen."}],
   note:"💡 Bei てから (L16): die zweite Aktion folgt unmittelbar. Bei あとで: zeitlicher Abstand möglich, aber Reihenfolge ist klar."},
  {l:34, t:"V ない で V₂ (ohne … tun)", de:"V₂ tun, ohne V₁ zu tun",
   rule:"Negation einer Begleithandlung: man tut V₂, ohne V₁ getan zu haben. ない-Form + で + Hauptverb.",
   build:[{form:"Anschluss",verb:"V<sub>ない</sub> + で、V₂",de:"V₂ tun, ohne V₁"},{form:"vs. なくて",verb:"V<sub>ない</sub> → V<sub>なくて</sub>",de:"Begründungsverbindung (»weil nicht«)"}],
   pattern:{slots:[{text:"V₁-ない",role:"verb",label:"ohne V₁"},{text:"で、",role:"actor"},{text:"V₂",role:"verb",label:"V₂ machen"}],gloss:"»[V₂] tun, ohne [V₁] getan zu haben.« — Begleitumstand wird verneint."},
   ex:[{jp:"<ruby>朝<rt>あさ</rt></ruby> ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べないで、<ruby>会社<rt>かいしゃ</rt></ruby>へ <ruby>行<rt>い</rt></ruby>きました。",de:"Ich bin ohne zu frühstücken zur Arbeit gegangen."},{jp:"きのうは <ruby>勉強<rt>べんきょう</rt></ruby>しないで、<ruby>寝<rt>ね</rt></ruby>ました。",de:"Gestern bin ich schlafen gegangen, ohne zu lernen."},{jp:"<ruby>傘<rt>かさ</rt></ruby>を <ruby>持<rt>も</rt></ruby>たないで、<ruby>出<rt>で</rt></ruby>かけました。",de:"Ich bin ohne Schirm aus dem Haus gegangen."}],
   note:"⚠️ Nicht verwechseln mit V<sub>なくて</sub> (Begründung): <ruby>食<rt>た</rt></ruby>べなくて = weil ich nicht gegessen habe (Grund)."},
  {l:35, t:"<ruby>条件形<rt>じょうけんけい</rt></ruby> (ば-Form) — Bildung", de:"Konditional »ば«",
   rule:"Konditionale Form: »wenn …, dann …«. Universell, leicht formell-schriftlich. Gruppe I: u→e + ば. Gruppe II: る→れば. Verneint: ない→なければ. い-Adj: い→ければ. な-Adj/N: 〜なら[ば].",
   build:[{form:"Gr. I: u → e + ば",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>けば",de:"wenn schreibt"},{form:"Gr. I",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>めば",de:"wenn trinkt"},{form:"Gr. II: る → れば",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べれば",de:"wenn isst"},{form:"Unregelmäßig",verb:"する → すれば / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>く</rt></ruby>れば",de:"wenn macht / kommt"},{form:"Verneint",verb:"V<sub>ない</sub> → V<sub>なければ</sub>",de:"<ruby>食<rt>た</rt></ruby>べなければ = wenn nicht isst"},{form:"い-Adj",verb:"い-Adj い → ければ",de:"<ruby>安<rt>やす</rt></ruby>ければ = wenn billig"},{form:"な-Adj/N",verb:"+ なら(ば)",de:"<ruby>暇<rt>ひま</rt></ruby>なら = wenn frei"}],
   pattern:{slots:[{text:"Bedingung",role:"cond",label:"wenn …"},{text:"V/Adj-ば",role:"verb"},{text:"、",role:"plain"},{text:"Folge",role:"verb",label:"dann …"}],gloss:"»Wenn [Bedingung], dann [Folge].« — universell, etwas formell-allgemein, oft für hypothetische/wiederholbare Verhältnisse."},
   ex:[{jp:"<ruby>春<rt>はる</rt></ruby>に なれば、<ruby>桜<rt>さくら</rt></ruby>が <ruby>咲<rt>さ</rt></ruby>きます。",de:"Wenn der Frühling kommt, blühen die Kirschen."},{jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>れば、<ruby>試合<rt>しあい</rt></ruby>は <ruby>中止<rt>ちゅうし</rt></ruby>です。",de:"Wenn es regnet, fällt das Spiel aus."},{jp:"<ruby>分<rt>わ</rt></ruby>からなければ、<ruby>聞<rt>き</rt></ruby>いて ください。",de:"Wenn Sie es nicht verstehen, fragen Sie bitte."}],
   note:"💡 ば-Form vs. たら (L25): ば eher allgemeingültig/hypothetisch; たら eher konkret/zeitlich. Beide oft austauschbar."},
  {l:35, t:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + V + か わかりません", de:"Ich weiß nicht, was/wer/wo …",
   rule:"Indirekte Frage. Fragewort + Plain-Form + か + わからない/知らない/教えてください. Die eingebettete Frage funktioniert wie ein Fragenominal.",
   build:[{form:"Anschluss",verb:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + Plain + か",de:"…ob/was/wer V"},{form:"+ <ruby>分<rt>わ</rt></ruby>かりません",verb:"weiß nicht",de:""},{form:"+ <ruby>知<rt>し</rt></ruby>りません",verb:"weiß nicht (Info)",de:""},{form:"+ <ruby>教<rt>おし</rt></ruby>えてください",verb:"sag mir bitte",de:""}],
   pattern:{slots:[{text:"Fragewort",role:"cond",label:"何/誰/どこ/いつ"},{text:"Plain-Form",role:"verb"},{text:"か",role:"plain",label:"ob"},{text:"<ruby>分<rt>わ</rt></ruby>かりません/<ruby>知<rt>し</rt></ruby>りません",role:"verb",label:"weiß nicht"}],gloss:"»Ich weiß nicht, [Fragewort] [V tun].« — die ganze Frage wird als Inhaltsobjekt eingebettet."},
   ex:[{jp:"あの <ruby>人<rt>ひと</rt></ruby>が だれか <ruby>分<rt>わ</rt></ruby>かりません。",de:"Ich weiß nicht, wer jene Person ist."},{jp:"<ruby>会議<rt>かいぎ</rt></ruby>が <ruby>何時<rt>なんじ</rt></ruby>に <ruby>始<rt>はじ</rt></ruby>まるか <ruby>知<rt>し</rt></ruby>って いますか。",de:"Wissen Sie, wann die Besprechung anfängt?"},{jp:"これは どう <ruby>使<rt>つか</rt></ruby>うか <ruby>教<rt>おし</rt></ruby>えて ください。",de:"Bitte sagen Sie mir, wie man das benutzt."}],
   note:"💡 Bei Ja/Nein-Fragen: 〜<b>かどうか</b> (»ob (oder nicht)«): <ruby>来<rt>く</rt></ruby>るかどうか分かりません = ich weiß nicht, ob er kommt."},
  {l:35, t:"N なら、…", de:"Was … betrifft, dann …",
   rule:"Themenbezogene Bedingung: »Wenn es um X geht, dann Y«. Empfehlung oder Reaktion auf das genannte Thema. Auch bei Vorschlägen: »Für X würde ich Y empfehlen«.",
   build:[{form:"Anschluss",verb:"N + なら、…",de:"was N betrifft"},{form:"vs. ば-Form",verb:"ば = generell wenn",de:"なら = themenbezogen"}],
   pattern:{slots:[{text:"N (Thema)",role:"obj",label:"betr."},{text:"なら、",role:"actor",label:"wenn es um X geht"},{text:"Empfehlung/Aussage",role:"verb"}],gloss:"»Was [N] betrifft — meine Empfehlung/Aussage dazu ist [Folge].« — typisch in Beratungs-Kontexten."},
   ex:[{jp:"<ruby>京都<rt>きょうと</rt></ruby>へ <ruby>行<rt>い</rt></ruby>くなら、<ruby>新幹線<rt>しんかんせん</rt></ruby>が べんりですよ。",de:"Wenn du nach Kyoto fährst, ist der Shinkansen praktisch."},{jp:"<ruby>日本料理<rt>にほんりょうり</rt></ruby>なら、すしが おすすめです。",de:"Was japanisches Essen betrifft, empfehle ich Sushi."},{jp:"パソコンなら、この <ruby>店<rt>みせ</rt></ruby>が <ruby>安<rt>やす</rt></ruby>いです。",de:"Für PCs ist dieses Geschäft günstig."}],
   note:"💡 なら reagiert auf etwas, was vorher genannt wurde — nimmt das Thema auf und gibt eine Empfehlung dazu."},
  {l:35, t:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> V<ruby>ば<rt></rt></ruby> いいですか", de:"Was/wie soll ich tun? (ば-Variante)",
   rule:"Fragt nach Ratschlag mit ば-Form + いいですか. Häufige Fragewörter: どう, 何, どこ, いつ, だれ. Etwas formeller als 〜たらいいですか (L26).",
   build:[{form:"Anschluss",verb:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + V<sub>ば</sub> + いいですか",de:"was/wie soll ich V?"},{form:"vs. たら-Variante (L26)",verb:"〜たら いいですか",de:"praktisch identisch, lockerer"}],
   pattern:{slots:[{text:"Fragewort",role:"cond",label:"どう/何…"},{text:"V-ば",role:"verb"},{text:"いいですか",role:"plain"}],gloss:"»Was wäre die richtige Handlung?« — Ratsuche, ば-Form ist etwas formeller/schriftlicher."},
   ex:[{jp:"どう すれば いいですか。",de:"Was soll ich tun? / Wie soll ich vorgehen?"},{jp:"<ruby>何時<rt>なんじ</rt></ruby>に <ruby>来<rt>く</rt></ruby>れば いいですか。",de:"Um wie viel Uhr soll ich kommen?"},{jp:"だれに <ruby>聞<rt>き</rt></ruby>けば いいですか。",de:"Wen soll ich fragen?"}],
   note:"💡 たら-Variante (L26): どうしたら いいですか — gleicher Sinn, aber lockerer und alltäglicher."},
  {l:35, t:"〜ば 〜ほど、…", de:"Je mehr …, desto mehr …",
   rule:"Steigerung: je mehr/weniger A, desto mehr/weniger B. Verb ば-Form + Verb辞書形 + ほど. Bei い-Adj: ければ+い+ほど. Bei な-Adj: なら+な+ほど.",
   build:[{form:"Verb",verb:"V<sub>ば</sub> + V<sub>辞書</sub> + ほど",de:"je mehr V"},{form:"い-Adj",verb:"Adj-ければ + Adj-い + ほど",de:"je Adj"},{form:"な-Adj",verb:"Adj-なら + Adj-な + ほど",de:"je Adj"}],
   pattern:{slots:[[{text:"Vば / Adj-ければ",role:"cond",label:"je mehr"},{text:"V<sub>辞書</sub> / Adj-い",role:"verb"},{text:"ほど、",role:"actor",label:"desto"}],[{text:"Folge",role:"verb",label:"desto mehr …"}]],gloss:"»Je [A], desto [B].« — proportionale Steigerung."},
   ex:[{jp:"<ruby>勉強<rt>べんきょう</rt></ruby>すれば する <b>ほど</b>、<ruby>面白<rt>おもしろ</rt></ruby>く なります。",de:"Je mehr man lernt, desto interessanter wird es."},{jp:"<ruby>高<rt>たか</rt></ruby>ければ <ruby>高<rt>たか</rt></ruby>い <b>ほど</b>、いいです。",de:"Je teurer, desto besser."},{jp:"<ruby>静<rt>しず</rt></ruby>かなら <ruby>静<rt>しず</rt></ruby>かな <b>ほど</b>、いいです。",de:"Je ruhiger, desto besser."}],
   note:"💡 Faustregel: dasselbe Wort wird zweimal verwendet (Vば+V辞書) — das »Doppeln« markiert die Steigerung."},
  {l:36, t:"V + ように なります", de:"… anfangen zu können / sich ändern",
   rule:"Drückt eine erlangte Fähigkeit oder einen veränderten Gewohnheitszustand aus. »Vorher konnte/tat ich nicht — jetzt schon« oder umgekehrt.",
   build:[{form:"positiv (jetzt schon)",verb:"V<sub>辞書</sub> + ように なります",de:"fängt an zu V"},{form:"Potential häufig",verb:"V<sub>可能</sub> + ように なります",de:"kann jetzt V (vorher nicht)"},{form:"negativ (jetzt nicht mehr)",verb:"V<sub>ない</sub> + ように なります",de:"hört auf zu V"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V-辞書/可能/ない",role:"verb",label:"Inhalt"},{text:"ように なりました",role:"actor",label:"Wandel"}],gloss:"»[Subjekt] hat angefangen, [V] zu (können/tun/nicht tun).« — Veränderung über die Zeit."},
   ex:[{jp:"<ruby>日本語<rt>にほんご</rt></ruby>が <ruby>話<rt>はな</rt></ruby>せるように なりました。",de:"Ich kann jetzt Japanisch sprechen (vorher nicht)."},{jp:"<ruby>毎朝<rt>まいあさ</rt></ruby> ジョギングを するように なりました。",de:"Ich habe angefangen, jeden Morgen zu joggen."},{jp:"タバコを <ruby>吸<rt>す</rt></ruby>わないように なりました。",de:"Ich rauche nicht mehr (habe aufgehört)."}],
   note:"💡 Sehr häufig kombiniert mit der Potential-Form: 〜ように なる drückt aus, dass man jetzt (zum ersten Mal) etwas KANN."},
  {l:36, t:"V + ように して います", de:"Ich achte darauf, dass …",
   rule:"Bewusste, regelmäßige Bemühung. Drückt einen Vorsatz / eine Gewohnheit aus, die man bewusst pflegt. Unterschied zu ようになる: ようにしている = ich strenge mich aktiv an.",
   build:[{form:"positiv",verb:"V<sub>辞書</sub> + ように して います",de:"achte darauf, V zu tun"},{form:"negativ",verb:"V<sub>ない</sub> + ように して います",de:"achte darauf, NICHT V"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V-辞書/ない",role:"verb",label:"Vorsatz"},{text:"ように して います",role:"actor",label:"bewusst gewohnt"}],gloss:"»[Subjekt] bemüht sich gewohnheitsmäßig, [V] (nicht) zu tun.« — aktiv-bewusster Lebenswandel."},
   ex:[{jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>運動<rt>うんどう</rt></ruby>するように して います。",de:"Ich achte darauf, jeden Tag Sport zu machen."},{jp:"あまい ものを <ruby>食<rt>た</rt></ruby>べないように して います。",de:"Ich achte darauf, nichts Süßes zu essen."},{jp:"<ruby>早<rt>はや</rt></ruby>く <ruby>寝<rt>ね</rt></ruby>るように して います。",de:"Ich versuche, früh schlafen zu gehen."}],
   note:"💡 Vergleich: ように なる = wurde so (Veränderung) / ように している = mache es so (bewusste Gewohnheit)."},
  {l:36, t:"V<ruby>辞書<rt>じしょ</rt></ruby> / V<ruby>ない<rt></rt></ruby> + ように、…", de:"damit / um zu … (Ziel)",
   rule:"Drückt ein angestrebtes Ziel aus, das man nicht direkt durch Willen kontrolliert (Können, Verstehen, Vermeiden). Anders als ために (direktes aktives Ziel, L42).",
   build:[{form:"positiv (Können)",verb:"V<sub>辞書/可能</sub> + ように",de:"damit man V kann"},{form:"negativ (Vermeiden)",verb:"V<sub>ない</sub> + ように",de:"damit nicht V"},{form:"vs. ために (L42)",verb:"V<sub>辞書</sub> + ために",de:"um aktiv V zu erreichen (steuerbar)"}],
   pattern:{slots:[{text:"Ziel-V",role:"verb",label:"damit V"},{text:"ように、",role:"actor"},{text:"Mittel/Handlung",role:"verb",label:"V₂ tun"}],gloss:"»Damit [Ziel] (kann / nicht passiert), tue ich [Mittel].« — Ziel ist nicht-willentlich (Können, Vermeiden, Verstehen)."},
   ex:[{jp:"<ruby>後<rt>うし</rt></ruby>ろの <ruby>人<rt>ひと</rt></ruby>が <ruby>聞<rt>き</rt></ruby>こえるように、<ruby>大<rt>おお</rt></ruby>きな <ruby>声<rt>こえ</rt></ruby>で <ruby>話<rt>はな</rt></ruby>します。",de:"Damit auch hinten alle hören können, spreche ich laut."},{jp:"<ruby>風邪<rt>かぜ</rt></ruby>を ひかないように、<ruby>気<rt>き</rt></ruby>を つけて ください。",de:"Pass auf, dass du dich nicht erkältest."},{jp:"<ruby>忘<rt>わす</rt></ruby>れないように、メモを します。",de:"Damit ich es nicht vergesse, mache ich mir eine Notiz."}],
   note:"💡 Faustregel: Bei Können/Verstehen/Vermeiden → ように (nicht-willkürlich). Bei aktiv-bewussten Zielen → ために (L42)."},
  {l:36, t:"N₁ とか N₂ とか", de:"zum Beispiel N₁ oder N₂ (Aufzählung)",
   rule:"Nicht-erschöpfende Aufzählung von Beispielen. Ähnlich wie や, aber informeller und macht klarer, dass es nur Beispiele sind. Kann auch Verben verbinden.",
   build:[{form:"Nomen",verb:"N₁ とか N₂ とか",de:"z.B. N₁ oder N₂"},{form:"Verb (Plain)",verb:"V₁ とか V₂ とか",de:"z.B. V₁ oder V₂"},{form:"vs. や",verb:"や = etwas formeller",de:"とか = lockerer"},{form:"vs. と",verb:"と = vollständige Liste",de:"とか = nur Beispiele"}],
   pattern:{slots:[{text:"N₁/V₁",role:"obj",label:"Beispiel 1"},{text:"とか",role:"actor"},{text:"N₂/V₂",role:"obj",label:"Beispiel 2"},{text:"とか …",role:"actor"}],gloss:"»Z.B. [N₁], [N₂] und so weiter.« — die Liste ist offen, es gibt mehr."},
   ex:[{jp:"<ruby>週末<rt>しゅうまつ</rt></ruby>は <ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>るとか <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>むとか して います。",de:"Am Wochenende mache ich z.B. Filme schauen oder lesen."},{jp:"すしとか てんぷらとか、<ruby>日本料理<rt>にほんりょうり</rt></ruby>が <ruby>好<rt>す</rt></ruby>きです。",de:"Ich mag japanisches Essen, z.B. Sushi oder Tempura."},{jp:"<ruby>赤<rt>あか</rt></ruby>とか <ruby>青<rt>あお</rt></ruby>とか、<ruby>明<rt>あか</rt></ruby>るい <ruby>色<rt>いろ</rt></ruby>が いいです。",de:"Helle Farben wie Rot oder Blau gefallen mir."}],
   note:"💡 Reihenfolge der Aufzählungs-Marker: と (vollständig) > や (mit »etc.« implizit) > とか (lockerste, »so was wie«)."},
  {l:37, t:"<ruby>受身形<rt>うけみけい</rt></ruby> (Passiv-Form) — Bildung", de:"Passivform der Verben",
   rule:"Drückt aus, dass jemand/etwas von einer Handlung BETROFFEN ist. Gruppe I: u→a + れる. Gruppe II: る→られる. Unregelmäßig: する→される、来る→こられる.",
   build:[{form:"Gr. I: u → a + れる",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>かれる",de:"geschrieben werden"},{form:"Gr. I",verb:"<ruby>呼<rt>よ</rt></ruby>ぶ → <ruby>呼<rt>よ</rt></ruby>ばれる",de:"gerufen werden"},{form:"Gr. I (★ う→われる!)",verb:"<ruby>言<rt>い</rt></ruby>う → <ruby>言<rt>い</rt></ruby>われる",de:"gesagt werden"},{form:"Gr. II: る → られる",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べられる",de:"gegessen werden"},{form:"Gr. II",verb:"<ruby>見<rt>み</rt></ruby>る → <ruby>見<rt>み</rt></ruby>られる",de:"gesehen werden"},{form:"Unregelmäßig",verb:"する → される / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>られる",de:""}],
   pattern:{slots:[{text:"V-Passiv (Form)",role:"verb",label:"reine Bildung"}],gloss:"Hier nur die Bildungsregel — wie das Passiv im Satz funktioniert, siehe nächste Karten (direktes Passiv, Leid-Passiv, Sachen-Passiv)."},
   ex:[{jp:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>かれる",de:"schreiben → geschrieben werden"},{jp:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べられる",de:"essen → gegessen werden"},{jp:"<ruby>誘<rt>さそ</rt></ruby>う → <ruby>誘<rt>さそ</rt></ruby>われる",de:"einladen → eingeladen werden"}],
   note:"⚠️ Gr. II Passiv (食べられる) ist IDENTISCH mit Potential (L27) und respektvollem Keigo (L49) — Kontext entscheidet! 💡 う-Verben: bei う→われる NICHT う→あれる."},
  {l:37, t:"P₁ は P₂ に V<ruby>受身<rt>うけみ</rt></ruby> (direktes Passiv)", de:"P₁ wird von P₂ … (direkt betroffen)",
   rule:"Direktes Passiv: P₁ (Thema/betroffene Person) wird durch die Handlung von P₂ (Täter) beeinflusst. Täter mit に markiert. Häufig bei Gefühlen wie gelobt/geschimpft/eingeladen werden.",
   build:[{form:"Form",verb:"V<sub>他</sub> → V<sub>受身</sub>",de:"siehe Bildungs-Karte"},{form:"Aktiv",verb:"<ruby>先生<rt>せんせい</rt></ruby>は <ruby>私<rt>わたし</rt></ruby>を <ruby>褒<rt>ほ</rt></ruby>めました",de:"Lehrer lobte mich"},{form:"Passiv",verb:"<ruby>私<rt>わたし</rt></ruby>は <ruby>先生<rt>せんせい</rt></ruby>に <ruby>褒<rt>ほ</rt></ruby>められました",de:"ich wurde vom Lehrer gelobt"}],
   pattern:{slots:[{text:"P₁",role:"subj",label:"betroffen"},{text:"は",role:"plain"},{text:"P₂",role:"actor",label:"Täter"},{text:"に",role:"plain",label:"von"},{text:"V-Passiv",role:"verb"}],gloss:"»[P₁] wird von [P₂] [V].« — der Täter steht mit に (NICHT で oder から!), die betroffene Person ist Subjekt."},
   ex:[{jp:"<ruby>私<rt>わたし</rt></ruby>は <ruby>先生<rt>せんせい</rt></ruby>に <ruby>褒<rt>ほ</rt></ruby>められました。",de:"Ich wurde vom Lehrer gelobt."},{jp:"<ruby>子供<rt>こども</rt></ruby>のとき、よく <ruby>父<rt>ちち</rt></ruby>に <ruby>叱<rt>しか</rt></ruby>られました。",de:"Als Kind wurde ich oft von meinem Vater geschimpft."},{jp:"<ruby>友達<rt>ともだち</rt></ruby>に <ruby>結婚式<rt>けっこんしき</rt></ruby>に <ruby>招待<rt>しょうたい</rt></ruby>されました。",de:"Ich wurde von einem Freund zur Hochzeit eingeladen."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は みんなに <ruby>愛<rt>あい</rt></ruby>されて います。",de:"Er wird von allen geliebt."}],
   note:"⚠️ Im Deutschen sagt man »von« — im Japanischen steht hier zwingend に (nicht から oder で)."},
  {l:37, t:"P₁ は P₂ に N を V<ruby>受身<rt>うけみ</rt></ruby> (Leid-Passiv)", de:"Jemand hat mir … (zum Leidwesen)",
   rule:"»Leid-Passiv« (迷惑の受身): P₁ leidet darunter, dass P₂ mit N etwas getan hat. N ist oft im Besitz von P₁. Auch bei intransitiven Verben möglich. Negative Stimmung!",
   build:[{form:"Transitiv (Besitz weg)",verb:"P₁ は P₂ に N<sub>(Besitz)</sub> を V<sub>受身</sub>",de:"jmd. nahm/zerstörte mein N"},{form:"Beispiel",verb:"<ruby>私<rt>わたし</rt></ruby>は どろぼうに かばんを <ruby>盗<rt>ぬす</rt></ruby>まれました",de:"mir wurde die Tasche gestohlen"},{form:"Intransitiv (Leid)",verb:"P₁ は P₂ に V<sub>受身</sub>",de:"jmd. tat mir was an"},{form:"Beispiel",verb:"<ruby>雨<rt>あめ</rt></ruby>に <ruby>降<rt>ふ</rt></ruby>られました",de:"vom Regen erwischt"}],
   pattern:{slots:[{text:"P₁",role:"subj",label:"Leidtragender"},{text:"は",role:"plain"},{text:"P₂",role:"actor",label:"Verursacher"},{text:"に",role:"plain"},{text:"(Besitz を)",role:"obj",label:"optional"},{text:"V-Passiv",role:"verb",label:"Leid"}],gloss:"»P₁ wird (zu seinem Leid) durch P₂s [V] betroffen.« — auch bei intransitiven Verben (im Deutschen untypisch!)."},
   ex:[{jp:"どろぼうに かばんを <ruby>盗<rt>ぬす</rt></ruby>まれました。",de:"Mir wurde die Tasche von einem Dieb gestohlen."},{jp:"<ruby>弟<rt>おとうと</rt></ruby>に ケーキを <ruby>食<rt>た</rt></ruby>べられました。",de:"Mein kleiner Bruder hat mir den Kuchen weggegessen."},{jp:"<ruby>子供<rt>こども</rt></ruby>に <ruby>泣<rt>な</rt></ruby>かれて、<ruby>寝<rt>ね</rt></ruby>られませんでした。",de:"Das Kind hat geweint und ich konnte nicht schlafen."},{jp:"<ruby>雨<rt>あめ</rt></ruby>に <ruby>降<rt>ふ</rt></ruby>られて、<ruby>風邪<rt>かぜ</rt></ruby>を ひきました。",de:"Ich wurde vom Regen erwischt und habe mich erkältet."}],
   note:"💡 Im Deutschen gibt es das so nicht — wir sagen aktiv: »Der Regen erwischte mich«. Auf Japanisch macht das Passiv den Leid-Aspekt klar."},
  {l:37, t:"N(Ding) が/は V<ruby>受身<rt>うけみ</rt></ruby> (Sachen-Passiv)", de:"… wird … gemacht / produziert / veranstaltet",
   rule:"Sachen-Passiv: Subjekt ist eine SACHE (kein Mensch). Oft ohne Täter-Angabe. Typisch für Veranstaltungen, Produktion, Sprachen, berühmte Werke.",
   build:[{form:"ohne Täter",verb:"N が/は V<sub>受身</sub>",de:"N wird V"},{form:"mit Schöpfer",verb:"N₁ は N₂ に よって V<sub>受身</sub>",de:"siehe nächste Karte"},{form:"mit Material",verb:"N から/で <ruby>作<rt>つく</rt></ruby>られる",de:"aus Material gemacht"}],
   pattern:{slots:[{text:"N (Sache)",role:"subj",label:"Ding"},{text:"が/は",role:"plain"},{text:"(Ort で)",role:"place",label:"optional"},{text:"V-Passiv",role:"verb"}],gloss:"»[N] wird (an Ort) [V].« — Täter wird oft weggelassen, weil unwichtig oder allgemein."},
   ex:[{jp:"<ruby>東京<rt>とうきょう</rt></ruby>で オリンピックが <ruby>行<rt>おこな</rt></ruby>われました。",de:"In Tokyo wurden die Olympischen Spiele veranstaltet."},{jp:"この <ruby>本<rt>ほん</rt></ruby>は <ruby>世界中<rt>せかいじゅう</rt></ruby>で <ruby>読<rt>よ</rt></ruby>まれて います。",de:"Dieses Buch wird weltweit gelesen."},{jp:"<ruby>日本<rt>にほん</rt></ruby>の <ruby>車<rt>くるま</rt></ruby>は <ruby>世界<rt>せかい</rt></ruby>に <ruby>輸出<rt>ゆしゅつ</rt></ruby>されて います。",de:"Japanische Autos werden in die Welt exportiert."},{jp:"<ruby>会議<rt>かいぎ</rt></ruby>は <ruby>来週<rt>らいしゅう</rt></ruby> <ruby>開<rt>ひら</rt></ruby>かれます。",de:"Die Besprechung wird nächste Woche abgehalten."}],
   note:"💡 Klingt für deutsche Ohren oft ungewohnt — im Japanischen aber sehr natürlich für allgemeine Aussagen über Veranstaltungen, Produkte, Sprachen."},
  {l:37, t:"N は P に よって V<ruby>受身<rt>うけみ</rt></ruby>", de:"N wurde von P erfunden/geschaffen",
   rule:"Mit によって (statt nur に) — wird bei Erfindern, Künstlern, Autoren, historischen Figuren verwendet. Klingt formeller und betont die Urheberschaft.",
   build:[{form:"Anschluss",verb:"N₁ は P に よって V<sub>受身</sub>",de:"N₁ wurde von P V"},{form:"vs. に (einfach)",verb:"persönliche Handlung (lobte, schimpfte)",de:""},{form:"によって verwendet bei",verb:"Erfindung / Werk / Bau / Entdeckung",de:""}],
   pattern:{slots:[{text:"N (Werk)",role:"subj",label:"Werk"},{text:"は",role:"plain"},{text:"Schöpfer",role:"actor",label:"Urheber"},{text:"に よって",role:"plain",label:"durch"},{text:"V-Passiv",role:"verb",label:"erschaffen"}],gloss:"»[Werk] wurde durch [Urheber] [V].« — formelle Konstruktion für Kunst, Erfindungen, historische Bauten."},
   ex:[{jp:"<ruby>電話<rt>でんわ</rt></ruby>は ベルに よって <ruby>発明<rt>はつめい</rt></ruby>されました。",de:"Das Telefon wurde von Bell erfunden."},{jp:"『<ruby>坊<rt>ぼ</rt></ruby>っちゃん』は <ruby>夏目漱石<rt>なつめそうせき</rt></ruby>に よって <ruby>書<rt>か</rt></ruby>かれました。",de:"»Botchan« wurde von Natsume Soseki geschrieben."},{jp:"この <ruby>絵<rt>え</rt></ruby>は ピカソに よって <ruby>描<rt>か</rt></ruby>かれました。",de:"Dieses Bild wurde von Picasso gemalt."},{jp:"<ruby>法隆寺<rt>ほうりゅうじ</rt></ruby>は <ruby>聖徳太子<rt>しょうとくたいし</rt></ruby>に よって <ruby>建<rt>た</rt></ruby>てられました。",de:"Der Horyu-ji Tempel wurde von Prinz Shotoku erbaut."}],
   note:"💡 Faustregel: bei Erfindungen, Kunstwerken, Bauten, historischen Leistungen → によって. Bei alltäglichen Handlungen (lobte, schimpfte) → einfaches に."},
  {l:37, t:"N から / N で <ruby>作<rt>つく</rt></ruby>ります", de:"aus N wird … gemacht (Material)",
   rule:"Material-/Rohstoffangabe: から = chemische Umwandlung (Material nicht mehr erkennbar). で = Material bleibt sichtbar erkennbar. Oft im Passiv: 作られています.",
   build:[{form:"から (umgewandelt)",verb:"N<sub>1</sub> から N<sub>2</sub> を <ruby>作<rt>つく</rt></ruby>ります",de:"unsichtbar (chem.)"},{form:"Beispiel",verb:"<ruby>米<rt>こめ</rt></ruby>から <ruby>酒<rt>さけ</rt></ruby>を <ruby>作<rt>つく</rt></ruby>ります",de:"Sake aus Reis (Reis weg)"},{form:"で (sichtbar)",verb:"N<sub>1</sub> で N<sub>2</sub> を <ruby>作<rt>つく</rt></ruby>ります",de:"sichtbar geformt"},{form:"Beispiel",verb:"<ruby>木<rt>き</rt></ruby>で いすを <ruby>作<rt>つく</rt></ruby>ります",de:"Stuhl aus Holz (Holz da)"},{form:"Passiv: 作られている",verb:"N<sub>1</sub> から/で <ruby>作<rt>つく</rt></ruby>られて いる",de:"wird gemacht aus"}],
   pattern:{slots:[{text:"Produkt",role:"subj",label:"was"},{text:"は",role:"plain"},{text:"Material",role:"obj",label:"Stoff"},{text:"から / で",role:"actor",label:"chem./sichtbar"},{text:"<ruby>作<rt>つく</rt></ruby>られます",role:"verb"}],gloss:"»[Produkt] wird aus [Material] hergestellt.« — から bei chemischer Umwandlung, で wenn Material noch erkennbar."},
   ex:[{jp:"<ruby>酒<rt>さけ</rt></ruby>は <ruby>米<rt>こめ</rt></ruby>から <ruby>作<rt>つく</rt></ruby>られます。",de:"Sake wird aus Reis hergestellt. [Reis nicht mehr sichtbar]"},{jp:"ワインは ぶどうから <ruby>作<rt>つく</rt></ruby>られます。",de:"Wein wird aus Trauben hergestellt."},{jp:"この テーブルは <ruby>木<rt>き</rt></ruby>で <ruby>作<rt>つく</rt></ruby>られて います。",de:"Dieser Tisch ist aus Holz gemacht. [Holz sichtbar]"},{jp:"この <ruby>家<rt>いえ</rt></ruby>は <ruby>石<rt>いし</rt></ruby>で <ruby>作<rt>つく</rt></ruby>られて います。",de:"Dieses Haus ist aus Stein gebaut."}],
   note:"💡 Merkregel: から = unsichtbar (chem. verändert) / で = sichtbar (nur geformt)."},
  {l:38, t:"V<ruby>普通形<rt>ふつうけい</rt></ruby> + の (Nominalisierung)", de:"Verb wird zu Substantiv mit の",
   rule:"の macht aus einem Verbal-Satz ein Substantiv (»die Tatsache/das Tun«). Grundbaustein für alle L38-Strukturen (のは・のが・のを). こと geht auch, ist aber abstrakter/formeller.",
   build:[{form:"V<sub>辞書</sub> + の",verb:"<ruby>食<rt>た</rt></ruby>べるの",de:"das Essen / dass man isst"},{form:"V<sub>た</sub> + の",verb:"<ruby>食<rt>た</rt></ruby>べたの",de:"dass man gegessen hat"},{form:"V<sub>ない</sub> + の",verb:"<ruby>食<rt>た</rt></ruby>べないの",de:"dass man nicht isst"},{form:"こと-Variante",verb:"<ruby>食<rt>た</rt></ruby>べること",de:"das Essen (formeller, abstrakter)"}],
   pattern:{slots:[{text:"V-Plain",role:"verb"},{text:"+ の",role:"actor",label:"Substantiv-Marker"}],gloss:"の/こと verwandeln einen Verbal-Inhalt in ein Substantiv, das man dann mit が/は/を im Satz weiter benutzen kann."},
   ex:[{jp:"<ruby>絵<rt>え</rt></ruby>を <ruby>描<rt>か</rt></ruby>く<b>の</b>が <ruby>好<rt>す</rt></ruby>きです。",de:"Ich mag es, Bilder zu malen."},{jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>運動<rt>うんどう</rt></ruby>する<b>の</b>は <ruby>大切<rt>たいせつ</rt></ruby>です。",de:"Täglich Sport zu machen ist wichtig."},{jp:"<ruby>日本語<rt>にほんご</rt></ruby>を <ruby>勉強<rt>べんきょう</rt></ruby>する<b>の</b>は <ruby>難<rt>むずか</rt></ruby>しいです。",de:"Japanisch zu lernen ist schwierig."}],
   note:"💡 の = konkret, gefühlsnah (zum Erleben). こと = abstrakt, formell (zur Beschreibung). Bei Empfindungen meist の."},
  {l:38, t:"V の は Adj です", de:"Es ist [Adj], … zu tun",
   rule:"Verb wird mit の zum Substantiv. »… zu tun ist [Adj]«. Adjektive wie 楽しい, 難しい, 大変, 大切, つらい.",
   build:[{form:"Anschluss",verb:"V<sub>辞書</sub> + のは + Adj です",de:"V zu tun ist Adj"},{form:"い-Adj",verb:"<ruby>楽<rt>たの</rt></ruby>しいです / <ruby>難<rt>むずか</rt></ruby>しいです",de:"toll / schwer"},{form:"な-Adj",verb:"<ruby>大切<rt>たいせつ</rt></ruby>です / <ruby>大変<rt>たいへん</rt></ruby>です",de:"wichtig / mühsam"}],
   pattern:{slots:[{text:"V-辞書",role:"verb",label:"Tätigkeit"},{text:"のは",role:"actor",label:"das ... ist"},{text:"Adj",role:"obj",label:"Eigenschaft"},{text:"です",role:"plain"}],gloss:"»[V tun] ist [Adj].« — die Tätigkeit selbst wird charakterisiert."},
   ex:[{jp:"<ruby>絵<rt>え</rt></ruby>を <ruby>描<rt>か</rt></ruby>く<b>のは</b> <ruby>楽<rt>たの</rt></ruby>しいです。",de:"Bilder zu malen macht Spaß."},{jp:"<ruby>朝<rt>あさ</rt></ruby> <ruby>早<rt>はや</rt></ruby>く <ruby>起<rt>お</rt></ruby>きる<b>のは</b> つらいです。",de:"Früh aufzustehen ist hart."},{jp:"<ruby>一人<rt>ひとり</rt></ruby>で <ruby>住<rt>す</rt></ruby>む<b>のは</b> <ruby>寂<rt>さび</rt></ruby>しいです。",de:"Alleine zu wohnen ist einsam."}],
   note:"💡 Bei Empfindungen wie 楽しい, つらい, <ruby>寂<rt>さび</rt></ruby>しい meist の (nicht こと), weil das Erleben konkret ist."},
  {l:38, t:"V の が <ruby>好<rt>す</rt></ruby>き/<ruby>上手<rt>じょうず</rt></ruby>です", de:"Ich mag/kann gut … tun",
   rule:"Wenn ein Verb das Objekt der Vorliebe/Fähigkeit ist, wird es mit の nominalisiert + が. Häufig mit 好き・嫌い・上手・下手・得意・苦手.",
   build:[{form:"Vorliebe",verb:"V<sub>辞書</sub> + のが <ruby>好<rt>す</rt></ruby>き/<ruby>嫌<rt>きら</rt></ruby>いです",de:"mag / mag nicht V"},{form:"Fähigkeit",verb:"V<sub>辞書</sub> + のが <ruby>上手<rt>じょうず</rt></ruby>/<ruby>下手<rt>へた</rt></ruby>です",de:"gut/schlecht in V"},{form:"Stärke",verb:"V<sub>辞書</sub> + のが <ruby>得意<rt>とくい</rt></ruby>/<ruby>苦手<rt>にがて</rt></ruby>です",de:"Stärke/Schwäche"},{form:"⚠ Achtung",verb:"のを wäre FALSCH bei 好き/上手!",de:"好き braucht が, nicht を"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V-辞書",role:"verb",label:"Tätigkeit"},{text:"のが",role:"actor",label:"das ist"},{text:"好き/上手 etc.",role:"obj",label:"Vorliebe"},{text:"です",role:"plain"}],gloss:"»[Subjekt] mag/kann [V tun].« — die Vorliebe braucht zwingend が, niemals を."},
   ex:[{jp:"<ruby>歌<rt>うた</rt></ruby>を <ruby>歌<rt>うた</rt></ruby>う<b>のが</b> <ruby>好<rt>す</rt></ruby>きです。",de:"Ich singe gerne."},{jp:"ミラーさんは <ruby>料理<rt>りょうり</rt></ruby>を <ruby>作<rt>つく</rt></ruby>る<b>のが</b> <ruby>上手<rt>じょうず</rt></ruby>です。",de:"Herr Miller kann gut kochen."},{jp:"<ruby>泳<rt>およ</rt></ruby>ぐ<b>のが</b> <ruby>得意<rt>とくい</rt></ruby>です。",de:"Ich bin gut im Schwimmen."},{jp:"<ruby>話<rt>はな</rt></ruby>す<b>のが</b> <ruby>苦手<rt>にがて</rt></ruby>です。",de:"Ich bin schwach im Reden."}],
   note:"⚠️ Wichtige Partikel: 好き/嫌い/上手/下手 brauchen alle が (NICHT を)! のが ist Pflicht — のを wäre falsch."},
  {l:38, t:"V の を <ruby>忘<rt>わす</rt></ruby>れました", de:"Ich habe vergessen zu …",
   rule:"の nominalisiert das Verb als Objekt von Aktionsverben wie 忘れる (vergessen), 止める (aufhören), 見る (sehen), 聞く (hören), 待つ (warten).",
   build:[{form:"Anschluss",verb:"V<sub>辞書</sub> + のを + V₂",de:"V (zu tun) V₂"},{form:"typische V₂",verb:"<ruby>忘<rt>わす</rt></ruby>れる, <ruby>止<rt>や</rt></ruby>める, <ruby>見<rt>み</rt></ruby>る",de:"vergessen, aufhören, sehen"},{form:"weitere V₂",verb:"<ruby>聞<rt>き</rt></ruby>く, <ruby>待<rt>ま</rt></ruby>つ, <ruby>手伝<rt>てつだ</rt></ruby>う",de:"hören, warten, helfen"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V₁-辞書",role:"verb",label:"Tätigkeit"},{text:"のを",role:"actor",label:"als Objekt"},{text:"V₂",role:"verb",label:"Hauptverb"}],gloss:"»[V₁ zu tun] [V₂].« — die Tätigkeit V₁ wird zum Objekt der Handlung V₂."},
   ex:[{jp:"<ruby>宿題<rt>しゅくだい</rt></ruby>を する<b>のを</b> <ruby>忘<rt>わす</rt></ruby>れました。",de:"Ich habe vergessen, die Hausaufgaben zu machen."},{jp:"タバコを <ruby>吸<rt>す</rt></ruby>う<b>のを</b> <ruby>止<rt>や</rt></ruby>めました。",de:"Ich habe aufgehört zu rauchen."},{jp:"<ruby>子供<rt>こども</rt></ruby>が <ruby>遊<rt>あそ</rt></ruby>んで いる<b>のを</b> <ruby>見<rt>み</rt></ruby>ました。",de:"Ich habe die spielenden Kinder gesehen."},{jp:"<ruby>彼<rt>かれ</rt></ruby>が <ruby>来<rt>く</rt></ruby>る<b>のを</b> <ruby>待<rt>ま</rt></ruby>って います。",de:"Ich warte darauf, dass er kommt."}],
   note:"💡 Hier: のを — die Aktion ist DIREKTES Objekt von vergessen/aufhören/sehen/hören etc."},
  {l:38, t:"V の を <ruby>知<rt>し</rt></ruby>って いますか", de:"Weißt du, dass …?",
   rule:"Nominalisiertes Verb + を + 知っていますか = »Weißt du von … ?« / »Kennst du die Tatsache, dass …?«. Verneinung: 知りません (NICHT 知って いません — siehe L15).",
   build:[{form:"Anschluss",verb:"V<sub>普通形</sub> + のを <ruby>知<rt>し</rt></ruby>って いますか",de:"weißt du, dass V?"},{form:"Antwort: ja",verb:"はい、<ruby>知<rt>し</rt></ruby>って います",de:"ja, weiß ich"},{form:"Antwort: nein",verb:"いいえ、<ruby>知<rt>し</rt></ruby>りません(でした)",de:"nein, weiß/wusste ich nicht"},{form:"vs. のを + V₂ (Karte oben)",verb:"hier: V₂ = <ruby>知<rt>し</rt></ruby>っている",de:"Spezialfall mit Wissen"}],
   pattern:{slots:[{text:"(Person) が",role:"actor",label:"wer"},{text:"V-Plain",role:"verb",label:"Tatsache"},{text:"のを",role:"plain"},{text:"<ruby>知<rt>し</rt></ruby>って いますか",role:"verb",label:"weißt du?"}],gloss:"»Weißt du, dass [Tatsache]?« — Frage nach einer Information über ein Ereignis."},
   ex:[{jp:"ミラーさんが <ruby>国<rt>くに</rt></ruby>へ <ruby>帰<rt>かえ</rt></ruby>った<b>のを</b> <ruby>知<rt>し</rt></ruby>って いますか。",de:"Weißt du, dass Herr Miller in sein Heimatland zurückgekehrt ist?"},{jp:"<ruby>山田<rt>やまだ</rt></ruby>さんが <ruby>結婚<rt>けっこん</rt></ruby>した<b>のを</b> <ruby>知<rt>し</rt></ruby>って いますか。",de:"Wusstest du, dass Frau Yamada geheiratet hat?"},{jp:"いいえ、<ruby>知<rt>し</rt></ruby>りませんでした。",de:"Nein, das wusste ich nicht."}],
   note:"💡 のを 知っています = Wissen über ein Ereignis. Verneinung: 知りません (nicht 知っていません!) — gilt nur für 知る, anderer Spezialfall."},
  {l:38, t:"〜のは N です (Hervorhebung)", de:"Es war N, der/die … (Hervorhebung)",
   rule:"Hervorhebung eines bestimmten Details. Struktur: »was-gemacht の は wer/wo/wann です«. Beantwortet eine »Wer/wo/wann?«-Frage. Im Deutschen oft mit »Es war …, der/wo/wann …«.",
   build:[{form:"Wer war es?",verb:"〜のは [<ruby>誰<rt>だれ</rt></ruby>] です",de:"Es war [Person]"},{form:"Wo war es?",verb:"〜のは [<ruby>場所<rt>ばしょ</rt></ruby>] です",de:"Es war in [Ort]"},{form:"Wann war es?",verb:"〜のは [<ruby>時<rt>とき</rt></ruby>] です",de:"Es war [Zeit]"}],
   pattern:{slots:[{text:"V-Plain",role:"verb",label:"Aktion"},{text:"のは",role:"actor",label:"…dabei"},{text:"hervorgehobenes Element",role:"obj",label:"das war"},{text:"です",role:"plain"}],gloss:"Erst die Aktion (mit のは), dann am Ende das hervorgehobene Element + です. Antwortet auf »Wer/wo/wann?«."},
   ex:[{jp:"<ruby>絵<rt>え</rt></ruby>を <ruby>描<rt>か</rt></ruby>いた<b>のは</b> <ruby>子供<rt>こども</rt></ruby>です。",de:"Es war ein Kind, das das Bild gemalt hat."},{jp:"これを <ruby>買<rt>か</rt></ruby>った<b>のは</b> <ruby>京都<rt>きょうと</rt></ruby>です。",de:"Gekauft habe ich es in Kyoto."},{jp:"<ruby>彼<rt>かれ</rt></ruby>に <ruby>会<rt>あ</rt></ruby>った<b>のは</b> <ruby>昨日<rt>きのう</rt></ruby>です。",de:"Es war gestern, dass ich ihn getroffen habe."}],
   note:"💡 Sehr starke Hervorhebung — beantwortet eine konkrete Frage. Klingt im Deutschen oft etwas hochgestelzt, im Japanischen aber natürlich."},
  {l:38, t:"とき + も / や / の / に etc.", de:"wenn / als (mit verschiedenen Partikeln)",
   rule:"とき (»Zeit/wenn«) wird durch Partikeln modifiziert: ときも (auch wenn), ときや (Aufzählung), ときの (Attribut), ときに (Zeitpunkt). Sehr flexibel einsetzbar.",
   build:[{form:"とき に",verb:"V<sub>辞書/た</sub> + ときに",de:"als/wenn (Zeitpunkt)"},{form:"とき も",verb:"〜とき<b>も</b>",de:"auch wenn"},{form:"とき の + N",verb:"〜とき<b>の</b> N",de:"das N von damals"},{form:"とき や",verb:"〜とき<b>や</b>〜とき (など)",de:"z.B. wenn …, wenn …"},{form:"とき は",verb:"〜とき<b>は</b>",de:"wenn (kontrastiv/themat.)"}],
   pattern:{slots:[[{text:"V/Adj/N",role:"verb",label:"Inhalt"},{text:"とき",role:"actor",label:"Zeit"},{text:"+ Partikel",role:"plain",label:"Funktion"},{text:"…",role:"verb"}]],gloss:"とき allein = »wenn/als«. Plus Partikel: ときに (Punkt), ときも (auch), ときの (attributiv), ときは (kontrastiv)."},
   ex:[{jp:"<ruby>子供<rt>こども</rt></ruby>の <b>ときの</b> <ruby>写真<rt>しゃしん</rt></ruby>です。",de:"Das ist ein Foto aus meiner Kindheit."},{jp:"<ruby>暇<rt>ひま</rt></ruby>な <b>ときに</b> <ruby>映画<rt>えいが</rt></ruby>を <ruby>見<rt>み</rt></ruby>ます。",de:"Ich schaue Filme, wenn ich frei habe."},{jp:"<ruby>疲<rt>つか</rt></ruby>れた <b>ときも</b>、<ruby>運動<rt>うんどう</rt></ruby>を します。",de:"Auch wenn ich müde bin, mache ich Sport."},{jp:"<ruby>頭<rt>あたま</rt></ruby>が <ruby>痛<rt>いた</rt></ruby>い <b>ときは</b>、この <ruby>薬<rt>くすり</rt></ruby>を <ruby>飲<rt>の</rt></ruby>みます。",de:"Wenn ich Kopfschmerzen habe, nehme ich diese Tablette."}],
   note:"💡 Anschluss vor とき: V辞書/V た + とき. い-Adj い + とき. な-Adj な + とき. N の + とき."},
  {l:39, t:"V て / Adj くて, … (Grund-Verbindung)", de:"weil … (Grund mit て-Form)",
   rule:"Die て-Form drückt einen Grund aus, wenn die Folge ein Gefühl, eine Empfindung oder ein nicht-willentlicher Zustand ist (überrascht sein, müde, krank). ⚠️ NICHT für Bitten/Befehle/Vorschläge!",
   build:[{form:"Verb",verb:"V<sub>テ</sub>",de:"<ruby>聞<rt>き</rt></ruby>いて = weil ich hörte"},{form:"い-Adj",verb:"い-Adj い → くて",de:"<ruby>寒<rt>さむ</rt></ruby>くて = weil kalt"},{form:"な-Adj",verb:"な-Adj + で",de:"<ruby>静<rt>しず</rt></ruby>かで = weil still"},{form:"Nomen",verb:"N + で",de:"<ruby>病気<rt>びょうき</rt></ruby>で = weil krank"},{form:"Negation",verb:"V<sub>なくて</sub>",de:"<ruby>分<rt>わ</rt></ruby>からなくて = weil nicht verstanden"}],
   pattern:{slots:[{text:"Grund",role:"cond",label:"Ursache"},{text:"-て / -くて / -で",role:"actor",label:"weil"},{text:"、",role:"plain"},{text:"Folge (Gefühl)",role:"verb",label:"emotional/Zustand"}],gloss:"»Weil [Grund], [Gefühl/Zustand].« — Folge ist NICHT etwas, was man aktiv tut."},
   ex:[{jp:"その ニュースを <ruby>聞<rt>き</rt></ruby>いて、びっくりしました。",de:"Ich war überrascht, weil ich diese Nachricht hörte."},{jp:"<ruby>道<rt>みち</rt></ruby>が <ruby>込<rt>こ</rt></ruby>んで いて、<ruby>遅<rt>おく</rt></ruby>れました。",de:"Weil die Straße verstopft war, bin ich zu spät."},{jp:"<ruby>子供<rt>こども</rt></ruby>が <ruby>病気<rt>びょうき</rt></ruby>で、<ruby>会社<rt>かいしゃ</rt></ruby>を <ruby>休<rt>やす</rt></ruby>みました。",de:"Weil mein Kind krank war, blieb ich von der Arbeit weg."}],
   note:"⚠️ Die Folge darf KEIN Befehl, keine Bitte und kein Vorschlag sein! Falsch: ✗ <ruby>寒<rt>さむ</rt></ruby>くて、コートを <ruby>着<rt>き</rt></ruby>てください. Stattdessen から/ので nutzen."},
  {l:39, t:"〜ので、… (höflicher Grund)", de:"weil / da …",
   rule:"Begründung mit ので — höflicher und weicher als から. Klingt erklärend, weniger fordernd. Bei な-Adj/N: なので. Häufig in höflichen Bitten und Erklärungen.",
   build:[{form:"Verb/い-Adj",verb:"V<sub>普通形</sub>/い-Adj + ので",de:"weil V/Adj"},{form:"な-Adj",verb:"な-Adj + な + ので",de:"<ruby>元気<rt>げんき</rt></ruby>なので"},{form:"Nomen",verb:"N + な + ので",de:"<ruby>学生<rt>がくせい</rt></ruby>なので"},{form:"vs. から",verb:"から = direkter, von außen",de:"ので = weicher, sachlich"}],
   pattern:{slots:[{text:"Grund",role:"cond",label:"Erklärung"},{text:"ので、",role:"actor",label:"weil (höflich)"},{text:"Folge",role:"verb"}],gloss:"»Da [Grund], [Folge].« — höflicher als から, oft im Berufsalltag und in Bitten."},
   ex:[{jp:"<ruby>頭<rt>あたま</rt></ruby>が <ruby>痛<rt>いた</rt></ruby>いので、<ruby>早<rt>はや</rt></ruby>く <ruby>帰<rt>かえ</rt></ruby>っても いいですか。",de:"Da ich Kopfschmerzen habe, dürfte ich früher gehen?"},{jp:"<ruby>日曜日<rt>にちようび</rt></ruby>な<b>ので</b>、<ruby>銀行<rt>ぎんこう</rt></ruby>は <ruby>休<rt>やす</rt></ruby>みです。",de:"Weil Sonntag ist, hat die Bank zu."},{jp:"<ruby>道<rt>みち</rt></ruby>が <ruby>込<rt>こ</rt></ruby>んで いる<b>ので</b>、<ruby>電車<rt>でんしゃ</rt></ruby>で <ruby>行<rt>い</rt></ruby>きます。",de:"Da die Straße verstopft ist, fahre ich mit dem Zug."}],
   note:"💡 Faustregel: bei höflichen Bitten/Entschuldigungen/Erklärungen → ので. Bei direkten/starken Aussagen → から. ので klingt erklärend, から fordernd."},
  {l:39, t:"V て、…/Adj くて、… (positive Folge)", de:"weil … (mit Gefühl/Bewertung)",
   rule:"Sehr ähnlich zur Grund-Karte oben — speziell wenn die Folge eine Bewertung oder spontane Reaktion ist (gut, schlecht, gefreut, geweint).",
   build:[{form:"V<sub>テ</sub>",verb:"<ruby>会<rt>あ</rt></ruby>えて、うれしいです",de:"freue mich, dich zu treffen"},{form:"い-Adj-くて",verb:"<ruby>難<rt>むずか</rt></ruby>しくて、できません",de:"zu schwer, schaffe nicht"},{form:"な-Adj/N + で",verb:"<ruby>便利<rt>べんり</rt></ruby>で、たすかります",de:"praktisch, hilft mir"}],
   pattern:{slots:[{text:"Grund/Auslöser",role:"cond"},{text:"-て/-くて/-で",role:"actor",label:"weil"},{text:"、",role:"plain"},{text:"Bewertung/Gefühl",role:"verb"}],gloss:"»Weil [Grund], (fühle ich) [Bewertung].« — emotionale oder bewertende Reaktion."},
   ex:[{jp:"<ruby>家族<rt>かぞく</rt></ruby>に <ruby>会<rt>あ</rt></ruby>えて、うれしいです。",de:"Ich freue mich, meine Familie zu sehen."},{jp:"この <ruby>本<rt>ほん</rt></ruby>は <ruby>難<rt>むずか</rt></ruby>しくて、<ruby>分<rt>わ</rt></ruby>かりません。",de:"Dieses Buch ist (so) schwer, ich verstehe es nicht."},{jp:"<ruby>仕事<rt>しごと</rt></ruby>が <ruby>多<rt>おお</rt></ruby>くて、<ruby>大変<rt>たいへん</rt></ruby>です。",de:"Weil ich viel Arbeit habe, ist es mühsam."}],
   note:"💡 Subtype der て-Begründung: Folge ist eine Bewertung oder ein Gefühl. Klingt natürlich und alltagsnah."},
  {l:39, t:"V<ruby>ない<rt></rt></ruby>形 + なくて (Negation als Grund)", de:"weil nicht …",
   rule:"Verneinte Variante der Grund-て-Form: »weil ich nicht V getan habe«. Bei い-Adj: い→くなくて. Bei な-Adj/N: ではなくて / じゃなくて.",
   build:[{form:"Verb",verb:"V<sub>ない</sub> → V<sub>なくて</sub>",de:"<ruby>食<rt>た</rt></ruby>べなくて = weil nicht gegessen"},{form:"い-Adj",verb:"い → くなくて",de:"<ruby>高<rt>たか</rt></ruby>くなくて = weil nicht teuer"},{form:"な-Adj/N",verb:"+ じゃなくて / ではなくて",de:"<ruby>元気<rt>げんき</rt></ruby>じゃなくて = weil nicht gesund"},{form:"vs. ないで (L34)",verb:"V<sub>ない</sub> + で = ohne zu V",de:"andere Bedeutung!"}],
   pattern:{slots:[{text:"V-なくて",role:"cond",label:"weil nicht V"},{text:"、",role:"plain"},{text:"Folge (Gefühl)",role:"verb"}],gloss:"»Weil [V] nicht, [Folge].« — Verneinung als Grund. Wichtig: nicht mit ないで verwechseln."},
   ex:[{jp:"<ruby>何<rt>なに</rt></ruby>も <ruby>食<rt>た</rt></ruby>べなくて、おなかが すきました。",de:"Weil ich nichts gegessen habe, habe ich Hunger."},{jp:"<ruby>宿題<rt>しゅくだい</rt></ruby>が <ruby>分<rt>わ</rt></ruby>からなくて、<ruby>困<rt>こま</rt></ruby>って います。",de:"Weil ich die Hausaufgaben nicht verstehe, bin ich ratlos."},{jp:"バスが <ruby>来<rt>こ</rt></ruby>なくて、<ruby>遅<rt>おそ</rt></ruby>く なりました。",de:"Weil der Bus nicht kam, bin ich zu spät."}],
   note:"⚠️ ないで vs. なくて: ないで = ohne zu V (Begleithandlung). なくて = weil nicht V (Grund)."},
  {l:39, t:"V て / Adj くて 〜たいへんです", de:"… und so weiter — ist mühsam",
   rule:"Beschreibt eine Situation als Folge von mehreren Gründen, die zusammen mühsam/schwierig sind. Häufige Endungen: 大変です, 困ります, 疲れます.",
   build:[{form:"Anschluss",verb:"〜て / 〜くて + <ruby>大変<rt>たいへん</rt></ruby>です",de:"… ist mühsam"},{form:"weitere Folgen",verb:"<ruby>困<rt>こま</rt></ruby>る / <ruby>疲<rt>つか</rt></ruby>れる / <ruby>大<rt>おお</rt></ruby>きい",de:"ratlos / müde / groß"}],
   pattern:{slots:[{text:"Grund 1 -て",role:"cond",label:"Ursache"},{text:"Grund 2 -て",role:"cond",label:"+ Ursache"},{text:"<ruby>大変<rt>たいへん</rt></ruby>です/<ruby>困<rt>こま</rt></ruby>ります",role:"verb",label:"Konsequenz"}],gloss:"Mehrere Gründe per て gereiht → führen zu einer mühsamen/schwierigen Situation."},
   ex:[{jp:"<ruby>仕事<rt>しごと</rt></ruby>が <ruby>多<rt>おお</rt></ruby>くて、<ruby>休<rt>やす</rt></ruby>みも なくて、<ruby>大変<rt>たいへん</rt></ruby>です。",de:"Es ist mühsam, weil ich viel Arbeit und keine freien Tage habe."},{jp:"<ruby>道<rt>みち</rt></ruby>が せまくて、<ruby>車<rt>くるま</rt></ruby>が <ruby>多<rt>おお</rt></ruby>くて、<ruby>歩<rt>ある</rt></ruby>きにくいです。",de:"Die Straße ist eng und es sind viele Autos da, schlecht zum Laufen."}],
   note:"💡 Kombination aus mehreren Begründungen — sehr typisch für Beschwerden im Alltag."},
  {l:40, t:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + V Plain + か, …", de:"eingebettete Ja/Nein-Frage / Inhalt",
   rule:"Fragewort + Plain-Form + か wird in einen Satz eingebettet. Verben dahinter: 知っている, 分かる, 教える, 調べる, 聞く, 覚える.",
   build:[{form:"Anschluss",verb:"<ruby>疑問詞<rt>ぎもんし</rt></ruby> + Plain + か + V₂",de:"V₂ versucht/weiß was V"},{form:"typische V₂",verb:"<ruby>調<rt>しら</rt></ruby>べる, <ruby>知<rt>し</rt></ruby>る, <ruby>聞<rt>き</rt></ruby>く",de:"untersuchen, wissen, fragen"},{form:"weitere V₂",verb:"<ruby>覚<rt>おぼ</rt></ruby>える, <ruby>教<rt>おし</rt></ruby>える, <ruby>忘<rt>わす</rt></ruby>れる",de:"sich merken, beibringen, vergessen"}],
   pattern:{slots:[{text:"Fragewort",role:"cond",label:"何/誰/どこ"},{text:"Plain-Form",role:"verb"},{text:"か",role:"plain",label:"ob/was"},{text:"、 V₂",role:"verb",label:"Hauptverb"}],gloss:"»[Frage] [V₂].« — der ganze Fragesatz wird zum Inhalt eines Wissens-/Untersuchungsverbs."},
   ex:[{jp:"<ruby>会議<rt>かいぎ</rt></ruby>が <ruby>何時<rt>なんじ</rt></ruby>から <ruby>始<rt>はじ</rt></ruby>まる<b>か</b>、<ruby>調<rt>しら</rt></ruby>べて ください。",de:"Bitte recherchiere, wann die Besprechung beginnt."},{jp:"あの <ruby>人<rt>ひと</rt></ruby>が だれ<b>か</b>、<ruby>知<rt>し</rt></ruby>って いますか。",de:"Weißt du, wer jene Person ist?"},{jp:"<ruby>駅<rt>えき</rt></ruby>へ どう <ruby>行<rt>い</rt></ruby>く<b>か</b> <ruby>教<rt>おし</rt></ruby>えて ください。",de:"Bitte sag mir, wie man zum Bahnhof kommt."}],
   note:"💡 Erweiterung von L35 (Fragewort + か + 分かりません) — jetzt mit weiteren Hauptverben."},
  {l:40, t:"V Plain + か どうか", de:"ob (oder nicht) …",
   rule:"Bei Ja/Nein-Fragen: 〜かどうか = »ob V (oder nicht)«. Wird in Sätze eingebettet wie eine Fragewort-Frage.",
   build:[{form:"Anschluss",verb:"V<sub>普通形</sub> + かどうか + V₂",de:"ob V"},{form:"vs. Fragewort + か",verb:"何 + か = was-ob (offene Frage)",de:""},{form:"vs. か どうか",verb:"ja/nein-Frage",de:""}],
   pattern:{slots:[{text:"Plain-Form",role:"verb"},{text:"かどうか",role:"actor",label:"ob (oder nicht)"},{text:"、 V₂",role:"verb",label:"Hauptverb"}],gloss:"»Ob [Inhalt] (oder nicht), [V₂].« — Ja/Nein-Frage als Inhalts-Objekt."},
   ex:[{jp:"<ruby>彼<rt>かれ</rt></ruby>が <ruby>来<rt>く</rt></ruby>る<b>かどうか</b>、まだ <ruby>分<rt>わ</rt></ruby>かりません。",de:"Ich weiß noch nicht, ob er kommt (oder nicht)."},{jp:"これが <ruby>正<rt>ただ</rt></ruby>しい<b>かどうか</b>、<ruby>調<rt>しら</rt></ruby>べて ください。",de:"Bitte prüfe, ob das richtig ist."},{jp:"<ruby>会議<rt>かいぎ</rt></ruby>が ある<b>かどうか</b> <ruby>確認<rt>かくにん</rt></ruby>します。",de:"Ich werde bestätigen, ob die Besprechung stattfindet."}],
   note:"💡 Faustregel: Fragewort + か = offene Frage (was/wer). か どうか = Ja/Nein-Frage."},
  {l:40, t:"V て みます", de:"… mal probieren / versuchen",
   rule:"Versuchsweise etwas tun, ausprobieren. て-Form + みます. Häufig im Alltag (mal essen probieren, mal versuchen).",
   build:[{form:"Anschluss",verb:"V<sub>テ</sub> + みます",de:"V mal probieren"},{form:"Vergangenheit",verb:"V<sub>テ</sub> + みました",de:"hab V probiert"},{form:"Vorschlag",verb:"V<sub>テ</sub> + みて ください",de:"probier mal V"},{form:"Wunsch",verb:"V<sub>テ</sub> + みたい",de:"möchte V probieren"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Objekt を",role:"obj"},{text:"V-て",role:"verb"},{text:"みます",role:"actor",label:"probieren"}],gloss:"»Ich probiere mal [V].« — testweise, neugierig, ohne Garantie auf Erfolg."},
   ex:[{jp:"<ruby>納豆<rt>なっとう</rt></ruby>を <ruby>食<rt>た</rt></ruby>べて みました。",de:"Ich habe Natto mal probiert."},{jp:"この <ruby>服<rt>ふく</rt></ruby>を <ruby>着<rt>き</rt></ruby>て みても いいですか。",de:"Darf ich dieses Kleidungsstück anprobieren?"},{jp:"<ruby>富士山<rt>ふじさん</rt></ruby>に <ruby>登<rt>のぼ</rt></ruby>って みたいです。",de:"Ich möchte mal den Fuji besteigen."}],
   note:"💡 みる kommt von 見る (sehen) — sinngemäß »machen und sehen, wie es ist«. Sehr häufig in der Alltagssprache."},
  {l:40, t:"Adj/N + そうです (Vermutung nach Aussehen)", de:"sieht aus, als ob …",
   rule:"Anscheins-Vermutung: Etwas sieht (vom Anschein her) so aus. ⚠️ Bei い-Adj: い fällt weg + そう (おいしそう). Bei な-Adj/N: nur + そう (元気そう). NICHT mit Verben (das ist L43).",
   build:[{form:"い-Adj",verb:"い fällt weg + そう",de:"おいしい → おいし<b>そう</b>"},{form:"な-Adj",verb:"+ そう",de:"<ruby>元気<rt>げんき</rt></ruby> → <ruby>元気<rt>げんき</rt></ruby>そう"},{form:"⚠ いい",verb:"いい → よさそう (NICHT いそう)",de:"sieht gut aus"},{form:"⚠ ない",verb:"ない → なさそう",de:"gibt es offenbar nicht"},{form:"Verneinung い-Adj",verb:"〜くなさそう",de:"sieht nicht Adj aus"}],
   pattern:{slots:[{text:"N",role:"subj",label:"betrachtet"},{text:"は/が",role:"plain"},{text:"Adj-そう",role:"verb",label:"sieht so aus"},{text:"です",role:"plain"}],gloss:"»[N] sieht (anscheinend) [Adj] aus.« — Eindruck aufgrund des Aussehens, nicht aufgrund von Information."},
   ex:[{jp:"この ケーキは おいし<b>そう</b>です。",de:"Dieser Kuchen sieht lecker aus."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>元気<rt>げんき</rt></ruby><b>そう</b>です。",de:"Er sieht gesund aus."},{jp:"この <ruby>本<rt>ほん</rt></ruby>は <ruby>難<rt>むずか</rt></ruby>し<b>そう</b>です。",de:"Dieses Buch sieht schwer aus."},{jp:"<ruby>時間<rt>じかん</rt></ruby>が なさ<b>そう</b>です。",de:"Es scheint keine Zeit zu sein."}],
   note:"⚠️ そうです gibt's in 2 Bedeutungen: ① Aussehen (diese Karte), ② Hörensagen (L47, mit Plain-Form). Kontext und Bildung unterscheiden!"},
  {l:41, t:"Höfliche Geben-Verben (Keigo): いただく/くださる/さしあげる", de:"höfliche Versionen von もらう/くれる/あげる",
   rule:"Höflichere Versionen der Geben-Verben aus L24. Die Wahl hängt davon ab, WER GIBT und an WEN — und welcher Status zueinander besteht.",
   build:[{form:"normal vs. höflich",verb:"もらう → いただく",de:"ich bekomme von höhergestellter Person"},{form:"normal vs. höflich",verb:"くれる → くださる",de:"jmd. (höher) gibt mir"},{form:"normal vs. höflich",verb:"あげる → さしあげる",de:"ich gebe an höhergestellte Person"},{form:"⚠ unregelmäßig",verb:"くださる → ます-Form: くださ<b>い</b>ます",de:"NICHT くださります!"},{form:"⚠ unregelmäßig",verb:"いただく → いただきます",de:"regelmäßig"},{form:"⚠ Vorsicht: さしあげる",verb:"klingt manchmal überheblich",de:"besser ohne — siehe Hinweis"}],
   pattern:{slots:[[{text:"ich は",role:"subj",label:"Empfänger"},{text:"höhergestellt に",role:"actor",label:"Geber"},{text:"N を",role:"obj"},{text:"いただきました",role:"verb",label:"bekam (höfl.)"}],[{text:"höhergestellt が",role:"actor",label:"Geber"},{text:"(mir) N を",role:"obj"},{text:"くださいました",role:"verb",label:"gab mir (höfl.)"}]],gloss:"Drei Achsen wie L24, aber höfliche Stufe: ich BEKOMME (いただく) / mir wird GEGEBEN (くださる) / ich GEBE (さしあげる)."},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>を いただきました。",de:"Ich habe vom Lehrer ein Buch bekommen."},{jp:"<ruby>部長<rt>ぶちょう</rt></ruby>が お <ruby>土産<rt>みやげ</rt></ruby>を くださいました。",de:"Der Abteilungsleiter hat mir ein Mitbringsel gegeben."},{jp:"<ruby>母<rt>はは</rt></ruby>に <ruby>花<rt>はな</rt></ruby>を さしあげました。",de:"Ich habe meiner Mutter Blumen gegeben."}],
   note:"⚠️ さしあげる kann arrogant klingen (so als würde man sich extra herab lassen). Im Alltag oft besser: <ruby>渡<rt>わた</rt></ruby>す oder normales あげる. 💡 くださる → くださいます (kein りがちな typisches あ→い: 5 Verben mit dieser Unregelmäßigkeit: いらっしゃる, おっしゃる, くださる, ござる, なさる)."},
  {l:41, t:"V て いただきます (höflich)", de:"jemand tut etwas für mich (höflich)",
   rule:"Höfliche Variante von てもらう (L24): ich erbitte/empfange eine Handlung von einer höhergestellten Person. Sehr respektvoll.",
   build:[{form:"Anschluss",verb:"V<sub>テ</sub> + いただきます",de:"jmd. (höher) tut für mich V"},{form:"vs. てもらいます",verb:"てもらう = neutral / freundschaftlich",de:""},{form:"vs. てもらえる",verb:"〜ていただけませんか",de:"sehr höfliche Bitte (L26)"},{form:"Vergangenheit",verb:"〜て いただきました",de:"jmd. tat für mich (höfl.)"}],
   pattern:{slots:[{text:"ich は",role:"subj",label:"Empfänger"},{text:"höhergestellt に",role:"actor",label:"wer hat getan"},{text:"V-て",role:"verb"},{text:"いただきました",role:"actor",label:"höfl. bekommen"}],gloss:"»[Höhergestellter] hat (für mich) [V] getan.« — höfliche Anerkennung der erhaltenen Hilfe."},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>に <ruby>日本語<rt>にほんご</rt></ruby>を <ruby>教<rt>おし</rt></ruby>えて いただきました。",de:"Vom Lehrer wurde mir Japanisch beigebracht."},{jp:"<ruby>部長<rt>ぶちょう</rt></ruby>に <ruby>駅<rt>えき</rt></ruby>まで <ruby>送<rt>おく</rt></ruby>って いただきました。",de:"Der Abteilungsleiter hat mich zum Bahnhof gefahren."},{jp:"<ruby>田中<rt>たなか</rt></ruby>さんに <ruby>手伝<rt>てつだ</rt></ruby>って いただきました。",de:"Frau Tanaka hat mir geholfen."}],
   note:"💡 Im Berufsalltag sehr häufig — drückt Dankbarkeit gegenüber Vorgesetzten oder Kunden aus."},
  {l:41, t:"V て くださいます (höflich)", de:"jemand (höher) tut für mich",
   rule:"Höfliche Variante von てくれる (L24): jemand TUT etwas für mich. Subjekt ist die höhergestellte Person, die die Handlung ausführt.",
   build:[{form:"Anschluss",verb:"höher が + V<sub>テ</sub> + くださいます",de:"höher tut für mich V"},{form:"⚠ unregelm. ます",verb:"くださ<b>い</b>ます (NICHT くださります)",de:""},{form:"vs. てくれる",verb:"てくれる = neutral",de:""},{form:"Bitte",verb:"V<sub>テ</sub> + くださいませんか",de:"würden Sie bitte V?"}],
   pattern:{slots:[{text:"höhergestellt が",role:"actor",label:"Helfer (höfl.)"},{text:"(mir に)",role:"subj",label:"opt."},{text:"V-て",role:"verb"},{text:"くださいました",role:"actor",label:"hat höfl. getan"}],gloss:"»[Höhergestellter] hat (für mich) [V] getan.« — Subjekt ist der Wohltäter, ich bin Empfänger."},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>が <ruby>本<rt>ほん</rt></ruby>を <ruby>貸<rt>か</rt></ruby>して くださいました。",de:"Der Lehrer hat mir das Buch geliehen."},{jp:"<ruby>部長<rt>ぶちょう</rt></ruby>が <ruby>家<rt>いえ</rt></ruby>まで <ruby>送<rt>おく</rt></ruby>って くださいました。",de:"Der Abteilungsleiter hat mich nach Hause gefahren."},{jp:"<ruby>山田<rt>やまだ</rt></ruby>さんが <ruby>道<rt>みち</rt></ruby>を <ruby>教<rt>おし</rt></ruby>えて くださいました。",de:"Herr Yamada hat mir den Weg gezeigt."}],
   note:"💡 Unterschied zu いただく: bei いただく ist ICH das Subjekt (»ich erhielt«). Bei くださる ist der HÖHERGESTELLTE das Subjekt (»er gab«)."},
  {l:41, t:"V て やります", de:"jemandem (Untergebenem/Kind/Tier) helfen",
   rule:"Sehr informelle Variante von てあげる (L24). Wird nur bei Personen mit niedrigerem Status (Kinder, Untergebene), Tieren oder Pflanzen benutzt. ⚠️ Bei gleichgestellten Personen kann es ARROGANT klingen!",
   build:[{form:"Anschluss",verb:"V<sub>テ</sub> + やります",de:"V tun für niedrigeren"},{form:"⚠ Achtung",verb:"NUR bei Kind/Tier/Pflanze",de:"bei Erwachsenen klingt arrogant"},{form:"sicher: あげる",verb:"V<sub>テ</sub> + あげる",de:"sicher bei Freunden"}],
   pattern:{slots:[{text:"ich は",role:"subj"},{text:"Kind/Tier に",role:"actor",label:"Empfänger"},{text:"V-て",role:"verb"},{text:"やります",role:"actor",label:"für (Niedrigeren)"}],gloss:"»Ich tue [V] für [Kind/Tier].« — nur in eindeutig hierarchisch niedrigem Kontext."},
   ex:[{jp:"<ruby>子供<rt>こども</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>んで やりました。",de:"Ich habe meinem Kind ein Buch vorgelesen."},{jp:"<ruby>犬<rt>いぬ</rt></ruby>を <ruby>散歩<rt>さんぽ</rt></ruby>に <ruby>連<rt>つ</rt></ruby>れて <ruby>行<rt>い</rt></ruby>って やります。",de:"Ich gehe mit dem Hund spazieren."},{jp:"<ruby>花<rt>はな</rt></ruby>に <ruby>水<rt>みず</rt></ruby>を やります。",de:"Ich gieße die Blumen."}],
   note:"⚠️ Bei Erwachsenen/Gleichgestellten lieber てあげる verwenden. やる klingt sonst herablassend."},
  {l:42, t:"V<ruby>辞書<rt>じしょ</rt></ruby> / N の + ために、…", de:"um zu / für (aktives Ziel)",
   rule:"Aktives, willentliches Ziel — etwas aktiv erreichen wollen. Bei Verben: 辞書形 + ために. Bei Nomen: N + の + ために. ⚠️ Subjekt für beide Teile muss gleich sein!",
   build:[{form:"Verb",verb:"V<sub>辞書</sub> + ために",de:"um V zu tun"},{form:"Nomen",verb:"N + の + ために",de:"für N"},{form:"vs. ように (L36)",verb:"ように = nicht-willkürlich (Können/Vermeiden)",de:""},{form:"vs. ために",verb:"ために = aktiv-willkürlich (steuerbar)",de:""}],
   pattern:{slots:[{text:"Subjekt は",role:"subj",label:"selbe Person!"},{text:"V-辞書 / N の",role:"verb",label:"Ziel"},{text:"ために、",role:"actor",label:"um zu"},{text:"Mittel-V",role:"verb",label:"Handlung"}],gloss:"»Um [Ziel] zu erreichen, [V tun].« — bewusst-aktives Streben, Subjekt für Ziel und Handlung ist gleich."},
   ex:[{jp:"<ruby>家<rt>いえ</rt></ruby>を <ruby>買<rt>か</rt></ruby>うために、<ruby>貯金<rt>ちょきん</rt></ruby>して います。",de:"Um ein Haus zu kaufen, spare ich."},{jp:"<ruby>留学<rt>りゅうがく</rt></ruby>のために、<ruby>日本語<rt>にほんご</rt></ruby>を <ruby>勉強<rt>べんきょう</rt></ruby>して います。",de:"Für das Auslandsstudium lerne ich Japanisch."},{jp:"<ruby>子供<rt>こども</rt></ruby>のために、はたらいて います。",de:"Für die Kinder arbeite ich."}],
   note:"💡 Faustregel: ために = aktives, kontrolliertes Ziel (kaufen, sparen, treffen). ように = nicht-aktives Ziel (verstehen können, nicht erkälten)."},
  {l:42, t:"V<ruby>辞書<rt>じしょ</rt></ruby> + のに <ruby>使<rt>つか</rt></ruby>います / いいです", de:"wird verwendet für / ist gut für …",
   rule:"Verwendungs-/Eignungsangabe. のに = »zu (dem Zweck), um …«. Auch mit いい (gut für), 便利 (praktisch), 必要 (nötig).",
   build:[{form:"Anschluss",verb:"V<sub>辞書</sub> + のに",de:"zum V (Zweck)"},{form:"+ <ruby>使<rt>つか</rt></ruby>います",verb:"wird benutzt für",de:""},{form:"+ いいです",verb:"ist gut für",de:""},{form:"+ <ruby>便利<rt>べんり</rt></ruby>です",verb:"ist praktisch für",de:""},{form:"+ <ruby>必要<rt>ひつよう</rt></ruby>です",verb:"ist nötig für",de:""}],
   pattern:{slots:[{text:"Werkzeug は",role:"subj",label:"das Ding"},{text:"V-辞書",role:"verb",label:"Zweck"},{text:"のに",role:"actor",label:"um zu"},{text:"<ruby>使<rt>つか</rt></ruby>います / いいです",role:"verb",label:"Bewertung"}],gloss:"»[Werkzeug] wird benutzt, um [V] zu tun / ist gut/praktisch für [V].«"},
   ex:[{jp:"これは <ruby>瓶<rt>びん</rt></ruby>を <ruby>開<rt>あ</rt></ruby>けるのに <ruby>使<rt>つか</rt></ruby>います。",de:"Das benutzt man, um Flaschen zu öffnen."},{jp:"この <ruby>辞書<rt>じしょ</rt></ruby>は <ruby>勉強<rt>べんきょう</rt></ruby>するのに いいです。",de:"Dieses Wörterbuch ist gut zum Lernen."},{jp:"スマホは <ruby>道<rt>みち</rt></ruby>を <ruby>調<rt>しら</rt></ruby>べるのに <ruby>便利<rt>べんり</rt></ruby>です。",de:"Smartphones sind praktisch zum Wegsuchen."}],
   note:"⚠️ Diese のに ist ANDERS als die のに-Konstruktion in L45 (»obwohl«). Hier = Zweck/Eignung. Dort = Konzession."},
  {l:42, t:"V<ruby>辞書<rt>じしょ</rt></ruby>/N + のに + <ruby>時間<rt>じかん</rt></ruby>/お<ruby>金<rt>かね</rt></ruby>が かかります", de:"… braucht/kostet Zeit/Geld",
   rule:"Aufwand für eine Tätigkeit. のに + 時間/お金/etc. + が かかります. Beschreibt, wie viel Zeit oder Geld eine Aktion benötigt.",
   build:[{form:"Verb",verb:"V<sub>辞書</sub> + のに",de:"um V zu tun"},{form:"Nomen",verb:"N + のに",de:"für N"},{form:"+ <ruby>時間<rt>じかん</rt></ruby>がかかる",verb:"braucht Zeit",de:""},{form:"+ お<ruby>金<rt>かね</rt></ruby>がかかる",verb:"kostet Geld",de:""}],
   pattern:{slots:[{text:"V-辞書 / N",role:"verb",label:"Aktion"},{text:"のに",role:"actor"},{text:"Aufwand",role:"obj",label:"Zeit/Geld"},{text:"が かかります",role:"verb"}],gloss:"»[V] braucht/kostet [Zeit/Geld].« — Aufwand-Beschreibung."},
   ex:[{jp:"この <ruby>仕事<rt>しごと</rt></ruby>を するのに <ruby>2時間<rt>にじかん</rt></ruby> かかります。",de:"Diese Arbeit braucht zwei Stunden."},{jp:"<ruby>留学<rt>りゅうがく</rt></ruby>するのに たくさん お<ruby>金<rt>かね</rt></ruby>が かかります。",de:"Ein Auslandsstudium kostet viel Geld."},{jp:"この レポートを <ruby>書<rt>か</rt></ruby>くのに <ruby>1週間<rt>いっしゅうかん</rt></ruby> かかりました。",de:"Diesen Bericht zu schreiben hat eine Woche gedauert."}],
   note:"💡 Häufige Variante mit に statt のに: <ruby>東京<rt>とうきょう</rt></ruby>から <ruby>京都<rt>きょうと</rt></ruby>まで に <ruby>2時間<rt>にじかん</rt></ruby> かかる = von Tokyo nach Kyoto braucht es 2 Stunden."},
  {l:42, t:"V<ruby>マス<rt></rt></ruby>-Stamm/N + に <ruby>行<rt>い</rt></ruby>きます/<ruby>来<rt>き</rt></ruby>ます", de:"Erweiterter Zweck mit Bewegung",
   rule:"Wiederholung/Erweiterung von L13: Bewegung mit Zweck. ます-Stamm + に + 行く/来る/帰る. Auch mit Aktivität: スーパーへ <ruby>買<rt>か</rt></ruby>い<ruby>物<rt>もの</rt></ruby>に <ruby>行<rt>い</rt></ruby>く.",
   build:[{form:"Verb (ます-Stamm)",verb:"V<sub>マス</sub>-Stamm + に",de:"<ruby>食<rt>た</rt></ruby>べに <ruby>行<rt>い</rt></ruby>く = essen gehen"},{form:"Nomen (Aktivität)",verb:"N + に",de:"<ruby>映画<rt>えいが</rt></ruby>に <ruby>行<rt>い</rt></ruby>く = ins Kino gehen"},{form:"+ Bewegungsverb",verb:"<ruby>行<rt>い</rt></ruby>く / <ruby>来<rt>く</rt></ruby>る / <ruby>帰<rt>かえ</rt></ruby>る",de:"gehen / kommen / heimgehen"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Ort へ/に",role:"place",label:"wohin"},{text:"V-マス / N",role:"verb",label:"Zweck"},{text:"に",role:"plain"},{text:"<ruby>行<rt>い</rt></ruby>きます/<ruby>来<rt>き</rt></ruby>ます",role:"verb",label:"Bewegung"}],gloss:"»[Subjekt] geht/kommt nach [Ort], um [V/N] zu tun.« — Bewegungs-Zweck."},
   ex:[{jp:"スーパーへ <ruby>買<rt>か</rt></ruby>い <ruby>物<rt>もの</rt></ruby>に <ruby>行<rt>い</rt></ruby>きます。",de:"Ich gehe zum Supermarkt einkaufen."},{jp:"<ruby>京都<rt>きょうと</rt></ruby>へ お<ruby>寺<rt>てら</rt></ruby>を <ruby>見<rt>み</rt></ruby>に <ruby>行<rt>い</rt></ruby>きました。",de:"Ich bin nach Kyoto gefahren, um Tempel zu sehen."},{jp:"<ruby>友達<rt>ともだち</rt></ruby>が <ruby>遊<rt>あそ</rt></ruby>びに <ruby>来<rt>き</rt></ruby>ます。",de:"Ein Freund kommt zu Besuch (zum Spielen/Treffen)."}],
   note:"💡 Wiederholung von L13 — diesmal kombiniert mit komplexeren Aktivitäten. Wichtig: ます-Stamm (NICHT 辞書形) vor に."},
  {l:42, t:"Quantifier + は (mindestens)", de:"mindestens (Menge/Dauer)",
   rule:"Mengenangabe + は = Mindestmaß: »mindestens X«, »wenigstens X«. Im positiven Satz drückt es eine ungefähre Untergrenze aus.",
   build:[{form:"Anschluss",verb:"Mengenangabe + は",de:"mindestens X"},{form:"vs. Mengen + も",verb:"も = überraschend viel (siehe nächste Karte)",de:""},{form:"vs. nur Mengen",verb:"neutrale Aussage",de:""}],
   pattern:{slots:[{text:"Aktion",role:"verb"},{text:"のに",role:"plain"},{text:"Menge",role:"time",label:"mindestens"},{text:"は",role:"actor",label:"min."},{text:"かかります/<ruby>必要<rt>ひつよう</rt></ruby>",role:"verb"}],gloss:"»Mindestens [Menge].« — die Untergrenze, könnte auch mehr sein."},
   ex:[{jp:"<ruby>日本<rt>にほん</rt></ruby>へ <ruby>行<rt>い</rt></ruby>くのに、<ruby>10万円<rt>じゅうまんえん</rt></ruby>は かかります。",de:"Um nach Japan zu fahren, braucht man mindestens 100.000 Yen."},{jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>1時間<rt>いちじかん</rt></ruby>は <ruby>勉強<rt>べんきょう</rt></ruby>して います。",de:"Ich lerne mindestens eine Stunde am Tag."},{jp:"レポートを <ruby>書<rt>か</rt></ruby>くのに、<ruby>1週間<rt>いっしゅうかん</rt></ruby>は <ruby>必要<rt>ひつよう</rt></ruby>です。",de:"Für den Bericht braucht man mindestens eine Woche."}],
   note:"💡 Faustregel: Menge + は = »mindestens« (Untergrenze). Menge + も = »sogar so viel« (überraschend hoch)."},
  {l:42, t:"Quantifier + も (überraschend viel)", de:"sogar / so viel wie (überraschend)",
   rule:"Mengenangabe + も = überraschend hohe Menge: »sogar so viel«, »ganze X«. Drückt aus, dass der Sprecher diese Menge als hoch/erstaunlich empfindet.",
   build:[{form:"Anschluss",verb:"Mengenangabe + も",de:"sogar X (überraschend)"},{form:"Negation: kein einziger",verb:"Menge + も + Verneinung",de:"nicht ein einziger"},{form:"vs. Mengen + は",verb:"は = mindestens",de:""},{form:"vs. Mengen + も",verb:"も = überraschend viel",de:""}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Menge",role:"time",label:"viel"},{text:"も",role:"actor",label:"sogar!"},{text:"V",role:"verb"}],gloss:"»[Subjekt] hat sogar [Menge] [V getan].« — der Sprecher findet die Menge auffallend groß."},
   ex:[{jp:"きのうは ビールを <ruby>10本<rt>じゅっぽん</rt></ruby>も <ruby>飲<rt>の</rt></ruby>みました。",de:"Gestern habe ich sogar 10 Flaschen Bier getrunken!"},{jp:"<ruby>一晩中<rt>ひとばんじゅう</rt></ruby> <ruby>10時間<rt>じゅうじかん</rt></ruby>も <ruby>寝<rt>ね</rt></ruby>ました。",de:"Ich habe ganze 10 Stunden geschlafen."},{jp:"きのうは <ruby>何<rt>なに</rt></ruby>も <ruby>食<rt>た</rt></ruby>べませんでした。",de:"Gestern habe ich nichts gegessen. [何 + も + Verneinung]"}],
   note:"💡 Im negativen Satz: 何も/誰も/どこも + ない = »nichts/niemand/nirgendwo« (vollständige Verneinung)."},
  {l:43, t:"V<ruby>マス<rt></rt></ruby>-Stamm + そうです (Anschein)", de:"sieht aus, als ob … (Verb)",
   rule:"Anscheinsvermutung bei VERBEN. ます-Stamm + そうです = sieht aus, als würde gleich V passieren / als sei V im Begriff. ⚠️ Dies ist die ZWEITE そうです-Verwendung neben L40 (Adj/N).",
   build:[{form:"Verb",verb:"V<sub>マス</sub>-Stamm + そう",de:"<ruby>降<rt>ふ</rt></ruby>り → <ruby>降<rt>ふ</rt></ruby>りそう = sieht nach Regen aus"},{form:"い-Adj (L40)",verb:"い fällt weg + そう",de:"おいしい → おいしそう"},{form:"な-Adj (L40)",verb:"+ そう",de:"<ruby>元気<rt>げんき</rt></ruby> → <ruby>元気<rt>げんき</rt></ruby>そう"},{form:"⚠ ない/いい",verb:"なさそう / よさそう",de:"speziell"},{form:"Verneinung Verb",verb:"V<sub>マス</sub>-Stamm + そうにない",de:"sieht so aus, als ob NICHT"}],
   pattern:{slots:[{text:"Subjekt は/が",role:"subj"},{text:"V-マス-Stamm",role:"verb",label:"Aktion (kurz)"},{text:"そうです",role:"actor",label:"Anschein"}],gloss:"»Es sieht so aus, als würde [V] gleich passieren.« — visueller Eindruck, nicht Information."},
   ex:[{jp:"<ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>りそうです。",de:"Es sieht nach Regen aus."},{jp:"<ruby>木<rt>き</rt></ruby>から りんごが <ruby>落<rt>お</rt></ruby>ちそうです。",de:"Der Apfel sieht so aus, als würde er gleich vom Baum fallen."},{jp:"<ruby>子供<rt>こども</rt></ruby>が <ruby>泣<rt>な</rt></ruby>きそうです。",de:"Das Kind sieht so aus, als würde es gleich weinen."}],
   note:"⚠️ NICHT mit Verben verwechseln: 〜<b>Plain-Form</b> + そうです (L47) = HÖRENSAGEN. Hier ます-Stamm = ANSCHEIN."},
  {l:43, t:"V て <ruby>来<rt>き</rt></ruby>ます", de:"… und zurückkommen / Annäherung / Beginn",
   rule:"Drei Bedeutungen: ① V + zurückkommen (mache V und komme dann zurück), ② Annäherung (etwas kommt auf mich zu), ③ Beginn einer Veränderung (es wird langsam …).",
   build:[{form:"① V & zurückkommen",verb:"V<sub>テ</sub> + <ruby>来<rt>き</rt></ruby>ます",de:"V tun und zurückkommen"},{form:"② Annäherung",verb:"V<sub>テ</sub> + <ruby>来<rt>く</rt></ruby>る",de:"kommt auf mich zu"},{form:"③ Beginn/Veränderung",verb:"V<sub>テ</sub> + <ruby>来<rt>く</rt></ruby>る",de:"wird allmählich V"},{form:"Gegenstück",verb:"V<sub>テ</sub> + <ruby>行<rt>い</rt></ruby>く",de:"V und entfernen / weiter werden"}],
   pattern:{slots:[[{text:"Subjekt は",role:"subj"},{text:"V-て",role:"verb",label:"V tun"},{text:"<ruby>来<rt>き</rt></ruby>ます",role:"actor",label:"+ zurückkommen"}]],gloss:"3 Bedeutungen: ① raus + V + zurück (買って来る = kaufen gehen), ② V kommt näher (走って来る = läuft auf mich zu), ③ Beginn (寒くなって来た = wird langsam kalt)."},
   ex:[{jp:"コンビニで お <ruby>弁当<rt>べんとう</rt></ruby>を <ruby>買<rt>か</rt></ruby>って <ruby>来<rt>き</rt></ruby>ます。",de:"Ich kaufe schnell eine Bento im Konbini (und komme zurück). [①]"},{jp:"<ruby>子供<rt>こども</rt></ruby>が <ruby>走<rt>はし</rt></ruby>って <ruby>来<rt>き</rt></ruby>ました。",de:"Das Kind kam angerannt. [②]"},{jp:"だんだん <ruby>寒<rt>さむ</rt></ruby>くなって <ruby>来<rt>き</rt></ruby>ました。",de:"Es wird allmählich kälter. [③]"}],
   note:"💡 Gegenstück: Vて行く = Aktion und sich entfernen / Trend in die Zukunft. <ruby>暑<rt>あつ</rt></ruby>くなって <ruby>行<rt>い</rt></ruby>く = wird (in Zukunft) wärmer."},
  {l:44, t:"V<ruby>マス<rt></rt></ruby>-Stamm / Adj-Stamm + すぎます", de:"zu (sehr) … (Übermaß)",
   rule:"Drückt »zu sehr« / »übermäßig« aus. Negative Bewertung: ist über das gesunde Maß hinaus. Bei Verben: ます-Stamm. Bei Adj: い weg / な weg.",
   build:[{form:"Verb",verb:"V<sub>マス</sub>-Stamm + すぎます",de:"<ruby>食<rt>た</rt></ruby>べすぎる = zu viel essen"},{form:"い-Adj",verb:"い weg + すぎます",de:"<ruby>高<rt>たか</rt></ruby>すぎる = zu teuer"},{form:"な-Adj",verb:"な weg + すぎます",de:"<ruby>静<rt>しず</rt></ruby>かすぎる = zu still"},{form:"⚠ いい",verb:"いい → よすぎる",de:"zu gut (unregelmäßig)"},{form:"⚠ ない",verb:"ない → なさすぎる",de:"zu wenig vorhanden"}],
   pattern:{slots:[{text:"Subjekt は/が",role:"subj"},{text:"V-Stamm/Adj-Stamm",role:"verb",label:"Inhalt"},{text:"すぎます",role:"actor",label:"zu sehr"}],gloss:"»[Inhalt] ist zu sehr.« — Übertreibung, oft mit negativem Beiklang."},
   ex:[{jp:"きのう ビールを <ruby>飲<rt>の</rt></ruby>みすぎました。",de:"Gestern habe ich zu viel Bier getrunken."},{jp:"この <ruby>本<rt>ほん</rt></ruby>は <ruby>難<rt>むずか</rt></ruby>しすぎます。",de:"Dieses Buch ist zu schwer."},{jp:"この <ruby>部屋<rt>へや</rt></ruby>は <ruby>静<rt>しず</rt></ruby>かすぎます。",de:"Dieses Zimmer ist zu ruhig."}],
   note:"💡 〜すぎる ist selbst ein Gruppe-II-Verb: 食べすぎる, 食べすぎた, 食べすぎて など. Lässt sich also weiter konjugieren."},
  {l:44, t:"V<ruby>マス<rt></rt></ruby>-Stamm + やすい / にくい", de:"leicht / schwer zu …",
   rule:"Eigenschaft: leicht oder schwer in der Anwendung. やすい = einfach zu V. にくい = schwer zu V. Beide werden wie い-Adjektive konjugiert.",
   build:[{form:"easy",verb:"V<sub>マス</sub>-Stamm + やすい",de:"leicht zu V"},{form:"hard",verb:"V<sub>マス</sub>-Stamm + にくい",de:"schwer zu V"},{form:"Konjugation wie い-Adj",verb:"〜やすい / 〜やすかった / 〜やすくない",de:""},{form:"Beispiele",verb:"<ruby>使<rt>つか</rt></ruby>いやすい / <ruby>分<rt>わ</rt></ruby>かりにくい",de:"leicht zu nutzen / schwer zu verstehen"}],
   pattern:{slots:[{text:"N",role:"subj",label:"Sache"},{text:"は",role:"plain"},{text:"V-Stamm + やすい/にくい",role:"verb",label:"Eigenschaft"},{text:"です",role:"plain"}],gloss:"»[N] ist leicht/schwer [V]bar.« — Eigenschaft des Objekts in Bezug auf eine Handlung."},
   ex:[{jp:"この ペンは <ruby>書<rt>か</rt></ruby>き<b>やすい</b>です。",de:"Dieser Stift schreibt sich leicht."},{jp:"この <ruby>本<rt>ほん</rt></ruby>は <ruby>分<rt>わ</rt></ruby>かり<b>にくい</b>です。",de:"Dieses Buch ist schwer zu verstehen."},{jp:"<ruby>東京<rt>とうきょう</rt></ruby>は <ruby>住<rt>す</rt></ruby>み<b>やすい</b> <ruby>町<rt>まち</rt></ruby>です。",de:"Tokyo ist eine wohnenswerte Stadt."}],
   note:"💡 やすい/にくい sind selbst い-Adjektive — können also normal konjugiert werden: 〜やすかったです, 〜にくくない etc."},
  {l:44, t:"い-Adj く します / な-Adj に します", de:"etwas [Adj] machen (Veränderung)",
   rule:"Aktive Veränderung: etwas wird durch eine Handlung [Adj] gemacht. Bei い-Adj: い→く. Bei な-Adj/N: + に. Vergleich mit Adjektiv→なります (von alleine werden, L19).",
   build:[{form:"い-Adj",verb:"い → く + します",de:"<ruby>大<rt>おお</rt></ruby>きく します = größer machen"},{form:"な-Adj",verb:"な-Adj + に + します",de:"きれいに します = sauber machen"},{form:"vs. なる",verb:"〜く なる / 〜に なる",de:"von selbst werden (L19)"},{form:"vs. する",verb:"〜く する / 〜に する",de:"jmd. macht es so"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Objekt を",role:"obj"},{text:"Adj く/に",role:"verb",label:"so machen"},{text:"します",role:"actor",label:"verändern"}],gloss:"»[Subjekt] macht [Objekt] [Adj].« — aktive Zustandsveränderung durch jemanden."},
   ex:[{jp:"<ruby>音<rt>おと</rt></ruby>を <ruby>大<rt>おお</rt></ruby>きく して ください。",de:"Bitte mach den Ton lauter."},{jp:"<ruby>部屋<rt>へや</rt></ruby>を きれい<b>に</b> しました。",de:"Ich habe das Zimmer sauber gemacht."},{jp:"スープを <ruby>熱<rt>あつ</rt></ruby><b>く</b> します。",de:"Ich mache die Suppe heiß."}],
   note:"💡 Vergleich なる vs. する: 大きく なる = wird größer (von selbst). 大きく する = jmd. macht größer (aktiv)."},
  {l:44, t:"N に します", de:"N wählen / zu N machen",
   rule:"Wahl/Entscheidung. に します = »ich nehme / wähle / entscheide mich für N«. Im Restaurant, beim Einkaufen, bei Entscheidungen sehr häufig.",
   build:[{form:"Anschluss",verb:"N + に します",de:"ich nehme N / wähle N"},{form:"vs. Adj に します",verb:"Veränderung",de:"vorige Karte"},{form:"Variante",verb:"〜に <ruby>決<rt>き</rt></ruby>めました",de:"habe mich für N entschieden"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"N",role:"obj",label:"Wahl"},{text:"に",role:"plain"},{text:"します",role:"verb",label:"wählen"}],gloss:"»Ich nehme/wähle [N].« — typische Wendung beim Bestellen oder Entscheiden."},
   ex:[{jp:"<ruby>私<rt>わたし</rt></ruby>は コーヒーに します。",de:"Ich nehme Kaffee. [im Café]"},{jp:"<ruby>夕<rt>ゆう</rt></ruby>ご<ruby>飯<rt>はん</rt></ruby>は すしに しましょう。",de:"Lass uns Sushi zum Abendessen wählen."},{jp:"<ruby>赤<rt>あか</rt></ruby>い のに します。",de:"Ich nehme das rote."}],
   note:"💡 Im Restaurant/Café fast immer 〜に します. Variante 〜に <ruby>決<rt>き</rt></ruby>めました klingt formeller (»entschieden«)."},
  {l:44, t:"い-Adj く / な-Adj に + V (Adverbial)", de:"adverbialer Gebrauch: [Adj] + Verb",
   rule:"Adjektive werden mit く / に in Adverbien umgewandelt. So beschreiben sie die ART und WEISE einer Handlung.",
   build:[{form:"い-Adj",verb:"い → く + V",de:"<ruby>速<rt>はや</rt></ruby>く <ruby>歩<rt>ある</rt></ruby>く = schnell gehen"},{form:"な-Adj",verb:"+ に + V",de:"<ruby>静<rt>しず</rt></ruby>かに <ruby>話<rt>はな</rt></ruby>す = leise sprechen"},{form:"⚠ いい → よく",verb:"<ruby>良<rt>よ</rt></ruby>く できる = kann gut",de:"unregelmäßig"},{form:"vs. Verbveränderung",verb:"〜く なる/する",de:"da Resultat, hier WIE"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"Objekt を",role:"obj"},{text:"Adj く/に",role:"actor",label:"wie"},{text:"V",role:"verb",label:"Aktion"}],gloss:"»[Subjekt] [V] auf [Adj] Weise.« — die Adj-Form vor dem Verb beschreibt die Art der Handlung."},
   ex:[{jp:"もう <ruby>少<rt>すこ</rt></ruby>し <ruby>大<rt>おお</rt></ruby>きく <ruby>書<rt>か</rt></ruby>いて ください。",de:"Bitte schreib etwas größer."},{jp:"<ruby>静<rt>しず</rt></ruby>かに <ruby>話<rt>はな</rt></ruby>して ください。",de:"Bitte sprich leise."},{jp:"<ruby>子供<rt>こども</rt></ruby>たちが <ruby>元気<rt>げんき</rt></ruby>に <ruby>遊<rt>あそ</rt></ruby>んで います。",de:"Die Kinder spielen energisch."}],
   note:"💡 Faustregel: vor Adjektiv stehende Form für Tätigkeit/Modus = adverbial (く/に). Vor 〜なる/〜する = Resultat."},
  {l:45, t:"V<ruby>普通形<rt>ふつうけい</rt></ruby> + ばあいは、…", de:"Im Falle, dass …",
   rule:"Hypothetische, oft formelle Bedingung. ばあい (場合) = »Fall«. Plain-Form + ばあいは. Bei な-Adj: な+ばあい. Bei N: の+ばあい. Klingt schriftlich/formell, oft in Ansagen oder Anweisungen.",
   build:[{form:"Verb",verb:"V<sub>普通形</sub> + <ruby>場合<rt>ばあい</rt></ruby>は",de:"im Falle, dass V"},{form:"い-Adj",verb:"い-Adj + <ruby>場合<rt>ばあい</rt></ruby>は",de:""},{form:"な-Adj",verb:"な-Adj + な + <ruby>場合<rt>ばあい</rt></ruby>",de:""},{form:"Nomen",verb:"N + の + <ruby>場合<rt>ばあい</rt></ruby>",de:""},{form:"vs. たら",verb:"たら = neutraler / gesprochen",de:"場合 = formeller / schriftlich"}],
   pattern:{slots:[{text:"Bedingung",role:"cond",label:"Fall"},{text:"<ruby>場合<rt>ばあい</rt></ruby>は、",role:"actor",label:"im Falle"},{text:"Reaktion",role:"verb",label:"dann …"}],gloss:"»Im Falle, dass [Bedingung] — dann [Reaktion].« — formeller Ton, oft auf Schildern, in Bedienungsanleitungen, Verträgen."},
   ex:[{jp:"<ruby>遅<rt>おく</rt></ruby>れる <ruby>場合<rt>ばあい</rt></ruby>は、<ruby>連絡<rt>れんらく</rt></ruby>して ください。",de:"Falls Sie sich verspäten, melden Sie sich bitte."},{jp:"<ruby>故障<rt>こしょう</rt></ruby>の <ruby>場合<rt>ばあい</rt></ruby>は、この <ruby>番号<rt>ばんごう</rt></ruby>に <ruby>電話<rt>でんわ</rt></ruby>して ください。",de:"Im Falle eines Defekts rufen Sie diese Nummer an."},{jp:"<ruby>雨<rt>あめ</rt></ruby>の <ruby>場合<rt>ばあい</rt></ruby>は、<ruby>試合<rt>しあい</rt></ruby>は <ruby>中止<rt>ちゅうし</rt></ruby>です。",de:"Im Falle von Regen fällt das Spiel aus."}],
   note:"💡 ばあいは = formell/schriftlich. たら/ば = alltagssprachlich. Im Geschäftsalltag und auf Aushängen sehr häufig."},
  {l:45, t:"V<ruby>普通形<rt>ふつうけい</rt></ruby> + のに、…", de:"obwohl …",
   rule:"Konzessivsatz: »obwohl A, doch B«. Drückt Überraschung, Enttäuschung, Verwunderung aus. Bei な-Adj/N: な + のに. ⚠️ Andere のに als L42 (Zweck-のに)!",
   build:[{form:"Verb",verb:"V<sub>普通形</sub> + のに",de:"obwohl V"},{form:"い-Adj",verb:"い-Adj + のに",de:""},{form:"な-Adj/N",verb:"+ な + のに",de:"<ruby>元気<rt>げんき</rt></ruby>な のに"},{form:"vs. が/けど",verb:"のに = mit Überraschung/Enttäuschung",de:""},{form:"vs. のに (L42)",verb:"L42 = Zweck (was wofür)",de:"L45 = obwohl (Konzession)"}],
   pattern:{slots:[{text:"Aussage A",role:"cond",label:"obwohl"},{text:"のに、",role:"actor",label:"trotzdem"},{text:"Aussage B (überraschend)",role:"verb"}],gloss:"»Obwohl [A], (überraschenderweise) [B].« — emotionale Färbung: erstaunt, enttäuscht, kritisch."},
   ex:[{jp:"<ruby>毎日<rt>まいにち</rt></ruby> <ruby>勉強<rt>べんきょう</rt></ruby>して いる<b>のに</b>、なかなか <ruby>上手<rt>じょうず</rt></ruby>に なりません。",de:"Obwohl ich jeden Tag lerne, werde ich nicht besser."},{jp:"<ruby>約束<rt>やくそく</rt></ruby>した<b>のに</b>、<ruby>彼<rt>かれ</rt></ruby>は <ruby>来<rt>こ</rt></ruby>ませんでした。",de:"Obwohl wir es vereinbart hatten, kam er nicht."},{jp:"<ruby>日曜日<rt>にちようび</rt></ruby>な<b>のに</b>、<ruby>働<rt>はたら</rt></ruby>かなければ なりません。",de:"Obwohl Sonntag ist, muss ich arbeiten."}],
   note:"💡 Vergleich が/けど vs. のに: が/けど = neutral »aber«. のに = emotional »obwohl (entgegen der Erwartung)«. Mehr Unzufriedenheit/Erstaunen."},
  {l:46, t:"V ところです (Phase einer Handlung)", de:"gerade dabei zu …",
   rule:"Bezeichnet eine PHASE der Handlung: davor / mittendrin / direkt danach. Drei Varianten je nach Verbform: 辞書形 (gleich), ている (gerade dabei), た (gerade fertig).",
   build:[{form:"vorher (gleich)",verb:"V<sub>辞書</sub> + ところです",de:"<ruby>食<rt>た</rt></ruby>べる ところです = will gleich essen"},{form:"mittendrin",verb:"V<sub>テ</sub>いる + ところです",de:"<ruby>食<rt>た</rt></ruby>べて いる ところです = bin gerade beim Essen"},{form:"direkt danach",verb:"V<sub>た</sub> + ところです",de:"<ruby>食<rt>た</rt></ruby>べた ところです = habe gerade fertig gegessen"}],
   pattern:{slots:[[{text:"Subjekt は",role:"subj"},{text:"V-辞書",role:"verb",label:"gleich"},{text:"ところです",role:"actor",label:"Phase: vorher"}],[{text:"V-ている",role:"verb",label:"laufend"},{text:"ところです",role:"actor",label:"Phase: mittendrin"}],[{text:"V-た",role:"verb",label:"fertig"},{text:"ところです",role:"actor",label:"Phase: gerade beendet"}]],gloss:"3 Phasen einer Handlung: 辞書形 = im Begriff zu V (vorher) / ている = während V / た = gerade abgeschlossen."},
   ex:[{jp:"<ruby>今<rt>いま</rt></ruby>から ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べる ところです。",de:"Ich werde gleich essen. [vorher]"},{jp:"<ruby>今<rt>いま</rt></ruby> ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べて いる ところです。",de:"Ich bin gerade beim Essen. [mittendrin]"},{jp:"ご<ruby>飯<rt>はん</rt></ruby>を <ruby>食<rt>た</rt></ruby>べた ところです。",de:"Ich habe gerade fertig gegessen. [direkt danach]"}],
   note:"💡 ところ = wörtlich »Stelle/Punkt«. Hier: Punkt im Verlauf der Handlung. Sehr präzise Zeitangabe."},
  {l:46, t:"V た ばかりです", de:"Habe gerade erst …",
   rule:"Drückt aus, dass eine Handlung VOR KURZEM (subjektiv) erfolgte. Nicht objektiv »vor 5 Min«, sondern »ich empfinde es als gerade erst«.",
   build:[{form:"Anschluss",verb:"V<sub>た</sub> + ばかりです",de:"hab gerade erst V"},{form:"vs. たところ",verb:"たところ = direkt danach (objektiv)",de:""},{form:"vs. たばかり",verb:"たばかり = gefühlt vor kurzem",de:"auch vor Tagen/Wochen möglich"}],
   pattern:{slots:[{text:"Subjekt は",role:"subj"},{text:"V-た",role:"verb",label:"V getan"},{text:"ばかりです",role:"actor",label:"gerade erst"}],gloss:"»Ich habe [V] gerade erst (subjektiv) getan.« — Empfindung des Sprechers, was »kürzlich« heißt."},
   ex:[{jp:"<ruby>日本<rt>にほん</rt></ruby>に <ruby>来<rt>き</rt></ruby>た ばかりです。",de:"Ich bin gerade erst nach Japan gekommen. [auch wenn vor Wochen]"},{jp:"この パソコンを <ruby>買<rt>か</rt></ruby>った ばかりです。",de:"Ich habe diesen PC erst kürzlich gekauft."},{jp:"さっき <ruby>食<rt>た</rt></ruby>べた ばかりですから、おなかが いっぱいです。",de:"Ich habe gerade gegessen, deshalb bin ich satt."}],
   note:"💡 Vergleich: たところ = objektiv-zeitlich gerade. たばかり = subjektiv-gefühlt kürzlich (kann auch Wochen sein)."},
  {l:46, t:"V<ruby>普通形<rt>ふつうけい</rt></ruby> + はずです", de:"Es müsste / sollte (so) sein …",
   rule:"Starke Vermutung mit Begründung (~90%). Der Sprecher hat einen logischen Grund anzunehmen, dass etwas zutrifft. Bei な-Adj: な + はず. Bei N: の + はず.",
   build:[{form:"Verb",verb:"V<sub>普通形</sub> + はずです",de:"müsste V"},{form:"い-Adj",verb:"い-Adj + はずです",de:""},{form:"な-Adj",verb:"な-Adj + な + はず",de:"<ruby>元気<rt>げんき</rt></ruby>な はず"},{form:"Nomen",verb:"N + の + はず",de:"<ruby>学生<rt>がくせい</rt></ruby>の はず"},{form:"Verneinung",verb:"〜ない はずです / 〜はずが ない",de:"sollte nicht V / kann nicht sein"}],
   pattern:{slots:[{text:"Begründung",role:"cond",label:"weil …"},{text:"。",role:"plain"},{text:"Vermutung (Plain)",role:"verb"},{text:"はずです",role:"actor",label:"müsste so sein"}],gloss:"»Es müsste [Inhalt] sein.« — der Sprecher schlussfolgert aus Wissen/Indizien (~90% sicher)."},
   ex:[{jp:"<ruby>田中<rt>たなか</rt></ruby>さんは <ruby>会議<rt>かいぎ</rt></ruby>に <ruby>来<rt>く</rt></ruby>る はずです。",de:"Frau Tanaka müsste zur Besprechung kommen."},{jp:"<ruby>銀行<rt>ぎんこう</rt></ruby>は <ruby>3時<rt>さんじ</rt></ruby>まで <ruby>開<rt>あ</rt></ruby>いて いる はずです。",de:"Die Bank müsste bis 3 Uhr offen sein."},{jp:"こんな <ruby>所<rt>ところ</rt></ruby>に <ruby>彼<rt>かれ</rt></ruby>が いる はずが ない。",de:"Es kann nicht sein, dass er an so einem Ort ist."}],
   note:"💡 Sicherheits-Skala: かもしれない (~30-50%) < でしょう (~70-80%) < はずです (~90%, mit Logik). はず braucht IMMER eine Begründung."},
  {l:47, t:"Plain + そうです (Hörensagen)", de:"Es heißt, dass … / Man sagt, dass …",
   rule:"Hörensagen / Information aus zweiter Hand. ⚠️ NICHT mit L40/L43 そうです verwechseln (das war Anschein)! Hier: Plain-Form + そうです. Quelle oft mit によると oder の話では.",
   build:[{form:"Anschluss",verb:"Plain-Form + そうです",de:"es heißt, dass …"},{form:"Verb",verb:"<ruby>降<rt>ふ</rt></ruby>る + そうです",de:"es heißt, dass es regnet"},{form:"い-Adj",verb:"い-Adj + そうです",de:"おいしい そうです = soll lecker sein"},{form:"な-Adj",verb:"な-Adj + だ + そうです",de:"<ruby>元気<rt>げんき</rt></ruby>だ そうです"},{form:"Nomen",verb:"N + だ + そうです",de:"<ruby>学生<rt>がくせい</rt></ruby>だ そうです"},{form:"Quelle",verb:"〜に よると / 〜の <ruby>話<rt>はなし</rt></ruby>では",de:"laut … / nach den Worten …"}],
   pattern:{slots:[{text:"Quelle に よると",role:"actor",label:"laut wem"},{text:"、",role:"plain"},{text:"Inhalt (Plain)",role:"verb"},{text:"そうです",role:"actor",label:"angeblich"}],gloss:"»Laut [Quelle] [Inhalt].« — der Sprecher gibt nur weiter, was er gehört hat."},
   ex:[{jp:"<ruby>天気予報<rt>てんきよほう</rt></ruby>に よると、<ruby>明日<rt>あした</rt></ruby>は <ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>る そうです。",de:"Laut Wetterbericht soll es morgen regnen."},{jp:"<ruby>田中<rt>たなか</rt></ruby>さんは <ruby>来週<rt>らいしゅう</rt></ruby> <ruby>結婚<rt>けっこん</rt></ruby>する そうです。",de:"Frau Tanaka soll nächste Woche heiraten."},{jp:"あの <ruby>店<rt>みせ</rt></ruby>は <ruby>有名<rt>ゆうめい</rt></ruby>だ そうです。",de:"Jenes Geschäft soll berühmt sein."}],
   note:"⚠️ そうです gibt's in 3 Bedeutungen: ① Anschein bei Adj (L40, おいし<b>そう</b>), ② Anschein bei Verb (L43, ます-Stamm 降り<b>そう</b>), ③ Hörensagen (L47, Plain 降る<b>そう</b>). Bildung & Inhalt unterscheiden sie!"},
  {l:47, t:"Plain + ようです (Anschein/Vermutung)", de:"Es scheint, als ob … (eigene Vermutung)",
   rule:"Eigene Schlussfolgerung des Sprechers aus eigenen Beobachtungen. Bei な-Adj: な+ようです. Bei N: の+ようです. In Konversation auch みたいです (informeller).",
   build:[{form:"Verb/い-Adj",verb:"V<sub>普通形</sub> / い-Adj + ようです",de:""},{form:"な-Adj",verb:"な-Adj + な + ようです",de:""},{form:"Nomen",verb:"N + の + ようです",de:""},{form:"informelle Variante",verb:"〜みたいです",de:"= ようです, lockerer"}],
   pattern:{slots:[{text:"(Beobachtung)",role:"cond",label:"Indizien"},{text:"Inhalt (Plain)",role:"verb"},{text:"ようです",role:"actor",label:"scheint so"}],gloss:"»Es scheint, als ob [Inhalt].« — eigene Schlussfolgerung aus eigener Wahrnehmung (im Gegensatz zu そうです/Hörensagen)."},
   ex:[{jp:"<ruby>外<rt>そと</rt></ruby>は <ruby>雨<rt>あめ</rt></ruby>が <ruby>降<rt>ふ</rt></ruby>って いる ようです。",de:"Es scheint draußen zu regnen. [Indizien: nasser Boden, Geräusche]"},{jp:"<ruby>田中<rt>たなか</rt></ruby>さんは <ruby>元気<rt>げんき</rt></ruby>な ようです。",de:"Frau Tanaka scheint gesund zu sein."},{jp:"だれも いない みたいです。",de:"Es scheint niemand da zu sein. [umg.]"}],
   note:"💡 Unterschied zu そうです: そう = HÖRENSAGEN (Quelle nennen). よう = EIGENE Schlussfolgerung aus Beobachtung. らしい (fortgeschritten) = Mischform."},
  {l:47, t:"〜<ruby>声<rt>こえ</rt></ruby>/<ruby>音<rt>おと</rt></ruby>/におい/<ruby>味<rt>あじ</rt></ruby> が します", de:"Es klingt/riecht/schmeckt nach …",
   rule:"Sinneswahrnehmung: します mit Sinnesnomen drückt aus, was man wahrnimmt. Subjekt der Wahrnehmung mit が markiert.",
   build:[{form:"hören",verb:"<ruby>声<rt>こえ</rt></ruby>/<ruby>音<rt>おと</rt></ruby>が します",de:"Stimme/Geräusch hörbar"},{form:"riechen",verb:"におい/<ruby>香<rt>かお</rt></ruby>りが します",de:"Geruch/Duft"},{form:"schmecken",verb:"<ruby>味<rt>あじ</rt></ruby>が します",de:"Geschmack"},{form:"fühlen",verb:"<ruby>感<rt>かん</rt></ruby>じが します",de:"Gefühl/Eindruck"}],
   pattern:{slots:[{text:"Beschreibung",role:"obj",label:"wie/was"},{text:"声/音/におい/味",role:"subj",label:"Sinn"},{text:"が",role:"plain"},{text:"します",role:"verb",label:"wahrnehmen"}],gloss:"»Es klingt/riecht/schmeckt nach [Beschreibung].« — Sinneswahrnehmung beschreiben."},
   ex:[{jp:"<ruby>外<rt>そと</rt></ruby>で <ruby>子供<rt>こども</rt></ruby>の <ruby>声<rt>こえ</rt></ruby>が します。",de:"Draußen hört man Kinderstimmen."},{jp:"いい においが しますね。",de:"Es riecht gut, oder?"},{jp:"この スープは <ruby>変<rt>へん</rt></ruby>な <ruby>味<rt>あじ</rt></ruby>が します。",de:"Diese Suppe schmeckt komisch."},{jp:"<ruby>地震<rt>じしん</rt></ruby>のような <ruby>感<rt>かん</rt></ruby>じが しました。",de:"Es fühlte sich wie ein Erdbeben an."}],
   note:"💡 Spezial-Konstruktion: します nicht im Sinn »machen«, sondern »(als Empfindung) auftreten«. Sinn-Nomen + が + します."},
  {l:48, t:"<ruby>使役形<rt>しえきけい</rt></ruby> (Kausativ-Form) — Bildung", de:"jemanden etwas tun lassen / machen lassen",
   rule:"Drückt aus, dass jemand jmd. anderes etwas TUN LÄSST oder ZWINGT, etwas zu tun. Gruppe I: u→a + せる. Gruppe II: る→させる. Unregelm.: する→させる, 来る→こさせる.",
   build:[{form:"Gr. I: u → a + せる",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>かせる",de:"schreiben lassen"},{form:"Gr. I",verb:"<ruby>飲<rt>の</rt></ruby>む → <ruby>飲<rt>の</rt></ruby>ませる",de:"trinken lassen"},{form:"Gr. I (う→わせる)",verb:"<ruby>言<rt>い</rt></ruby>う → <ruby>言<rt>い</rt></ruby>わせる",de:"sagen lassen"},{form:"Gr. II: る → させる",verb:"<ruby>食<rt>た</rt></ruby>べる → <ruby>食<rt>た</rt></ruby>べさせる",de:"essen lassen"},{form:"Unregelmäßig",verb:"する → させる / <ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>させる",de:""},{form:"Bedeutung",verb:"① zwingen (lassen) ② erlauben (lassen)",de:"Kontext entscheidet"}],
   pattern:{slots:[{text:"Boss は",role:"subj",label:"wer veranlasst"},{text:"Untergebener を/に",role:"actor",label:"wer tut"},{text:"V-Kausativ",role:"verb",label:"lassen"}],gloss:"»[Boss] lässt [Untergebenen] [V tun].« — der Boss veranlasst die Handlung. を/に: siehe nächste Karte."},
   ex:[{jp:"<ruby>母<rt>はは</rt></ruby>は <ruby>子供<rt>こども</rt></ruby>に <ruby>野菜<rt>やさい</rt></ruby>を <ruby>食<rt>た</rt></ruby>べさせました。",de:"Die Mutter ließ das Kind Gemüse essen. [zwingen oder erlauben]"},{jp:"<ruby>先生<rt>せんせい</rt></ruby>は <ruby>学生<rt>がくせい</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>ませました。",de:"Der Lehrer ließ die Schüler ein Buch lesen."},{jp:"<ruby>彼<rt>かれ</rt></ruby>は <ruby>子供<rt>こども</rt></ruby>を <ruby>遊<rt>あそ</rt></ruby>ばせました。",de:"Er ließ das Kind spielen."}],
   note:"⚠️ Kausativ + Passiv kombiniert (使役受身): V<sub>させ</sub>られる = »wurde gezwungen, V zu tun« (fortgeschritten)."},
  {l:48, t:"<ruby>使役形<rt>しえきけい</rt></ruby>: を vs. に", de:"Partikel-Unterschied beim Kausativ",
   rule:"Wahl zwischen を und に hängt vom Verb ab: bei intransitiven Verben → を (oder に), bei transitiven Verben → に (weil を schon vom Objekt belegt ist).",
   build:[{form:"intransitiv → を",verb:"<ruby>子供<rt>こども</rt></ruby>を <ruby>泣<rt>な</rt></ruby>かせる",de:"das Kind weinen lassen"},{form:"intransitiv → に",verb:"<ruby>子供<rt>こども</rt></ruby>に <ruby>泣<rt>な</rt></ruby>かせる",de:"erlaubend nuanciert"},{form:"transitiv → に",verb:"<ruby>子供<rt>こども</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>ませる",de:"das Kind ein Buch lesen lassen"},{form:"⚠ NIE",verb:"<ruby>子供<rt>こども</rt></ruby>を <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>ませる",de:"FALSCH! 2× を nicht möglich"}],
   pattern:{slots:[[{text:"Boss は",role:"subj",label:"intransitiv"},{text:"Untergebener",role:"actor"},{text:"を / に",role:"plain",label:"Wahl"},{text:"V-Kausativ",role:"verb"}],[{text:"Boss は",role:"subj",label:"transitiv"},{text:"Untergebener",role:"actor"},{text:"に",role:"plain",label:"Pflicht"},{text:"Objekt を",role:"obj"},{text:"V-Kausativ",role:"verb"}]],gloss:"Bei intransitiven Verben: を (Zwang-Nuance) oder に (Erlaubnis-Nuance). Bei transitiven Verben: zwingend に, weil を vom Objekt belegt ist."},
   ex:[{jp:"<ruby>父<rt>ちち</rt></ruby>は <ruby>子供<rt>こども</rt></ruby>を <ruby>遊<rt>あそ</rt></ruby>ばせました。",de:"Der Vater ließ das Kind spielen. [intransitiv: を]"},{jp:"<ruby>父<rt>ちち</rt></ruby>は <ruby>子供<rt>こども</rt></ruby>に <ruby>本<rt>ほん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>ませました。",de:"Der Vater ließ das Kind ein Buch lesen. [transitiv: に]"},{jp:"<ruby>先生<rt>せんせい</rt></ruby>は <ruby>学生<rt>がくせい</rt></ruby>に <ruby>漢字<rt>かんじ</rt></ruby>を <ruby>書<rt>か</rt></ruby>かせます。",de:"Der Lehrer lässt die Schüler Kanji schreiben."}],
   note:"💡 Faustregel: bei transitiven Verben (mit を-Objekt): zwingend に. Bei intransitiven: を (Zwang) oder に (Erlaubnis), je nach Nuance."},
  {l:49, t:"<ruby>尊敬語<rt>そんけいご</rt></ruby> (Respektsprache)", de:"Respektsprache — Spezialverben + お〜になる",
   rule:"Hebt die ANDERE Person hervor (höhergestellt). Drei Bildungswege: ① Spezialverben (z.B. <ruby>召<rt>め</rt></ruby>し<ruby>上<rt>あ</rt></ruby>がる = essen). ② Passiv-Form als Respekt. ③ Allgemeine Regel: お + V-Stamm + になる.",
   build:[{form:"Spezial: いる/<ruby>行<rt>い</rt></ruby>く/<ruby>来<rt>く</rt></ruby>る",verb:"いらっしゃる",de:"sein/gehen/kommen (Resp.)"},{form:"Spezial: <ruby>食<rt>た</rt></ruby>べる/<ruby>飲<rt>の</rt></ruby>む",verb:"<ruby>召<rt>め</rt></ruby>し<ruby>上<rt>あ</rt></ruby>がる",de:"essen/trinken (Resp.)"},{form:"Spezial: <ruby>言<rt>い</rt></ruby>う",verb:"おっしゃる",de:"sagen (Resp.)"},{form:"Spezial: する",verb:"なさる",de:"tun (Resp.)"},{form:"Spezial: <ruby>見<rt>み</rt></ruby>る",verb:"ご<ruby>覧<rt>らん</rt></ruby>に なる",de:"sehen (Resp.)"},{form:"Spezial: <ruby>知<rt>し</rt></ruby>る",verb:"ご<ruby>存<rt>ぞん</rt></ruby>じです",de:"wissen (Resp.)"},{form:"⚠ unregelm. ます",verb:"いらっしゃる → いらっしゃ<b>い</b>ます",de:"5 Verben (siehe L41)"},{form:"Allg. Regel",verb:"お + V<sub>マス</sub>-Stamm + に なる",de:"<ruby>使<rt>つか</rt></ruby>う → お<ruby>使<rt>つか</rt></ruby>いに なる"}],
   pattern:{slots:[{text:"höhergestellt は",role:"actor",label:"er/sie (Resp.)"},{text:"Inhalt",role:"obj"},{text:"V-Respekt",role:"verb",label:"höfl. Verb"}],gloss:"Hebt die HANDLUNG des HÖHERGESTELLTEN hervor — Respekt-Stufe für Kunden, Vorgesetzte, ältere Menschen."},
   ex:[{jp:"<ruby>社長<rt>しゃちょう</rt></ruby>は きょう <ruby>大阪<rt>おおさか</rt></ruby>へ いらっしゃいます。",de:"Der Firmenchef geht heute nach Osaka."},{jp:"どうぞ <ruby>召<rt>め</rt></ruby>し<ruby>上<rt>あ</rt></ruby>がって ください。",de:"Bitte essen Sie."},{jp:"<ruby>先生<rt>せんせい</rt></ruby>は あした お<ruby>休<rt>やす</rt></ruby>みに なります。",de:"Der Lehrer macht morgen frei. [allg. Regel: お + 休み + になる]"}],
   note:"💡 Wichtigste Spezialverben auswendig lernen — sie machen 80% der Respektsprache aus. Allg. Regel お〜になる nur, wenn KEIN Spezialverb existiert."},
  {l:49, t:"<ruby>受身形<rt>うけみけい</rt></ruby> als <ruby>尊敬語<rt>そんけいご</rt></ruby>", de:"Passivform als Respektsform",
   rule:"Die Passiv-Form (L37) hat eine ZWEITE Bedeutung: leichte Respektsform, schwächer als お〜になる aber höflicher als die Standardform. Häufig im Alltag und Berufsleben.",
   build:[{form:"Bildung",verb:"= Passiv-Form (L37)",de:"u→aれる / る→られる"},{form:"Beispiel",verb:"<ruby>書<rt>か</rt></ruby>く → <ruby>書<rt>か</rt></ruby>かれる",de:"schreiben (Resp.)"},{form:"Beispiel",verb:"<ruby>来<rt>く</rt></ruby>る → <ruby>来<rt>こ</rt></ruby>られる",de:"kommen (Resp.)"},{form:"Stärken-Skala",verb:"normal < <b>Passiv-Resp</b> < お〜になる < Spezialverb",de:"steigend höflich"}],
   pattern:{slots:[{text:"höhergestellt は",role:"actor",label:"er/sie"},{text:"V-Passiv",role:"verb",label:"höfl. Resp."}],gloss:"Mittlere Respekt-Stufe: höflicher als die Standardform, weicher als お〜になる. Oft in beruflichen Gesprächen."},
   ex:[{jp:"<ruby>社長<rt>しゃちょう</rt></ruby>は <ruby>毎朝<rt>まいあさ</rt></ruby> <ruby>新聞<rt>しんぶん</rt></ruby>を <ruby>読<rt>よ</rt></ruby>まれます。",de:"Der Firmenchef liest jeden Morgen Zeitung. [Resp. via Passiv]"},{jp:"<ruby>先生<rt>せんせい</rt></ruby>は あした <ruby>来<rt>こ</rt></ruby>られますか。",de:"Kommen Sie, Lehrer/in, morgen?"},{jp:"<ruby>部長<rt>ぶちょう</rt></ruby>は もう <ruby>帰<rt>かえ</rt></ruby>られました。",de:"Der Abteilungsleiter ist schon heimgegangen."}],
   note:"⚠️ Form ist IDENTISCH mit Passiv (L37) und Potential bei Gr. II (L27, 食べられる) — nur der Kontext unterscheidet die drei Bedeutungen!"},
  {l:49, t:"お + V-Stamm + ください", de:"höfliche Aufforderung",
   rule:"Sehr höfliche Bitte/Aufforderung. Höher als 〜てください. Bei Suru-Verben: ご + N + ください. Häufig in Ansagen, im Service-Bereich, bei Produkt-Anweisungen.",
   build:[{form:"normale Verben",verb:"お + V<sub>マス</sub>-Stamm + ください",de:"<ruby>待<rt>ま</rt></ruby>つ → お <ruby>待<rt>ま</rt></ruby>ち ください"},{form:"Suru-Verben",verb:"ご + N + ください",de:"<ruby>注意<rt>ちゅうい</rt></ruby> → ご <ruby>注意<rt>ちゅうい</rt></ruby> ください"},{form:"Höflichkeits-Skala",verb:"〜てください < お〜ください < お〜くださいませ",de:"steigend"}],
   pattern:{slots:[{text:"お/ご",role:"actor",label:"Resp.-Präfix"},{text:"V-Stamm / N",role:"verb",label:"Inhalt"},{text:"ください",role:"plain",label:"bitte"}],gloss:"»Bitte tun Sie [V] (sehr höflich).« — sehr formelle, respektvolle Aufforderung."},
   ex:[{jp:"<ruby>少々<rt>しょうしょう</rt></ruby> お<ruby>待<rt>ま</rt></ruby>ち ください。",de:"Bitte warten Sie einen Moment."},{jp:"こちらに お<ruby>名前<rt>なまえ</rt></ruby>を お<ruby>書<rt>か</rt></ruby>き ください。",de:"Bitte schreiben Sie hier Ihren Namen hin."},{jp:"ご<ruby>注意<rt>ちゅうい</rt></ruby> ください。",de:"Bitte achten Sie darauf. [Suru-Verb: ご+N+ください]"}],
   note:"💡 Beim Service / am Bahnhof / im Flugzeug Standardform. Im Alltag mit Freunden zu förmlich."},
  {l:50, t:"お + V-Stamm + します / いたします", de:"Bescheidenheits-Bildung (Regel)",
   rule:"<ruby>謙譲語<rt>けんじょうご</rt></ruby>: eigene Handlungen DEMÜTIG ausdrücken (= sich kleiner machen, um Respekt zu zeigen). Form: お + V<sub>マス</sub>-Stamm + します (oder höflicher いたします). Bei Suru-Verben: ご + N + します/いたします.",
   build:[{form:"normale Verben",verb:"お + V<sub>マス</sub>-Stamm + します/いたします",de:""},{form:"Beispiel",verb:"<ruby>持<rt>も</rt></ruby>つ → お <ruby>持<rt>も</rt></ruby>ち します",de:"ich trage (für Sie)"},{form:"Beispiel",verb:"<ruby>送<rt>おく</rt></ruby>る → お <ruby>送<rt>おく</rt></ruby>り いたします",de:"ich begleite (höfl.)"},{form:"Suru-Verben",verb:"ご + N + します/いたします",de:"<ruby>説明<rt>せつめい</rt></ruby> → ご <ruby>説明<rt>せつめい</rt></ruby> いたします"},{form:"Skala",verb:"します < いたします",de:"いたします höflicher"}],
   pattern:{slots:[{text:"ich (Subjekt) は",role:"subj",label:"ich, demütig"},{text:"höhergestellt に/を",role:"actor",label:"für wen"},{text:"お/ご",role:"plain",label:"Demuts-Präfix"},{text:"V-Stamm / N",role:"verb"},{text:"します/いたします",role:"verb",label:"demütig"}],gloss:"»Ich [V] (demütig für Sie).« — eigene Handlung wird demütig ausgedrückt, um den anderen zu erhöhen."},
   ex:[{jp:"かばんを お <ruby>持<rt>も</rt></ruby>ち します。",de:"Ich trage die Tasche (für Sie)."},{jp:"<ruby>駅<rt>えき</rt></ruby>まで お <ruby>送<rt>おく</rt></ruby>り いたします。",de:"Ich werde Sie zum Bahnhof bringen."},{jp:"あした ご <ruby>連絡<rt>れんらく</rt></ruby> いたします。",de:"Ich werde Sie morgen kontaktieren."}],
   note:"💡 ⚠️ Wichtig: 謙譲語 NUR für eigene Handlungen oder Handlungen der eigenen Gruppe (Familie, Firma) verwenden. Niemals für die Handlungen der anderen Person!"},
  {l:50, t:"<ruby>謙譲語<rt>けんじょうご</rt></ruby> — Spezialverben", de:"Spezielle Bescheidenheitsverben",
   rule:"Wie bei Sonkeigo gibt es auch hier wichtige Spezialverben, die häufiger benutzt werden als die allgemeine Regel お〜します.",
   build:[{form:"<ruby>行<rt>い</rt></ruby>く/<ruby>来<rt>く</rt></ruby>る",verb:"<ruby>参<rt>まい</rt></ruby>る",de:"gehen/kommen (demütig)"},{form:"いる",verb:"おる",de:"sein (demütig)"},{form:"<ruby>言<rt>い</rt></ruby>う",verb:"<ruby>申<rt>もう</rt></ruby>す / <ruby>申<rt>もう</rt></ruby>し<ruby>上<rt>あ</rt></ruby>げる",de:"sagen (demütig)"},{form:"する",verb:"いたす",de:"tun (demütig)"},{form:"<ruby>食<rt>た</rt></ruby>べる/<ruby>飲<rt>の</rt></ruby>む/もらう",verb:"いただく",de:"essen/trinken/bekommen"},{form:"<ruby>見<rt>み</rt></ruby>る",verb:"<ruby>拝見<rt>はいけん</rt></ruby>する",de:"sehen/lesen (demütig)"},{form:"<ruby>会<rt>あ</rt></ruby>う",verb:"お <ruby>目<rt>め</rt></ruby>に かかる",de:"treffen (demütig)"},{form:"<ruby>知<rt>し</rt></ruby>る",verb:"<ruby>存<rt>ぞん</rt></ruby>じる / <ruby>存<rt>ぞん</rt></ruby>じて おる",de:"wissen (demütig)"},{form:"あげる",verb:"さしあげる",de:"geben (demütig, L41)"}],
   pattern:{slots:[{text:"ich は",role:"subj",label:"ich, demütig"},{text:"Inhalt",role:"obj"},{text:"V-Demut-Spezial",role:"verb",label:"demütige Form"}],gloss:"»Ich [V] (mit demütigem Spezialverb).« — die wichtigsten 8-9 Verben auswendig lernen."},
   ex:[{jp:"<ruby>私<rt>わたし</rt></ruby>は ミラーと <ruby>申<rt>もう</rt></ruby>します。",de:"Ich heiße Miller. [demütige Selbstvorstellung]"},{jp:"あした そちらへ <ruby>参<rt>まい</rt></ruby>ります。",de:"Ich werde morgen zu Ihnen kommen."},{jp:"お <ruby>手紙<rt>てがみ</rt></ruby>を <ruby>拝見<rt>はいけん</rt></ruby>しました。",de:"Ich habe Ihren Brief gelesen."},{jp:"よろしく お <ruby>願<rt>ねが</rt></ruby>い いたします。",de:"Ich bitte Sie um Ihr Wohlwollen."}],
   note:"💡 Diese Spezialverben sind im Berufsalltag PFLICHT — bei Vorstellungen, Begrüßungen, Telefongesprächen, Mails. Lerne mindestens 申す, 参る, いたす, いただく."},
  {l:50, t:"<ruby>丁寧語<rt>ていねいご</rt></ruby> / Höflichkeitsstufen Übersicht", de:"Allgemeine Höflichkeit + 3 Stufen der Keigo",
   rule:"<ruby>丁寧語<rt>ていねいご</rt></ruby> = grundlegende Höflichkeit (です/ます). Darüber: <ruby>尊敬語<rt>そんけいご</rt></ruby> (Respekt für andere), <ruby>謙譲語<rt>けんじょうご</rt></ruby> (Demut für sich). Plus: お/ご-Präfixe für Nomen.",
   build:[{form:"① <ruby>丁寧語<rt>ていねいご</rt></ruby>",verb:"です/ます-Form",de:"Grundhöflichkeit"},{form:"② <ruby>尊敬語<rt>そんけいご</rt></ruby>",verb:"über die ANDERE Person",de:"sie wird erhöht"},{form:"③ <ruby>謙譲語<rt>けんじょうご</rt></ruby>",verb:"über MICH SELBST",de:"ich mache mich klein"},{form:"+ お/ご-Nomen",verb:"お<ruby>名前<rt>なまえ</rt></ruby> / ご<ruby>家族<rt>かぞく</rt></ruby>",de:"höfliche Nomen-Präfixe"}],
   pattern:{slots:[[{text:"丁寧語: 行きます",role:"verb",label:"höfl. neutral"},{text:"  →  geht",role:"plain"}],[{text:"尊敬語: いらっしゃいます",role:"verb",label:"Respekt für ANDEREN"},{text:"  →  Sie gehen",role:"plain"}],[{text:"謙譲語: 参ります",role:"verb",label:"Demut für MICH"},{text:"  →  ich gehe",role:"plain"}]],gloss:"3 Achsen: ① neutral höflich (alle Personen) / ② Respekt-Form (für andere) / ③ Demut-Form (für mich). Wichtig: nicht mischen!"},
   ex:[{jp:"<ruby>先生<rt>せんせい</rt></ruby>は <ruby>来週<rt>らいしゅう</rt></ruby> アメリカへ いらっしゃいます。",de:"Der Lehrer geht nächste Woche in die USA. [尊敬語]"},{jp:"<ruby>私<rt>わたし</rt></ruby>は <ruby>来週<rt>らいしゅう</rt></ruby> アメリカへ <ruby>参<rt>まい</rt></ruby>ります。",de:"Ich gehe nächste Woche in die USA. [謙譲語]"},{jp:"お <ruby>名前<rt>なまえ</rt></ruby>は <ruby>何<rt>なん</rt></ruby>で いらっしゃいますか。",de:"Wie ist Ihr werter Name? [お+尊敬語]"}],
   note:"⚠️ Keigo-Faustregel: 1. Ist die Person höhergestellt? Wenn ja → 尊敬語 für ihre Handlungen, 謙譲語 für meine. 2. Niemals mischen: NIE 尊敬語 für mich selbst (= falsch!). 3. Spezialverben gehen vor allgemeiner Regel."}

];

// ============ RENDER ============
const grid = document.getElementById('grid');
const overview = document.getElementById('overview');
const lessonGrid = document.getElementById('lessonGrid');
const cheatsBlock = document.getElementById('cheats');
const cheatToggle = document.getElementById('cheatToggle');
const search = document.getElementById('search');
const lessonFilter = document.getElementById('lessonFilter');
const stats = document.getElementById('stats');
const backBtn = document.getElementById('backBtn');

// ============ STATS SYSTEM (localStorage) ============
const STORAGE_KEY = 'minna_card_stats_v1';

function loadStats() {
  try {
    const data = localStorage.getItem(STORAGE_KEY);
    return data ? JSON.parse(data) : {};
  } catch (e) {
    console.warn('Could not load stats:', e);
    return {};
  }
}

function saveStats(s) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
  } catch (e) {
    console.warn('Could not save stats:', e);
  }
}

// Karte-ID = Lektion + Titel (eindeutig)
function cardId(card) {
  return 'L' + card.l + ':' + card.t.replace(/<[^>]+>/g, '').substring(0, 60);
}

function getCardStatus(card) {
  const all = loadStats();
  const id = cardId(card);
  return all[id] || { status: 'new', good: 0, bad: 0, lastSeen: null };
}

function setCardRating(card, rating) {
  const all = loadStats();
  const id = cardId(card);
  const cur = all[id] || { status: 'new', good: 0, bad: 0, lastSeen: null };
  if (rating === 'good') {
    cur.good += 1;
    cur.status = 'good';
  } else if (rating === 'bad') {
    cur.bad += 1;
    cur.status = 'bad';
  }
  cur.lastSeen = Date.now();
  all[id] = cur;
  saveStats(all);
}

function getStatusIcon(status) {
  if (status === 'good') return '✅';
  if (status === 'bad') return '🔴';
  return '';
}

function computeOverallStats() {
  const all = loadStats();
  let good = 0, bad = 0, neu = 0;
  CARDS.forEach(card => {
    const id = cardId(card);
    const s = all[id];
    if (!s || s.status === 'new') neu++;
    else if (s.status === 'good') good++;
    else if (s.status === 'bad') bad++;
  });
  return { good, bad, neu, total: CARDS.length };
}

function computeLessonStats(lessonNum) {
  const all = loadStats();
  const lessonCards = CARDS.filter(c => c.l === lessonNum);
  let good = 0, bad = 0, neu = 0;
  lessonCards.forEach(card => {
    const id = cardId(card);
    const s = all[id];
    if (!s || s.status === 'new') neu++;
    else if (s.status === 'good') good++;
    else if (s.status === 'bad') bad++;
  });
  return { good, bad, neu, total: lessonCards.length };
}

function updateStatsCard() {
  const s = computeOverallStats();
  document.getElementById('statGood').textContent = s.good;
  document.getElementById('statBad').textContent = s.bad;
  document.getElementById('statNew').textContent = s.neu;
}

// Reset
document.getElementById('statsReset').addEventListener('click', () => {
  if (confirm('Wirklich alle Statistiken zurücksetzen? Das kann nicht rückgängig gemacht werden.')) {
    localStorage.removeItem(STORAGE_KEY);
    updateStatsCard();
    renderOverview();
    render();
  }
});

// ============ REVIEW MODE ============
const reviewBtn = document.getElementById('reviewBtn');
const reviewModal = document.getElementById('reviewModal');
const reviewMode = document.getElementById('reviewMode');
const reviewClose = document.getElementById('reviewClose');
const reviewCancel = document.getElementById('reviewCancel');
const reviewStart = document.getElementById('reviewStart');
const reviewCard = document.getElementById('reviewCard');
const reviewFront = document.getElementById('reviewFront');
const reviewBack = document.getElementById('reviewBack');
const reviewFlipHint = document.getElementById('reviewFlipHint');
const reviewButtons = document.getElementById('reviewButtons');
const reviewCounter = document.getElementById('reviewCounter');
const reviewGoodCount = document.getElementById('reviewGood');
const reviewAgainCount = document.getElementById('reviewAgain');
const reviewFinished = document.getElementById('reviewFinished');
const reviewFinishedStats = document.getElementById('reviewFinishedStats');
const reviewFinishedClose = document.getElementById('reviewFinishedClose');
const btnGood = document.getElementById('btnGood');
const btnBad = document.getElementById('btnBad');
const lessonMultiSelect = document.getElementById('lessonMultiSelect');
const lessonMultiGrid = document.getElementById('lessonMultiGrid');

let reviewQueue = [];
let reviewIndex = 0;
let reviewSession = { good: 0, bad: 0 };
let selectedLessons = new Set();

function openReviewModal() {
  // Update counts
  const s = computeOverallStats();
  document.getElementById('countAll').textContent = `${s.total} Karten`;
  document.getElementById('countUnrated').textContent = `${s.neu} Karten`;
  document.getElementById('countAgain').textContent = `${s.bad} Karten`;
  
  // Build lesson grid
  selectedLessons.clear();
  const allLessons = [...new Set(CARDS.map(c => c.l))].sort((a,b)=>a-b);
  lessonMultiGrid.innerHTML = '';
  allLessons.forEach(l => {
    const div = document.createElement('div');
    div.className = 'lesson-multi-item';
    div.textContent = 'L' + l;
    div.addEventListener('click', () => {
      if (selectedLessons.has(l)) {
        selectedLessons.delete(l);
        div.classList.remove('selected');
      } else {
        selectedLessons.add(l);
        div.classList.add('selected');
      }
    });
    lessonMultiGrid.appendChild(div);
  });
  
  // Reset
  document.querySelector('input[name="reviewFilter"][value="all"]').checked = true;
  lessonMultiSelect.classList.add('hidden');
  
  reviewModal.classList.remove('hidden');
}

// Filter radio change
document.querySelectorAll('input[name="reviewFilter"]').forEach(r => {
  r.addEventListener('change', () => {
    if (r.value === 'lesson' && r.checked) {
      lessonMultiSelect.classList.remove('hidden');
    } else if (r.checked) {
      lessonMultiSelect.classList.add('hidden');
    }
  });
});

reviewBtn.addEventListener('click', openReviewModal);
reviewCancel.addEventListener('click', () => reviewModal.classList.add('hidden'));

reviewStart.addEventListener('click', () => {
  const filter = document.querySelector('input[name="reviewFilter"]:checked').value;
  let pool = [];
  
  if (filter === 'all') {
    pool = [...CARDS];
  } else if (filter === 'unrated') {
    pool = CARDS.filter(c => getCardStatus(c).status === 'new');
  } else if (filter === 'again') {
    pool = CARDS.filter(c => getCardStatus(c).status === 'bad');
  } else if (filter === 'lesson') {
    if (selectedLessons.size === 0) {
      alert('Bitte mindestens eine Lektion auswählen.');
      return;
    }
    pool = CARDS.filter(c => selectedLessons.has(c.l));
  }
  
  if (pool.length === 0) {
    alert('Keine Karten gefunden für diese Auswahl.');
    return;
  }
  
  // Shuffle
  reviewQueue = pool.sort(() => Math.random() - 0.5);
  reviewIndex = 0;
  reviewSession = { good: 0, bad: 0 };
  
  reviewModal.classList.add('hidden');
  reviewMode.classList.remove('hidden');
  reviewFinished.classList.add('hidden');
  showReviewCard();
});

function showReviewCard() {
  if (reviewIndex >= reviewQueue.length) {
    showReviewFinished();
    return;
  }
  
  const card = reviewQueue[reviewIndex];
  
  // Front side
  reviewFront.innerHTML = `
    <div class="rc-title">${card.t}</div>
    <div class="rc-de">${card.de}</div>
    <div class="rc-lesson">Lektion ${card.l}</div>
  `;
  
  // Back side
  let backHtml;
  if (card.pattern) {
    // Neue 4-Sektionen-Struktur für L26+
    backHtml = buildSectionedBack(card);
  } else {
    backHtml = `<div class="rc-rule">${card.rule}</div>`;
    if (card.conj && card.conj.length > 0) {
      backHtml += '<div class="rc-examples"><table style="width:100%;border-collapse:collapse"><tbody>';
      card.conj.forEach(row => {
        backHtml += `<tr><td style="padding:.2rem .3rem;font-size:.85rem">${row.form}</td><td style="padding:.2rem .3rem;font-weight:500">${row.verb}</td><td style="padding:.2rem .3rem;font-size:.8rem;color:#5a4530">${row.de}</td></tr>`;
      });
      backHtml += '</tbody></table></div>';
    }
    if (card.ex && card.ex.length > 0) {
      backHtml += '<div class="rc-examples">';
      card.ex.forEach(ex => {
        backHtml += `<div class="rc-ex"><div class="rc-ex-jp">${ex.jp}</div><div class="rc-ex-de">${ex.de}</div></div>`;
      });
      backHtml += '</div>';
    }
    if (card.note) {
      backHtml += `<div class="rc-note">${card.note}</div>`;
    }
  }
  reviewBack.innerHTML = backHtml;
  
  // Reset state
  reviewBack.classList.add('hidden');
  reviewFlipHint.classList.remove('hidden');
  reviewButtons.classList.add('hidden');
  
  // Update progress
  reviewCounter.textContent = `${reviewIndex + 1} / ${reviewQueue.length}`;
  reviewGoodCount.textContent = `✅ ${reviewSession.good}`;
  reviewAgainCount.textContent = `🔴 ${reviewSession.bad}`;
}

reviewCard.addEventListener('click', () => {
  if (reviewBack.classList.contains('hidden')) {
    reviewBack.classList.remove('hidden');
    reviewFlipHint.classList.add('hidden');
    reviewButtons.classList.remove('hidden');
  }
});

btnGood.addEventListener('click', (e) => {
  e.stopPropagation();
  setCardRating(reviewQueue[reviewIndex], 'good');
  reviewSession.good++;
  reviewIndex++;
  showReviewCard();
});

btnBad.addEventListener('click', (e) => {
  e.stopPropagation();
  setCardRating(reviewQueue[reviewIndex], 'bad');
  reviewSession.bad++;
  reviewIndex++;
  showReviewCard();
});

function showReviewFinished() {
  document.querySelector('.review-card-area').style.display = 'none';
  document.querySelector('.review-actions').style.display = 'none';
  reviewFinished.classList.remove('hidden');
  
  const total = reviewSession.good + reviewSession.bad;
  const pct = total > 0 ? Math.round(reviewSession.good / total * 100) : 0;
  reviewFinishedStats.innerHTML = `
    Du hast <b>${total} Karten</b> wiederholt.<br>
    ✅ ${reviewSession.good} kann ich · 🔴 ${reviewSession.bad} nochmal<br>
    Erfolgsquote: <b>${pct}%</b>
  `;
}

function closeReviewMode() {
  reviewMode.classList.add('hidden');
  document.querySelector('.review-card-area').style.display = '';
  document.querySelector('.review-actions').style.display = '';
  reviewFinished.classList.add('hidden');
  // Refresh
  updateStatsCard();
  renderOverview();
  render();
}

reviewClose.addEventListener('click', () => {
  if (reviewIndex < reviewQueue.length && reviewSession.good + reviewSession.bad > 0) {
    if (!confirm('Wiederholen wirklich beenden? Dein bisheriger Fortschritt wird gespeichert.')) return;
  }
  closeReviewMode();
});
reviewFinishedClose.addEventListener('click', closeReviewMode);

// Kurz-Themen pro Lektion (für Übersichts-Kacheln)
const TOPICS = {
  1:"Vorstellung", 2:"これ/それ/あれ", 3:"Orte", 4:"Uhrzeit", 5:"Bewegung",
  6:"を & で", 7:"Geben/Bekommen", 8:"Adjektive", 9:"好き & から", 10:"います/あります",
  11:"Zählwörter", 12:"Vergangenheit", 13:"〜たい/欲しい", 14:"て-Form", 15:"〜ています",
  16:"〜てから", 17:"ない-Form", 18:"辞書形/ことが", 19:"た-Form/たり", 20:"Plain-Form",
  21:"〜と思う", 22:"Relativsätze", 23:"とき & と", 24:"くれる/あげる", 25:"たら/ても",
  26:"んです", 27:"Potential", 28:"〜ながら/し", 29:"〜てしまう", 30:"〜てある",
  31:"Volitional", 32:"〜ほうがいい", 33:"Imperativ", 34:"〜とおりに/あとで", 35:"ば-Form/なら",
  36:"ように/ために", 37:"Passiv", 38:"の/こと", 39:"〜て(Grund)", 40:"Frage in Satz",
  41:"Keigo geben", 42:"ために/Quantifier", 43:"〜そう (Anschein)", 44:"〜すぎ/やすい", 45:"場合/のに",
  46:"ところ/ばかり", 47:"〜そう (Hörensagen)", 48:"Kausativ", 49:"尊敬語", 50:"謙譲語"
};

const lessons = [...new Set(CARDS.map(c => c.l))].sort((a,b)=>a-b);

// Filter-Dropdown füllen — Cheat-Sheets ZUERST, dann Lektionen
const cheatOpt = document.createElement('option');
cheatOpt.value = 'cheats';
cheatOpt.textContent = '📖 Cheat-Sheets';
lessonFilter.appendChild(cheatOpt);

lessons.forEach(l => {
  const opt = document.createElement('option');
  opt.value = l;
  opt.textContent = `Lektion ${l}${TOPICS[l] ? ' · ' + TOPICS[l] : ''}`;
  lessonFilter.appendChild(opt);
});

// Übersichts-Kacheln rendern
function renderOverview() {
  lessonGrid.innerHTML = '';
  const counts = {};
  CARDS.forEach(c => { counts[c.l] = (counts[c.l] || 0) + 1; });
  lessons.forEach(l => {
    const lstats = computeLessonStats(l);
    const learned = lstats.good;
    const pct = lstats.total > 0 ? Math.round(learned / lstats.total * 100) : 0;
    
    const tile = document.createElement('button');
    tile.className = 'lesson-tile';
    tile.innerHTML = `
      <span class="num">L${String(l).padStart(2,'0')}</span>
      <span class="topic">${TOPICS[l] || ''}</span>
      <span class="count">${counts[l]} Karte${counts[l]!==1?'n':''}</span>
      <div class="tile-progress"><div class="tile-progress-bar" style="width:${pct}%"></div></div>
      <span class="tile-progress-text">${learned}/${lstats.total} ✅${lstats.bad > 0 ? ' · '+lstats.bad+' 🔴' : ''}</span>
    `;
    tile.addEventListener('click', () => {
      lessonFilter.value = l;
      render();
      window.scrollTo({top:document.querySelector('.controls').offsetTop, behavior:'smooth'});
    });
    lessonGrid.appendChild(tile);
  });
  updateStatsCard();
}
renderOverview();

function buildConjTable(conj) {
  if (!conj || conj.length === 0) return '';
  let html = '<table class="conj-table"><thead><tr><th>Form</th><th>Japanisch</th><th>Bedeutung</th></tr></thead><tbody>';
  conj.forEach(row => {
    html += `<tr><td>${row.form}</td><td>${row.verb}</td><td>${row.de}</td></tr>`;
  });
  html += '</tbody></table>';
  return html;
}

// Satzbauplan-Slots als visuelles Schema rendern
function buildPattern(pattern) {
  if (!pattern || !pattern.slots) return '';
  let html = '<div class="sec"><span class="sec-label">② Satzbauplan</span>';
  // Mehrere Zeilen-Varianten möglich (Array von Arrays) oder einzelne Zeile (Array)
  const lines = Array.isArray(pattern.slots[0]) ? pattern.slots : [pattern.slots];
  lines.forEach(line => {
    html += '<div class="pattern-box"><div class="pattern-line">';
    line.forEach(slot => {
      const cls = slot.role || 'plain';
      const label = slot.label ? `<span class="slot-label">${slot.label}</span>` : '';
      html += `<span class="slot ${cls}"><span class="slot-text">${slot.text}</span>${label}</span>`;
    });
    html += '</div></div>';
  });
  if (pattern.gloss) {
    html += `<div class="pattern-gloss">${pattern.gloss}</div>`;
  }
  html += '</div>';
  return html;
}

// 4-Sektionen-Backside für Karten ab L26 (mit pattern-Feld)
function buildSectionedBack(c) {
  let html = `<div class="rule">${c.rule}</div>`;
  // ① Bildung
  if (c.build && c.build.length > 0) {
    html += '<div class="sec"><span class="sec-label">① Bildung</span>';
    html += '<table class="conj-table"><tbody>';
    c.build.forEach(row => {
      html += `<tr><td>${row.form}</td><td>${row.verb}</td><td>${row.de}</td></tr>`;
    });
    html += '</tbody></table></div>';
  }
  // ② Satzbauplan
  html += buildPattern(c.pattern);
  // ③ Beispiele
  if (c.ex && c.ex.length > 0) {
    html += '<div class="sec"><span class="sec-label">③ Beispiele</span>';
    html += '<div class="examples">';
    c.ex.forEach(e => {
      html += `<div class="ex"><span class="jp">${e.jp}</span><span class="de">${e.de}</span></div>`;
    });
    html += '</div></div>';
  }
  // ④ Hinweise
  if (c.note) {
    html += `<div class="sec"><span class="sec-label">④ Hinweise</span><div class="note" style="border-top:none;padding-top:0;margin-top:0">${c.note}</div></div>`;
  }
  return html;
}

function render(){
  const q = search.value.toLowerCase().trim();
  const lf = lessonFilter.value;

  // SPEZIALFALL: Cheat-Sheets ausgewählt UND keine Suche
  if (lf === 'cheats' && !q) {
    overview.style.display = 'none';
    grid.innerHTML = '';
    grid.style.display = 'none';
    cheatsBlock.classList.remove('hidden');
    cheatToggle.textContent = 'Cheat-Sheets ausblenden';
    stats.innerHTML = `<b>📖</b> Cheat-Sheets`;
    backBtn.classList.add('visible');
    setTimeout(() => cheatsBlock.scrollIntoView({behavior:'smooth', block:'start'}), 50);
    return;
  }

  // Wenn Suche aktiv aber Cheats-Filter: switch zurück auf "all"
  if (lf === 'cheats' && q) {
    lessonFilter.value = 'all';
    cheatsBlock.classList.add('hidden');
    cheatToggle.textContent = 'Cheat-Sheets anzeigen';
    return render();
  }

  // SPEZIALFALL: "Alle" + keine Suche → nur Übersicht zeigen
  if (lf === 'all' && !q) {
    overview.style.display = 'block';
    grid.innerHTML = '';
    grid.style.display = 'none';
    stats.innerHTML = `<b>${CARDS.length}</b> Karten · ${lessons.length} Lektionen`;
    backBtn.classList.remove('visible');
    return;
  }

  // NORMAL: Karten rendern
  overview.style.display = 'none';
  grid.style.display = 'grid';
  backBtn.classList.add('visible');
  grid.innerHTML = '';
  let count = 0;
  CARDS.forEach((c) => {
    const matchLesson = (lf === 'all' || c.l == lf);
    const conjText = (c.conj || []).map(r => r.form + ' ' + r.verb + ' ' + r.de).join(' ');
    const buildText = (c.build || []).map(r => r.form + ' ' + r.verb + ' ' + r.de).join(' ');
    let patternText = '';
    if (c.pattern && c.pattern.slots) {
      const lines = Array.isArray(c.pattern.slots[0]) ? c.pattern.slots : [c.pattern.slots];
      patternText = lines.map(line => line.map(s => (s.text||'') + ' ' + (s.label||'')).join(' ')).join(' ');
      if (c.pattern.gloss) patternText += ' ' + c.pattern.gloss;
    }
    const exText = (c.ex || []).map(e => e.jp + ' ' + e.de).join(' ');
    const haystack = (c.t + ' ' + c.de + ' ' + c.rule + ' ' + conjText + ' ' + buildText + ' ' + patternText + ' ' + exText + ' L' + c.l + ' Lektion' + c.l).toLowerCase();
    const matchSearch = (!q || haystack.includes(q));
    if(!matchLesson || !matchSearch) return;
    count++;

    const card = document.createElement('div');
    card.className = 'card';
    const cstatus = getCardStatus(c);
    const statusIcon = getStatusIcon(cstatus.status);
    // Neue Sektionen-Struktur ab L26 (oder wenn pattern-Feld vorhanden)
    const useSectioned = !!c.pattern;
    const backInner = useSectioned ? buildSectionedBack(c) : `
          <div class="rule">${c.rule}</div>
          ${buildConjTable(c.conj)}
          <div class="examples">
            ${(c.ex||[]).map(e=>`<div class="ex"><span class="jp">${e.jp}</span><span class="de">${e.de}</span></div>`).join('')}
          </div>
          ${c.note ? `<div class="note">${c.note}</div>` : ''}
        `;
    card.innerHTML = `
      ${statusIcon ? `<span class="card-status">${statusIcon}</span>` : ''}
      <div class="front">
        <span class="lesson-tag">L ${String(c.l).padStart(2,'0')}</span>
        <div class="grammar-jp">${c.t}</div>
        <div class="grammar-de">${c.de}</div>
        <span class="flip-hint">umdrehen</span>
      </div>
      <div class="back">
        <div class="back-content">
          <span class="lesson-tag">L ${String(c.l).padStart(2,'0')} · ${c.de}</span>
          <h3>${c.t}</h3>
          ${backInner}
        </div>
      </div>
    `;
    card.addEventListener('click', () => card.classList.toggle('flipped'));
    grid.appendChild(card);
  });
  stats.innerHTML = `<b>${count}</b> Karte${count!==1?'n':''}`;
}

search.addEventListener('input', render);
lessonFilter.addEventListener('change', render);

backBtn.addEventListener('click', () => {
  lessonFilter.value = 'all';
  search.value = '';
  cheatsBlock.classList.add('hidden');
  cheatToggle.textContent = 'Cheat-Sheets anzeigen';
  render();
  window.scrollTo({top:0, behavior:'smooth'});
});

// Cheat-Toggle Button: ändert Filter statt direkter Toggle (saubere State-Verwaltung)
cheatToggle.addEventListener('click', () => {
  if (lessonFilter.value === 'cheats') {
    // Cheats sind aktiv → zurück zur Übersicht
    lessonFilter.value = 'all';
    search.value = '';
  } else {
    // Cheats aktivieren
    lessonFilter.value = 'cheats';
  }
  render();
});

// Floating to-top Button: nach 400px Scroll einblenden
const toTop = document.getElementById('toTop');
window.addEventListener('scroll', () => {
  if (window.scrollY > 400) toTop.classList.add('visible');
  else toTop.classList.remove('visible');
}, {passive:true});
toTop.addEventListener('click', () => {
  window.scrollTo({top:0, behavior:'smooth'});
});

// iOS Fix: Suchfeld nach Fokus zentrieren (Tastatur überdeckt sonst)
search.addEventListener('focus', () => {
  setTimeout(() => {
    search.scrollIntoView({behavior:'smooth', block:'center'});
  }, 300);
});

// TOC Smooth-Scroll mit Offset für Sticky-Header
document.querySelectorAll('.cheat-toc a').forEach(link => {
  link.addEventListener('click', (e) => {
    e.preventDefault();
    const target = document.querySelector(link.getAttribute('href'));
    if (target) {
      const y = target.getBoundingClientRect().top + window.scrollY - 10;
      window.scrollTo({top:y, behavior:'smooth'});
    }
  });
});

document.getElementById('randomBtn').addEventListener('click', () => {
  // Wenn Übersicht aktiv: zufällige Lektion + Karte zeigen
  if (overview.style.display !== 'none' && lessonFilter.value === 'all') {
    const randomCard = CARDS[Math.floor(Math.random() * CARDS.length)];
    lessonFilter.value = randomCard.l;
    render();
    setTimeout(() => {
      const cards = [...document.querySelectorAll('.card')];
      const matchIdx = cards.findIndex(c => c.querySelector('.grammar-jp').innerHTML === randomCard.t);
      const target = matchIdx >= 0 ? cards[matchIdx] : cards[Math.floor(Math.random()*cards.length)];
      if (target) {
        target.scrollIntoView({behavior:'smooth', block:'center'});
        setTimeout(() => target.classList.add('highlight'), 400);
      }
    }, 100);
    return;
  }
  // Sonst: zufällige aus aktuell sichtbaren Karten
  const visibleCards = [...document.querySelectorAll('.card')];
  if (visibleCards.length === 0) return;
  const target = visibleCards[Math.floor(Math.random() * visibleCards.length)];
  document.querySelectorAll('.card.highlight').forEach(c => c.classList.remove('highlight'));
  target.scrollIntoView({behavior:'smooth', block:'center'});
  setTimeout(() => target.classList.add('highlight'), 400);
});

render();
</script>

<!-- PWA Service Worker Registration -->

<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('service-worker.js')
        .then((reg) => console.log('SW registered:', reg.scope))
        .catch((err) => console.log('SW registration failed:', err));
    });
  }
</script>

</body>
</html>
