<div class="cheats hidden" id="cheats">

  <!-- TOC -->

  <div class="cheat-toc">
    <a href="#cheat-konditional">① Konditionale</a>
    <a href="#cheat-keigo">② Keigo-Verben</a>
    <a href="#cheat-konjugation">③ Konjugation</a>
